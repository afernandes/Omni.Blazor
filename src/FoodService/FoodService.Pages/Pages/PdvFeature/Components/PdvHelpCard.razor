@inject DialogService Dialog

@*  Help card: sintaxe do omnibox + atalhos F-keys. *@
<div class="fs-pdv-modal-body fs-pdv-help-card">
    <div>
        <div class="fs-pdv-modal-section-label">Sintaxe do Omni Box</div>
        <table class="fs-pdv-help-syntax-table">
            <thead>
                <tr><th>Comando</th><th>Resultado</th></tr>
            </thead>
            <tbody>
                <tr><td class="code">201</td><td>Adiciona 1× produto código 201</td></tr>
                <tr><td class="code">2x201</td><td>Adiciona 2× produto código 201</td></tr>
                <tr><td class="code">G101</td><td>Pizza Grande sabor 101</td></tr>
                <tr><td class="code">G101/102</td><td>Pizza Grande meio-a-meio 101/102</td></tr>
                <tr><td class="code">G101/102.C</td><td>Pizza Grande meio-a-meio + borda Catupiry</td></tr>
                <tr><td class="code">F107</td><td>Pizza Família sabor 107</td></tr>
                <tr><td class="code">B201</td><td>Pizza Broto sabor 201 (doce)</td></tr>
                <tr><td class="code">coca</td><td>Busca produtos por nome</td></tr>
            </tbody>
        </table>
        <div style="margin-top: 8px; font-size: 11.5px; color: var(--omni-fg-soft);">
            Borda: <b>.C</b> = Catupiry, <b>.K</b> = Cheddar, <b>.X</b> = Chocolate, <b>.R</b> = Cream cheese
        </div>
    </div>

    <div>
        <div class="fs-pdv-modal-section-label">Atalhos de teclado</div>
        <div class="fs-pdv-help-shortcuts">
            <div class="fs-pdv-help-shortcut"><kbd>⌘K</kbd> <span class="fs-pdv-help-shortcut-label">Foco no Omni Box</span></div>
            <div class="fs-pdv-help-shortcut"><kbd>F2</kbd> <span class="fs-pdv-help-shortcut-label">Cardápio</span></div>
            <div class="fs-pdv-help-shortcut"><kbd>F5</kbd> <span class="fs-pdv-help-shortcut-label">Finalizar pedido</span></div>
            <div class="fs-pdv-help-shortcut"><kbd>F9</kbd> <span class="fs-pdv-help-shortcut-label">Limpar pedido</span></div>
            <div class="fs-pdv-help-shortcut"><kbd>Ctrl + N</kbd> <span class="fs-pdv-help-shortcut-label">Pausar &amp; iniciar novo</span></div>
            <div class="fs-pdv-help-shortcut"><kbd>Esc</kbd> <span class="fs-pdv-help-shortcut-label">Fechar painel</span></div>
            <div class="fs-pdv-help-shortcut"><kbd>↑ / ↓</kbd> <span class="fs-pdv-help-shortcut-label">Navegar sugestões</span></div>
            <div class="fs-pdv-help-shortcut"><kbd>Enter</kbd> <span class="fs-pdv-help-shortcut-label">Adicionar item</span></div>
        </div>
    </div>

    <div class="fs-pdv-adj-actions">
        <button class="fs-pdv-btn fs-pdv-btn-primary" @onclick="@(() => Dialog.Close(null))">Fechar</button>
    </div>
</div>
