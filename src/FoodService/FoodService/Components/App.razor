@*  Root document do FoodService — host Server interactive.
    Carrega Omni.Blazor (CSS bundle + JS) e o assembly FoodService.Pages
    (Routes + layouts + pages). *@
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <base href="/" />
    <title>FoodService — PDV</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <OmniTheme Accent="crimson" />
    <link rel="stylesheet" href="@Assets["_content/FoodService.Pages/css/foodservice.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>
<body>
    <FoodService.Pages.Routes @rendermode="InteractiveServer" />
    <script src="@Assets["_content/Omni.Blazor/js/Omni.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>
</html>
