@inherits LayoutComponentBase
@layout AppShell
@implements IDisposable
@using Forneria.Demo.Pages.Layout
@using Omni.Blazor.Models
@using Microsoft.AspNetCore.Components.Routing
@inject Microsoft.AspNetCore.Components.NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JS

@* Component browser. Nav is auto-built from every routable /showcase page (ShowcaseCatalog):
   nested routes become collapsible submenus; categories are collapsible; live filter
   (accent-insensitive + synonyms) with match highlight; per-category counts; "Novo" badges;
   and ⌘K jumps to any component. Styles live in ShowcaseLayout.razor.css (CSS isolation). *@

<div class="sc-shell">
    <OmniSplitView AsideSize="ComponentSize.Lg">
        <AsideContent>
            <div class="sc-aside">
                <div class="sc-aside-head">
                    <div class="sc-aside-search">
                        <OmniIcon Name="search" Size="ComponentSize.Sm" />
                        <input type="search" value="@_query" @oninput="OnSearch"
                               placeholder="Filtrar componentes…  (⌘K p/ pular)" aria-label="Filtrar componentes"
                               autocomplete="off" spellcheck="false" />
                        @if (_query.Length > 0)
                        {
                            <button type="button" class="sc-aside-clear" @onclick="Clear" aria-label="Limpar">
                                <OmniIcon Name="x" Size="ComponentSize.Sm" />
                            </button>
                        }
                    </div>
                    <div class="sc-aside-count">
                        @if (_query.Length == 0)
                        {
                            <span><strong>@ShowcaseCatalog.All.Count</strong> componentes</span>
                        }
                        else
                        {
                            <span><strong>@_matchedCount</strong> de @ShowcaseCatalog.All.Count</span>
                        }
                    </div>
                </div>

                <div class="sc-aside-list">
                    @{ var roots = VisibleRoots().ToList(); }
                    @if (roots.Count == 0)
                    {
                        <div class="sc-aside-empty">
                            <OmniIcon Name="search" />
                            <span>Nenhum componente para “@_query”.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var group in roots.GroupBy(l => (l.Category, l.CategoryOrder)).OrderBy(g => g.Key.CategoryOrder))
                        {
                            var cat = group.Key.Category;
                            var collapsed = _query.Length == 0 && _collapsed.Contains(cat);
                            <button type="button" class="sc-cat" @onclick="@(() => ToggleCat(cat))" aria-expanded="@(!collapsed)">
                                <OmniIcon Name="@(collapsed ? "chevron-right" : "chevron-down")" Size="ComponentSize.Sm" />
                                <span class="sc-cat-name">@cat</span>
                                <span class="sc-cat-count">@(CategoryTotals.GetValueOrDefault(cat))</span>
                            </button>
                            @if (!collapsed)
                            {
                                <OmniPanelMenu>
                                    @foreach (var root in group)
                                    {
                                        var kids = VisibleChildren(root.Path);
                                        @if (kids.Count == 0)
                                        {
                                            <OmniPanelMenuItem Text="@root.Title" TextContent="@Lbl(root.Title)" Icon="@root.Icon" Path="@root.Path"
                                                               Match="@(root.Path == "/showcase" ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                                                               CountText="@BadgeText(root)" CountKind="@BadgeKind(root)" />
                                        }
                                        else
                                        {
                                            <OmniPanelMenuItem Text="@root.Title" TextContent="@Lbl(root.Title)" Icon="@root.Icon"
                                                               Expanded="@(_query.Length > 0 || IsUnder(root.Path))">
                                                <ChildContent>
                                                    <OmniPanelMenuItem Text="Galeria" Icon="@root.Icon" Path="@root.Path" Match="NavLinkMatch.All" />
                                                    @foreach (var kid in kids)
                                                    {
                                                        <OmniPanelMenuItem Text="@kid.Title" TextContent="@Lbl(kid.Title)" Icon="@kid.Icon" Path="@kid.Path"
                                                                           Match="NavLinkMatch.Prefix"
                                                                           CountText="@BadgeText(kid)" CountKind="@BadgeKind(kid)" />
                                                    }
                                                </ChildContent>
                                            </OmniPanelMenuItem>
                                        }
                                    }
                                </OmniPanelMenu>
                            }
                        }
                    }
                </div>
            </div>
        </AsideContent>
        <ChildContent>
            @Body
        </ChildContent>
    </OmniSplitView>
</div>

@* ⌘K / Ctrl+K — jump to any of the discovered components. *@
<OmniCommandPalette Commands="_commands" HistoryKey="showcase" />

@code {
    // ── tree (computed once from the catalog) ───────────────────────────────
    private static readonly Dictionary<string, string> ParentOf = BuildParents();
    private static readonly List<ShowcaseLink> Roots =
        ShowcaseCatalog.All.Where(l => !ParentOf.ContainsKey(l.Path)).ToList();
    private static readonly Dictionary<string, List<ShowcaseLink>> ChildrenOf =
        ShowcaseCatalog.All.Where(l => ParentOf.ContainsKey(l.Path))
            .GroupBy(l => ParentOf[l.Path])
            .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.OrdinalIgnoreCase);
    private static readonly Dictionary<string, int> CategoryTotals =
        ShowcaseCatalog.All.GroupBy(l => l.Category).ToDictionary(g => g.Key, g => g.Count());

    private static Dictionary<string, string> BuildParents()
    {
        var paths = ShowcaseCatalog.All.Select(l => l.Path).ToList();
        var map = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var path in paths)
        {
            string? best = null;
            foreach (var p in paths)
            {
                if (string.Equals(p, "/showcase", StringComparison.OrdinalIgnoreCase)) continue;
                if (string.Equals(p, path, StringComparison.OrdinalIgnoreCase)) continue;
                if (path.StartsWith(p + "/", StringComparison.OrdinalIgnoreCase) && (best is null || p.Length > best.Length))
                    best = p;
            }
            if (best is not null) map[path] = best;
        }
        return map;
    }

    // ── state ────────────────────────────────────────────────────────────────
    private OmniCommand[] _commands = Array.Empty<OmniCommand>();
    private string _query = "";
    private HashSet<string>? _visible;                       // null = show everything
    private int _matchedCount = ShowcaseCatalog.All.Count;
    private readonly HashSet<string> _collapsed = new(StringComparer.OrdinalIgnoreCase);
    private bool _scrollPending;

    protected override void OnInitialized()
    {
        _commands = ShowcaseCatalog.All.Select(l =>
        {
            var path = l.Path;
            return new OmniCommand(l.Title) { Category = l.Category, Icon = l.Icon, Action = () => { Nav.NavigateTo(path); return Task.CompletedTask; } };
        }).ToArray();
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _scrollPending = true;
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _scrollPending)
        {
            _scrollPending = false;
            try { await JS.InvokeVoidAsync("omniBlazor.scrollIntoView", ".sc-aside-list .omni-active", "nearest"); }
            catch { }
        }
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    // ── filter ─────────────────────────────────────────────────────────────────
    private void OnSearch(ChangeEventArgs e) { _query = e.Value?.ToString() ?? ""; Recompute(); }
    private void Clear() { _query = ""; Recompute(); }
    private void ToggleCat(string cat) { if (!_collapsed.Remove(cat)) _collapsed.Add(cat); }

    private void Recompute()
    {
        var q = _query.Trim();
        if (q.Length == 0) { _visible = null; _matchedCount = ShowcaseCatalog.All.Count; return; }

        var matched = ShowcaseCatalog.All.Where(l => Matches(l, q)).ToList();
        _matchedCount = matched.Count;

        var vis = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var m in matched)
        {
            vis.Add(m.Path);
            for (var p = ParentOf.GetValueOrDefault(m.Path); p is not null; p = ParentOf.GetValueOrDefault(p))
                vis.Add(p);
            foreach (var d in ShowcaseCatalog.All)
                if (d.Path.StartsWith(m.Path + "/", StringComparison.OrdinalIgnoreCase)) vis.Add(d.Path);
        }
        _visible = vis;
    }

    private bool IsVisible(ShowcaseLink l) => _visible is null || _visible.Contains(l.Path);
    private IEnumerable<ShowcaseLink> VisibleRoots() => Roots.Where(IsVisible);
    private List<ShowcaseLink> VisibleChildren(string path)
        => ChildrenOf.TryGetValue(path, out var list) ? list.Where(IsVisible).ToList() : new();

    private bool IsUnder(string path)
    {
        var cur = "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].TrimEnd('/');
        return cur.StartsWith(path + "/", StringComparison.OrdinalIgnoreCase);
    }

    private static bool Matches(ShowcaseLink l, string q)
    {
        var f = Fold(q);
        if (Fold(l.Title).Contains(f) || Fold(l.Category).Contains(f)) return true;
        foreach (var a in ShowcaseCatalog.AliasesOf(l.Path))
            if (Fold(a).Contains(f)) return true;
        return false;
    }

    // Nav badge: flagship/advanced differentiators get an accent "★ Destaque"; genuinely-new
    // components get a green "Novo" (reserved for future use). Featured wins if both are set.
    private static string? BadgeText(ShowcaseLink l) => l.Featured ? "★ Destaque" : l.IsNew ? "Novo" : null;
    private static MenuMetaKind BadgeKind(ShowcaseLink l) => l.Featured ? MenuMetaKind.Accent : MenuMetaKind.Good;

    // ── match highlight (best-effort: case-insensitive on the original text) ──
    private RenderFragment Lbl(string text) => builder =>
    {
        var q = _query.Trim();
        var idx = q.Length == 0 ? -1 : text.IndexOf(q, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) { builder.AddContent(0, text); return; }
        var seq = 0;
        if (idx > 0) builder.AddContent(seq++, text[..idx]);
        builder.OpenElement(seq++, "mark");
        builder.AddAttribute(seq++, "class", "sc-hl");
        builder.AddContent(seq++, text.Substring(idx, q.Length));
        builder.CloseElement();
        var rest = idx + q.Length;
        if (rest < text.Length) builder.AddContent(seq++, text[rest..]);
    };

    // lowercase + strip accents so "visao" matches "Visão", "botao" matches "Botões".
    private static string Fold(string s)
    {
        var d = s.Normalize(System.Text.NormalizationForm.FormD);
        var sb = new System.Text.StringBuilder(d.Length);
        foreach (var c in d)
            if (System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c) != System.Globalization.UnicodeCategory.NonSpacingMark)
                sb.Append(char.ToLowerInvariant(c));
        return sb.ToString();
    }
}
