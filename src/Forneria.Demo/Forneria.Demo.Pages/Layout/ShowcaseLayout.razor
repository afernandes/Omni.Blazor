@inherits LayoutComponentBase
@layout AppShell

@* Bootstrap-style component browser: categorized sub-sidebar + main pane.
   Every component in the library has a dedicated page reachable from here. *@

<OmniSplitView AsideSize="ComponentSize.Lg">
    <AsideContent>
        <OmniSplitAsideLabel Text="Overview" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Começar" Icon="zap" Path="/showcase/get-started" />
            <OmniPanelMenuItem Text="Bem-vindo" Icon="grid" Path="/showcase" Match="NavLinkMatch.All" />
            <OmniPanelMenuItem Text="Typography" Icon="file-text" Path="/showcase/typography" />
            <OmniPanelMenuItem Text="Theme & tokens" Icon="zap" Path="/showcase/theme" />
            <OmniPanelMenuItem Text="Theme Picker + Density" Icon="settings" Path="/showcase/theme-picker" />
            <OmniPanelMenuItem Text="Appearance Toggle" Icon="sun" Path="/showcase/appearance-toggle" />
            <OmniPanelMenuItem Text="Acessibilidade (a11y)" Icon="shield" Path="/showcase/a11y" />
            <OmniPanelMenuItem Text="UX Markers (HTML)" Icon="command" Path="/showcase/ux-markers" />
            <OmniPanelMenuItem Text="Breakpoints" Icon="grid" Path="/showcase/breakpoints" />
            <OmniPanelMenuItem Text="Hidden (por viewport)" Icon="zap" Path="/showcase/hidden" />
            <OmniPanelMenuItem Text="Media Query (headless)" Icon="zap" Path="/showcase/media-query" />
            <OmniPanelMenuItem Text="Scroll manager" Icon="arrow-up" Path="/showcase/scroll" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Estrutura & Layout" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Layout & SplitView" Icon="layout-dashboard" Path="/showcase/layout" />
            <OmniPanelMenuItem Text="Auth Layout"        Icon="lock"             Path="/showcase/auth-layout" />
            <OmniPanelMenuItem Text="Wireframes (LEGO)" Icon="layout"            Path="/showcase/wireframes" />
            <OmniPanelMenuItem Text="Container"          Icon="package"          Path="/showcase/container" />
            <OmniPanelMenuItem Text="Grid 12 (Row+Col)"  Icon="grid"             Path="/showcase/grid" />
            <OmniPanelMenuItem Text="Splitter"           Icon="layout-dashboard" Path="/showcase/splitter" />
            <OmniPanelMenuItem Text="Swipe Area"         Icon="zap"              Path="/showcase/swipearea" />
            <OmniPanelMenuItem Text="Stack"              Icon="list"             Path="/showcase/stack" />
            <OmniPanelMenuItem Text="TileGroup"          Icon="package"          Path="/showcase/tile-group" />
            <OmniPanelMenuItem Text="Panel menu"         Icon="list"             Path="/showcase/panel-menu" />
            <OmniPanelMenuItem Text="Menu bar"           Icon="menu"             Path="/showcase/menubar" />
            <OmniPanelMenuItem Text="Exit Prompt"        Icon="alert-triangle"   Path="/showcase/exit-prompt" />
            <OmniPanelMenuItem Text="Hotkeys"            Icon="command"          Path="/showcase/hotkeys" />
            <OmniPanelMenuItem Text="Key Interceptor"    Icon="command"          Path="/showcase/key-interceptor" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Navegação" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Breadcrumb"         Icon="chevron-right"    Path="/showcase/breadcrumb" />
            <OmniPanelMenuItem Text="Tabs"               Icon="grid"             Path="/showcase/tabs" />
            <OmniPanelMenuItem Text="Segmented control"  Icon="grid"             Path="/showcase/segmented" />
            <OmniPanelMenuItem Text="Pagination"         Icon="chevron-right"    Path="/showcase/pagination" />
            <OmniPanelMenuItem Text="Stepper"            Icon="check-circle"     Path="/showcase/stepper" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Buttons" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Button"                 Icon="package" Path="/showcase/buttons" />
            <OmniPanelMenuItem Text="Split & Toggle Button"  Icon="layers"  Path="/showcase/split-toggle-button" />
            <OmniPanelMenuItem Text="FAB & FabMenu"          Icon="plus"    Path="/showcase/fab" />
            <OmniPanelMenuItem Text="Social Button"          Icon="lock"    Path="/showcase/social-button" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Inputs básicos" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="TextBox / Password / TextArea" Icon="edit"        Path="/showcase/textbox" />
            <OmniPanelMenuItem Text="Numeric"                       Icon="dollar-sign" Path="/showcase/numeric" />
            <OmniPanelMenuItem Text="Qty Stepper"                   Icon="plus"        Path="/showcase/qty-stepper" />
            <OmniPanelMenuItem Text="Masked TextBox"                Icon="tag"         Path="/showcase/masked" />
            <OmniPanelMenuItem Text="Security Code (OTP)"           Icon="lock"        Path="/showcase/security-code" />
            <OmniPanelMenuItem Text="DatePicker & Range"            Icon="calendar"    Path="/showcase/datepicker" />
            <OmniPanelMenuItem Text="Slider & Rating"               Icon="sliders"     Path="/showcase/slider-rating" />
            <OmniPanelMenuItem Text="Speech to Text"                Icon="mic"         Path="/showcase/speech-to-text" />
            <OmniPanelMenuItem Text="Password Strength"             Icon="lock"        Path="/showcase/password-strength" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Seleção & avançados" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Select & AutoComplete"         Icon="search"      Path="/showcase/select" />
            <OmniPanelMenuItem Text="CheckBox / Switch / Radio"     Icon="check"       Path="/showcase/checkbox-switch-radio" />
            <OmniPanelMenuItem Text="CheckBoxList / ListBox / Multi" Icon="list"       Path="/showcase/selection-extras" />
            <OmniPanelMenuItem Text="Pick List"                     Icon="columns"     Path="/showcase/picklist" />
            <OmniPanelMenuItem Text="File Upload"                   Icon="upload"      Path="/showcase/upload" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Formulários" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="FormField & Validation"        Icon="help-circle" Path="/showcase/formfield" />
            <OmniPanelMenuItem Text="Form Validation (OmniForm)"   Icon="shield"      Path="/showcase/form-validation" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Data display" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Card"         Icon="package"     Path="/showcase/card" />
            <OmniPanelMenuItem Text="Card Group"   Icon="columns"     Path="/showcase/card-group" />
            <OmniPanelMenuItem Text="Result (status)" Icon="alert-circle" Path="/showcase/result" />
            <OmniPanelMenuItem Text="Empty State"  Icon="inbox"       Path="/showcase/empty-state" />
            <OmniPanelMenuItem Text="Badge & Chip" Icon="tag"         Path="/showcase/badge-chip" />
            <OmniPanelMenuItem Text="Label & Link" Icon="link"        Path="/showcase/label-link" />
            <OmniPanelMenuItem Text="Avatar"       Icon="user"        Path="/showcase/avatar" />
            <OmniPanelMenuItem Text="Avatar Group" Icon="users"       Path="/showcase/avatar-group" />
            <OmniPanelMenuItem Text="Image"        Icon="image"       Path="/showcase/image" />
            <OmniPanelMenuItem Text="Carousel"     Icon="film"        Path="/showcase/carousel" />
            <OmniPanelMenuItem Text="Stat"         Icon="trending-up" Path="/showcase/stat" />
            <OmniPanelMenuItem Text="Stat Group"   Icon="grid"        Path="/showcase/stat-group" />
            <OmniPanelMenuItem Text="Description List" Icon="list"     Path="/showcase/description-list" />
            <OmniPanelMenuItem Text="Option Card"  Icon="check-circle" Path="/showcase/option-card" />
            <OmniPanelMenuItem Text="Progress"     Icon="bar-chart"   Path="/showcase/progress" />
            <OmniPanelMenuItem Text="Progress Circular" Icon="loader" Path="/showcase/progress-circular" />
            <OmniPanelMenuItem Text="Accordion"    Icon="list"        Path="/showcase/accordion" />
            <OmniPanelMenuItem Text="Timeline"     Icon="clock"       Path="/showcase/timeline" />
            <OmniPanelMenuItem Text="Markdown"     Icon="file-text"   Path="/showcase/markdown" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Utilitários" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Icon"     Icon="star"            Path="/showcase/icons" />
            <OmniPanelMenuItem Text="Kbd"      Icon="grid"            Path="/showcase/kbd" />
            <OmniPanelMenuItem Text="Skeleton" Icon="more-horizontal" Path="/showcase/skeleton" />
            <OmniPanelMenuItem Text="Spinner & Loading" Icon="refresh" Path="/showcase/loading" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Feedback & overlay" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Alert"         Icon="alert-triangle" Path="/showcase/alert" />
            <OmniPanelMenuItem Text="Banner"        Icon="alert-triangle" Path="/showcase/banner" />
            <OmniPanelMenuItem Text="Dialog"        Icon="alert-circle"   Path="/showcase/dialog" />
            <OmniPanelMenuItem Text="Confirm Prompt" Icon="alert-triangle" Path="/showcase/confirm-prompt" />
            <OmniPanelMenuItem Text="Command Palette (⌘K)" Icon="search" Path="/showcase/command-palette" />
            <OmniPanelMenuItem Text="Notification"  Icon="bell"           Path="/showcase/notification" />
            <OmniPanelMenuItem Text="Tooltip"       Icon="info"           Path="/showcase/tooltip" />
            <OmniPanelMenuItem Text="Popover"       Icon="more-horizontal" Path="/showcase/popover" />
            <OmniPanelMenuItem Text="Context menu"  Icon="more-vertical"  Path="/showcase/context-menu" />
            <OmniPanelMenuItem Text="Overlay"       Icon="layers"         Path="/showcase/overlay" />
            <OmniPanelMenuItem Text="Bottom Sheet"  Icon="layers"         Path="/showcase/bottom-sheet" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Data" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="DataGrid"   Icon="list"          Path="/showcase/datagrid" />
            <OmniPanelMenuItem Text="Data Filter" Icon="filter"       Path="/showcase/datafilter" />
            <OmniPanelMenuItem Text="Pivot Grid" Icon="grid"          Path="/showcase/pivot" />
            <OmniPanelMenuItem Text="HTML Editor" Icon="edit"         Path="/showcase/html-editor" />
            <OmniPanelMenuItem Text="Chat"       Icon="message-square" Path="/showcase/chat" />
            <OmniPanelMenuItem Text="Tree"       Icon="folder"        Path="/showcase/tree" />
            <OmniPanelMenuItem Text="Scheduler"  Icon="calendar"      Path="/showcase/scheduler" />
            <OmniPanelMenuItem Text="Gantt"      Icon="bar-chart"     Path="/showcase/gantt" />
            <OmniPanelMenuItem Text="DropZone"   Icon="layers"        Path="/showcase/dropzone" />
            <OmniPanelMenuItem Text="Virtualize" Icon="grid"     Path="/showcase/virtualize" />
            <OmniPanelMenuItem Text="Diagram"    Icon="workflow"      Path="/showcase/diagram" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Data viz" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Sparkline" Icon="trending-up" Path="/showcase/sparkline" />
            <OmniPanelMenuItem Text="Chart"     Icon="bar-chart"   Path="/showcase/chart" />
            <OmniPanelMenuItem Text="Barcode"   Icon="grid"        Path="/showcase/barcode" />
            <OmniPanelMenuItem Text="QR Code"   Icon="grid"        Path="/showcase/qrcode" />
        </OmniPanelMenu>

        <OmniSplitAsideLabel Text="Marketing" />
        <OmniPanelMenu>
            <OmniPanelMenuItem Text="Hero, Eyebrow & Mosaic" Icon="star" Path="/showcase/marketing" />
        </OmniPanelMenu>
    </AsideContent>
    <ChildContent>
        @Body
    </ChildContent>
</OmniSplitView>
