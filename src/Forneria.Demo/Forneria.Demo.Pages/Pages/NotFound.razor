@page "/not-found"
@layout MarketingLayout

<PageTitle>Página não encontrada — Forneria</PageTitle>

<OmniHero Title="Página não encontrada"
           Subtitle="A rota que você acessou não existe ou foi movida. Volte para o início ou explore os componentes.">
    <EyebrowContent>
        <OmniEyebrow Text="ERRO 404" />
    </EyebrowContent>
    <CtaContent>
        <a href="/" class="omni-btn omni-btn-primary omni-btn-lg">
            <span>Voltar ao início</span>
        </a>
        <a href="/showcase/buttons" class="omni-btn omni-btn-lg">
            <span>Ver componentes</span>
        </a>
    </CtaContent>
</OmniHero>
