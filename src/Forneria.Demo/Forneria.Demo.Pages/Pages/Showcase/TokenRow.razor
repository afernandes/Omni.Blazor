@* Small helper used by the Theme showcase page to render a token swatch + name. *@

<div class="omni-row omni-row-gap-12" style="padding: 8px 10px; border: 1px solid var(--omni-line); border-radius: 6px; background: var(--omni-bg-elev);">
    <span style="display:inline-block;width:28px;height:28px;border-radius:6px;background:@Color;border:1px solid var(--omni-line);"></span>
    <span class="omni-mono" style="font-size: 12px;">@Name</span>
</div>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = "";
    [Parameter, EditorRequired] public string Color { get; set; } = "";
}
