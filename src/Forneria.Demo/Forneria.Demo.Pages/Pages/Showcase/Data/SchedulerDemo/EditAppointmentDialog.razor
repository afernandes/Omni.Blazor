@namespace Forneria.Demo.Pages.Pages.Showcase.Data.SchedulerDemo
@using Omni.Blazor.Services
@inject DialogService DialogService

<div class="fs-sched-form">
    <label class="fs-sched-field">
        <span>Título</span>
        <OmniTextBox @bind-Value="_model.Text" Placeholder="Título do evento" />
    </label>
    <label class="fs-sched-field">
        <span>Início</span>
        <OmniDatePicker TValue="DateTime" @bind-Value="_model.Start" ShowTime="true" />
    </label>
    <label class="fs-sched-field">
        <span>Fim</span>
        <OmniDatePicker TValue="DateTime" @bind-Value="_model.End" ShowTime="true" />
    </label>
    <div class="fs-sched-actions">
        <OmniButton Variant="ButtonVariant.Danger" Text="Excluir" OnClick="@(() => DialogService.Close("delete"))" />
        <div style="flex:1"></div>
        <OmniButton Variant="ButtonVariant.Default" Text="Cancelar" OnClick="@(() => DialogService.Close(null))" />
        <OmniButton Variant="ButtonVariant.Primary" Text="Salvar" OnClick="@(() => DialogService.Close(_model))" />
    </div>
</div>

@code {
    [Parameter] public SchedulerAppointment Appointment { get; set; } = new();

    // Edit a copy; the page applies changes to the original on save.
    private readonly SchedulerAppointment _model = new();
    private bool _seeded;

    protected override void OnParametersSet()
    {
        if (_seeded) return;
        _seeded = true;
        _model.Start = Appointment.Start;
        _model.End = Appointment.End;
        _model.Text = Appointment.Text;
    }
}
