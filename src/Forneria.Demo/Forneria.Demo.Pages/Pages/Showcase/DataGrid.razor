@code {
    private static readonly System.Globalization.CultureInfo _ptBr =
        System.Globalization.CultureInfo.GetCultureInfo("pt-BR");

    private List<Order> _inMemory = new();
    private HashSet<Order> _selected = new();
    private string? _lastResize;

    // —— Hierarquia (tree-grid) ——
    private OmniDataGrid<SharingNode>? _treeGridRef;
    private string? _treeSearch;
    private bool _pendingTreeAutoExpand;

    private void OnTreeSearchChangedAsync(string? value)
    {
        _treeSearch = value;
        // Após o grid receber a nova lista filtrada (que só preserva matches +
        // ancestrais), forçamos expand-all para que o caminho até o item ache
        // localizado fique visível. Limpa o termo → não força collapse: respeita
        // o que o usuário expandiu manualmente.
        if (!string.IsNullOrWhiteSpace(value))
            _pendingTreeAutoExpand = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingTreeAutoExpand && _treeGridRef is not null)
        {
            _pendingTreeAutoExpand = false;
            await _treeGridRef.ExpandAllAsync();
        }
    }

    private sealed record SharingNode(
        string Nome,
        string IdProprietario,
        string IdLoja,
        string? IdPai,
        int? Nivel,
        bool IsCurrent,
        bool IsInconsistent,
        List<SharingNode>? Children);

    private List<SharingNode> _sharingRoots = new()
    {
        new SharingNode("OMNI Holding Brasil", "PROP-001", "0001", null, 1, false, false, new()
        {
            new SharingNode("Regional Sul", "PROP-001", "0010", "0001", 2, false, false, new()
            {
                new SharingNode("OMNI Large Enterprise Tecnologia", "PROP-001", "0100", "0010", 3, true, false, null),
                new SharingNode("OMNI Porto Alegre Centro",         "PROP-001", "0101", "0010", 3, false, false, null),
                new SharingNode("OMNI Canoas",                      "PROP-001", "0102", "0010", 3, false, false, null),
            }),
            new SharingNode("Regional Centro-Oeste", "PROP-001", "0020", "0001", 2, false, false, new()
            {
                new SharingNode("OMNI Curitiba",      "PROP-001", "0200", "0020", 3, false, false, null),
                new SharingNode("OMNI Florianópolis", "PROP-001", "0201", "0020", 3, false, false, null),
            }),
            new SharingNode("Regional Sudeste", "PROP-002", "0030", "0001", 2, false, false, null),
        }),
        new SharingNode("Filial Órfã (pai não encontrado)", "PROP-003", "0999", "0099", null, false, true, null),
    };

    private IEnumerable<SharingNode> FilteredSharing
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_treeSearch)) return _sharingRoots;
            var q = _treeSearch.Trim();
            // Filtro mantém a árvore (parents que tenham descendentes matching)
            return _sharingRoots
                .Select(r => MatchTree(r, q))
                .Where(r => r is not null)!
                .Cast<SharingNode>()
                .ToList();
        }
    }

    private static SharingNode? MatchTree(SharingNode n, string q)
    {
        bool selfMatches =
            n.Nome.Contains(q, StringComparison.OrdinalIgnoreCase) ||
            n.IdProprietario.Contains(q, StringComparison.OrdinalIgnoreCase) ||
            n.IdLoja.Contains(q, StringComparison.OrdinalIgnoreCase);
        var keptChildren = n.Children?
            .Select(c => MatchTree(c, q))
            .Where(c => c is not null)!
            .Cast<SharingNode>()
            .ToList();
        if (selfMatches || (keptChildren is { Count: > 0 }))
            return n with { Children = keptChildren };
        return null;
    }

    private static int CountAll(IEnumerable<SharingNode> nodes) =>
        nodes.Sum(n => 1 + (n.Children is null ? 0 : CountAll(n.Children)));

    // —— Empty/Loading template demo ——
    private int _emptyDemoState; // 0=dados, 1=vazio, 2=loading

    private async Task<GridLoadResult<Order>> DemoLoadAsync(GridState<Order> state)
    {
        if (_emptyDemoState == 2)
        {
            // Simula loading longo: fica ~1s antes de retornar
            await Task.Delay(1200);
            _emptyDemoState = 0; // volta pra "dados" após o load
            StateHasChanged();
        }
        if (_emptyDemoState == 1)
        {
            // Vazio: retorna zero items
            return new GridLoadResult<Order>(Array.Empty<Order>(), 0);
        }
        // Estado normal: retorna uma página
        var page = Orders.AllOrders.Skip(state.Skip).Take(Math.Min(state.Top, 12)).ToList();
        return new GridLoadResult<Order>(page, 12);
    }

    private async Task OnDemoLoadAsync()
    {
        _emptyDemoState = 2;
        await Task.CompletedTask;
        StateHasChanged();
    }

    private Task OnEmptyCtaClickAsync()
    {
        Toast.Success("Demo", "Botão CTA do EmptyTemplate funciona!");
        return Task.CompletedTask;
    }

    private static BadgeVariant LevelBadgeVariant(int? n) => n switch
    {
        1 => BadgeVariant.Info,
        2 => BadgeVariant.Plain,
        3 => BadgeVariant.Good,
        null => BadgeVariant.Danger,
        _ => BadgeVariant.Default
    };

    protected override void OnInitialized()
    {
        // Pega só 24 do total pra demos client-side
        var rng = new Random(7);
        _inMemory = Enumerable.Range(1, 24)
            .Select(_ => Orders.ItemAtRandom(rng))
            .ToList();
    }

    private static BadgeVariant StatusVariant(string s) => s switch
    {
        "Pronto" => BadgeVariant.Good,
        "Em preparo" => BadgeVariant.Warn,
        "Pendente" => BadgeVariant.Info,
        "Entregue" => BadgeVariant.Plain,
        "Cancelado" => BadgeVariant.Danger,
        _ => BadgeVariant.Default,
    };

    private void OnBulkCancel()
    {
        Toast.Notify(NotificationSeverity.Success, "Bulk action",
            $"{_selected.Count} pedidos marcados como cancelados.");
        _selected.Clear();
    }

    private RenderFragment<Order> RenderOrderDetail => order => __builder =>
    {
        var items = Orders.ItemsOf(order);
        <div class="omni-stack omni-stack-8">
            <div class="omni-mono omni-muted" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">
                Pedido #@order.Numero · @order.Cliente · @order.Canal
            </div>
            <ul class="omni-stack omni-stack-4" style="padding-left: 1.25rem; margin: 0;">
                @foreach (var it in items)
                {
                    <li class="omni-mono" style="font-size: 13px;">@it</li>
                }
            </ul>
        </div>
    };
}
