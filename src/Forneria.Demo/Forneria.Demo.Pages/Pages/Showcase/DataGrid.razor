@page "/showcase/datagrid"
@layout ShowcaseLayout
@using Forneria.Demo.Pages.Services
@inject FakeOrderService Orders
@inject NotificationService Toast

<PageTitle>DataGrid — Showcase</PageTitle>

<ShowcasePage Title="OmniDataGrid"
              Subtitle="Tabela de dados completa — server-side, multi-sort, agregações, filtros por coluna, seleção, master-detail, hierarquia e virtualização.">

    <Overview>
        <p>
            O <code>OmniDataGrid&lt;TItem&gt;</code> é o componente de tabela da biblioteca,
            desenhado para telas de listagem de qualquer escala. Trabalha em <strong>dois
            modos de dados</strong>: in-memory via <code>Data</code> (filtro, ordenação e
            paginação calculados no cliente) ou server-side via <code>LoadData</code>, onde
            o grid delega tudo ao consumidor e renderiza apenas a janela retornada.
        </p>
        <p>
            As colunas são declaradas com <code>OmniDataGridColumn&lt;TItem&gt;</code> dentro
            do slot <code>Columns</code>. O grid suporta ordenação multi-coluna (Shift+clique),
            linha de agregações no rodapé, filtros por coluna, seleção múltipla com checkbox,
            expansão master-detail, modo árvore (tree-grid) via <code>ChildrenSelector</code> e
            virtualização do <code>&lt;tbody&gt;</code> para milhares de registros. Colunas
            podem ser congeladas (<code>Frozen</code>), ocultadas e exportadas para CSV.
        </p>
    </Overview>

    <WhenToUse>
        <ul>
            <li>Listar registros tabulares — pedidos, clientes, produtos, transações.</li>
            <li>Datasets grandes que precisam de paginação ou virtualização server-side.</li>
            <li>Telas que exigem ordenação, filtros, seleção em massa ou exportação.</li>
            <li>Estruturas hierárquicas (árvores) com expansão por nível.</li>
        </ul>
    </WhenToUse>

    <WhenNotToUse>
        <ul>
            <li>Listas simples sem colunas nem ordenação → use uma lista ou cards.</li>
            <li>Exibir um único registro em detalhe → use um layout de formulário.</li>
            <li>Coleções pequenas e visuais (galeria) → use <code>OmniMosaic</code> ou grid de cards.</li>
        </ul>
    </WhenNotToUse>

    <ChildContent>
        <ShowcaseSection Title="Básico (in-memory)"
                         Description="Pipeline client-side: sort em uma coluna, busca global, paginação de 6 em 6."
                         Code="@(@"<OmniDataGrid TItem=""Order"" Data=""@_inMemory"" AllowSearch AllowPaging PageSize=""6"">
    <Columns>
        <OmniDataGridColumn TItem=""Order"" Title=""Cliente"" Property=""@(o => o.Cliente)"" />
        <OmniDataGridColumn TItem=""Order"" Title=""Status"" Property=""@(o => o.Status)"" />
    </Columns>
</OmniDataGrid>")">
            <OmniDataGrid TItem="Order" Data="@_inMemory" AllowSearch AllowPaging PageSize="6">
                <Columns>
                    <OmniDataGridColumn TItem="Order" Title="Pedido #" PropertyName="Numero" Property="@(o => (object)o.Numero)" Width="120px">
                        <Template><span class="omni-mono">#@context.Numero</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Cliente" PropertyName="Cliente" Property="@(o => o.Cliente)" />
                    <OmniDataGridColumn TItem="Order" Title="Canal" PropertyName="Canal" Property="@(o => o.Canal)">
                        <Template><OmniBadge Text="@context.Canal" Variant="BadgeVariant.Plain" /></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Status" PropertyName="Status" Property="@(o => o.Status)">
                        <Template><OmniBadge Text="@context.Status" Variant="@StatusVariant(context.Status)" /></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Total" PropertyName="Total" Property="@(o => (object)o.Total)">
                        <Template><span class="omni-mono">@context.Total.ToString("C", _ptBr)</span></Template>
                    </OmniDataGridColumn>
                </Columns>
            </OmniDataGrid>
        </ShowcaseSection>

        <ShowcaseSection Title="Redimensionamento de colunas"
                         Description="Arraste a borda direita de qualquer header. AllowColumnResize liga as alças; ColumnResized dispara ao soltar. Como as colunas não preenchem a largura toda, uma coluna-filler invisível no fim absorve a sobra — assim cada coluna mantém o tamanho exato e o arraste acompanha o mouse com precisão (sem 'pulo'). Arraste além da largura disponível e aparece scroll horizontal. Use Resizable=false para travar uma coluna (ex.: Status)."
                         Code="@(@"<OmniDataGrid TItem=""Order"" Data=""@_inMemory"" AllowColumnResize
               ColumnResized=""@(e => _lastResize = $""{e.PropertyName} → {e.Width:F0}px"")"">
    <Columns>
        <OmniDataGridColumn TItem=""Order"" Title=""Cliente"" Property=""@(o => o.Cliente)"" Width=""200px"" />
        <OmniDataGridColumn TItem=""Order"" Title=""Status"" Property=""@(o => o.Status)"" Resizable=""false"" />
    </Columns>
</OmniDataGrid>")">
            <div class="omni-stack omni-gap-2">
                <div class="omni-text-soft omni-mono" style="font-size:12px;">
                    Último resize: <strong>@(_lastResize ?? "—")</strong>
                </div>
                <OmniDataGrid TItem="Order" Data="@_inMemory" AllowColumnResize AllowSorting AllowPaging PageSize="6"
                              ColumnResized="@(e => _lastResize = $"{e.PropertyName} → {e.Width:F0}px")">
                    <Columns>
                        <OmniDataGridColumn TItem="Order" Title="Pedido #" PropertyName="Numero" Property="@(o => (object)o.Numero)" Width="120px">
                            <Template><span class="omni-mono">#@context.Numero</span></Template>
                        </OmniDataGridColumn>
                        <OmniDataGridColumn TItem="Order" Title="Cliente" PropertyName="Cliente" Property="@(o => o.Cliente)" Width="200px" />
                        <OmniDataGridColumn TItem="Order" Title="Canal" PropertyName="Canal" Property="@(o => o.Canal)" Width="130px">
                            <Template><OmniBadge Text="@context.Canal" Variant="BadgeVariant.Plain" /></Template>
                        </OmniDataGridColumn>
                        <OmniDataGridColumn TItem="Order" Title="Itens" PropertyName="Itens" Property="@(o => (object)o.Itens)" Width="90px">
                            <Template><span class="omni-mono">@context.Itens</span></Template>
                        </OmniDataGridColumn>
                        <OmniDataGridColumn TItem="Order" Title="Status (fixa)" PropertyName="Status" Property="@(o => o.Status)" Width="150px" Resizable="false">
                            <Template><OmniBadge Text="@context.Status" Variant="@StatusVariant(context.Status)" /></Template>
                        </OmniDataGridColumn>
                        <OmniDataGridColumn TItem="Order" Title="Total" PropertyName="Total" Property="@(o => (object)o.Total)" Width="150px">
                            <Template><span class="omni-mono">@context.Total.ToString("C", _ptBr)</span></Template>
                        </OmniDataGridColumn>
                        <OmniDataGridColumn TItem="Order" Title="Data/hora" PropertyName="QuandoUtc" Property="@(o => (object)o.QuandoUtc)" Width="170px">
                            <Template><span class="omni-mono">@context.QuandoUtc.ToLocalTime().ToString("dd/MM HH:mm")</span></Template>
                        </OmniDataGridColumn>
                    </Columns>
                </OmniDataGrid>
            </div>
        </ShowcaseSection>

        <ShowcaseSection Title="Server-side simulado (10.000 pedidos)"
                         Description="LoadData callback. Latência de 220ms exibe o loading overlay. Search com debounce de 300ms. Paginação chama o servidor."
                         Code="@(@"<OmniDataGrid TItem=""Order""
               LoadData=""@(state => Orders.SearchAsync(state))""
               AllowSearch AllowPaging PageSize=""20"">
    <Columns>...</Columns>
</OmniDataGrid>")">
            <OmniDataGrid TItem="Order" LoadData="@(state => Orders.SearchAsync(state))" AllowSearch AllowPaging PageSize="20">
                <Columns>
                    <OmniDataGridColumn TItem="Order" Title="Pedido #" PropertyName="Numero" Property="@(o => (object)o.Numero)" Width="120px">
                        <Template><span class="omni-mono">#@context.Numero</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Cliente" PropertyName="Cliente" Property="@(o => o.Cliente)" />
                    <OmniDataGridColumn TItem="Order" Title="Canal" PropertyName="Canal" Property="@(o => o.Canal)" />
                    <OmniDataGridColumn TItem="Order" Title="Status" PropertyName="Status" Property="@(o => o.Status)">
                        <Template><OmniBadge Text="@context.Status" Variant="@StatusVariant(context.Status)" /></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Itens" PropertyName="Itens" Property="@(o => (object)o.Itens)" Width="80px">
                        <Template><span class="omni-mono">@context.Itens</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Total" PropertyName="Total" Property="@(o => (object)o.Total)">
                        <Template><span class="omni-mono">@context.Total.ToString("C", _ptBr)</span></Template>
                    </OmniDataGridColumn>
                </Columns>
            </OmniDataGrid>
        </ShowcaseSection>

        <ShowcaseSection Title="Multi-column sort + Aggregations"
                         Description="Shift+clique no header adiciona o critério ao sort. Footer (tfoot) mostra Σ Total, Σ Itens e contagem."
                         Code="@(@"<OmniDataGrid TItem=""Order"" LoadData=""@Load"" ShowAggregateRow>
    <Columns>
        <OmniDataGridColumn TItem=""Order"" Title=""Total"" Property=""@(o => (object)o.Total)""
                             Aggregate=""AggregateFunction.Sum"" />
    </Columns>
</OmniDataGrid>")">
            <OmniDataGrid TItem="Order" LoadData="@(state => Orders.SearchAsync(state))" AllowSearch AllowPaging PageSize="15" ShowAggregateRow>
                <Columns>
                    <OmniDataGridColumn TItem="Order" Title="Pedido #" PropertyName="Numero" Property="@(o => (object)o.Numero)"
                                         Aggregate="AggregateFunction.Count" Width="120px">
                        <Template><span class="omni-mono">#@context.Numero</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Cliente" PropertyName="Cliente" Property="@(o => o.Cliente)" />
                    <OmniDataGridColumn TItem="Order" Title="Status" PropertyName="Status" Property="@(o => o.Status)">
                        <Template><OmniBadge Text="@context.Status" Variant="@StatusVariant(context.Status)" /></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Itens" PropertyName="Itens" Property="@(o => (object)o.Itens)"
                                         Aggregate="AggregateFunction.Sum" AggregateProperty="@(o => (decimal)o.Itens)" Width="100px">
                        <Template><span class="omni-mono">@context.Itens</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Total" PropertyName="Total" Property="@(o => (object)o.Total)"
                                         Aggregate="AggregateFunction.Sum"
                                         AggregateFormat="@(v => ((decimal)v!).ToString("C", _ptBr))">
                        <Template><span class="omni-mono">@context.Total.ToString("C", _ptBr)</span></Template>
                    </OmniDataGridColumn>
                </Columns>
            </OmniDataGrid>
        </ShowcaseSection>

        <ShowcaseSection Title="Filter per-column"
                         Description="Linha de filtros abaixo do header. Cada coluna decide se é filtrável (operador Contains client-side e server-side)."
                         Code="@(@"<OmniDataGrid TItem=""Order"" LoadData=""@Load"" AllowColumnFilter>
    <Columns>
        <OmniDataGridColumn TItem=""Order"" Title=""Cliente"" Property=""@(o => o.Cliente)"" Filterable />
    </Columns>
</OmniDataGrid>")">
            <OmniDataGrid TItem="Order" LoadData="@(state => Orders.SearchAsync(state))" AllowColumnFilter AllowPaging PageSize="12">
                <Columns>
                    <OmniDataGridColumn TItem="Order" Title="Pedido #" PropertyName="Numero" Property="@(o => (object)o.Numero)"
                                         Filterable Width="120px">
                        <Template><span class="omni-mono">#@context.Numero</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Cliente" PropertyName="Cliente" Property="@(o => o.Cliente)" Filterable />
                    <OmniDataGridColumn TItem="Order" Title="Canal" PropertyName="Canal" Property="@(o => o.Canal)" Filterable />
                    <OmniDataGridColumn TItem="Order" Title="Status" PropertyName="Status" Property="@(o => o.Status)" Filterable>
                        <Template><OmniBadge Text="@context.Status" Variant="@StatusVariant(context.Status)" /></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Total" PropertyName="Total" Property="@(o => (object)o.Total)">
                        <Template><span class="omni-mono">@context.Total.ToString("C", _ptBr)</span></Template>
                    </OmniDataGridColumn>
                </Columns>
            </OmniDataGrid>
        </ShowcaseSection>

        <ShowcaseSection Title="Multi-selection + bulk actions"
                         Description="Checkbox no header seleciona a página inteira. Barra de bulk-actions reflete o total."
                         Code="@(@"<OmniDataGrid TItem=""Order"" Data=""@_inMemory""
               AllowMultiSelection @bind-SelectedItems=""_selected"">
    <Columns>...</Columns>
</OmniDataGrid>")">
            @if (_selected.Count > 0)
            {
                <OmniAlert Severity="NotificationSeverity.Info" Title="@($"{_selected.Count} pedidos selecionados")"
                            Dismissible Closed="@(() => _selected.Clear())">
                    <OmniButton Text="Cancelar selecionados" Icon="x-circle" Variant="ButtonVariant.Danger" Size="ComponentSize.Sm"
                                 OnClick="OnBulkCancel" />
                </OmniAlert>
            }
            <OmniDataGrid TItem="Order" Data="@_inMemory" AllowMultiSelection
                           @bind-SelectedItems="_selected" AllowPaging PageSize="8">
                <Columns>
                    <OmniDataGridColumn TItem="Order" Title="Pedido #" Property="@(o => (object)o.Numero)" Width="120px">
                        <Template><span class="omni-mono">#@context.Numero</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Cliente" Property="@(o => o.Cliente)" />
                    <OmniDataGridColumn TItem="Order" Title="Canal" Property="@(o => o.Canal)" />
                    <OmniDataGridColumn TItem="Order" Title="Status" Property="@(o => o.Status)">
                        <Template><OmniBadge Text="@context.Status" Variant="@StatusVariant(context.Status)" /></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Total" Property="@(o => (object)o.Total)">
                        <Template><span class="omni-mono">@context.Total.ToString("C", _ptBr)</span></Template>
                    </OmniDataGridColumn>
                </Columns>
            </OmniDataGrid>
        </ShowcaseSection>

        <ShowcaseSection Title="Master-detail (Row expand)"
                         Description="Cada linha expande mostrando os itens do pedido. ExpandMode=Single fecha o anterior."
                         Code="@(@"<OmniDataGrid TItem=""Order"" Data=""@_inMemory""
               ExpandMode=""ExpandMode.Single""
               DetailTemplate=""@RenderOrderDetail"">
    <Columns>...</Columns>
</OmniDataGrid>")">
            <OmniDataGrid TItem="Order" Data="@_inMemory" AllowPaging PageSize="6"
                           ExpandMode="ExpandMode.Single"
                           DetailTemplate="@RenderOrderDetail">
                <Columns>
                    <OmniDataGridColumn TItem="Order" Title="Pedido #" Property="@(o => (object)o.Numero)" Width="120px">
                        <Template><span class="omni-mono">#@context.Numero</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Cliente" Property="@(o => o.Cliente)" />
                    <OmniDataGridColumn TItem="Order" Title="Itens" Property="@(o => (object)o.Itens)" Width="80px">
                        <Template><span class="omni-mono">@context.Itens</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Total" Property="@(o => (object)o.Total)">
                        <Template><span class="omni-mono">@context.Total.ToString("C", _ptBr)</span></Template>
                    </OmniDataGridColumn>
                </Columns>
            </OmniDataGrid>
        </ShowcaseSection>

        <ShowcaseSection Title="Hierarquia (tree-grid auto-aninhado)"
                         Description="ChildrenSelector síncrono + InitiallyExpanded. Chevron + indentação na coluna âncora. Multi-nível recursivo. Linha destacada via RowClass."
                         Code="@(@"<OmniDataGrid TItem=""SharingNode"" Data=""@_sharingRoots""
               ChildrenSelector=""@(n => n.Children)""
               InitiallyExpanded IndentSize=""22"">
    <Columns>
        <OmniDataGridColumn TItem=""SharingNode"" Title=""Nome""
                             IsHierarchyAnchor Property=""@(n => n.Nome)"" />
    </Columns>
</OmniDataGrid>")">
            <div class="omni-stack omni-stack-12">
                <div class="omni-stack" style="flex-direction: row; gap: 8px; align-items: center;">
                    <OmniTextBox Placeholder="Buscar por nome, ID retaguarda ou proprietário..."
                                  LeadingIcon="search" Clearable="true"
                                  Value="@_treeSearch"
                                  ValueChanged="OnTreeSearchChangedAsync"
                                  Style="flex: 1; max-width: 380px;" />
                    <OmniButton Variant="ButtonVariant.Default" Size="ComponentSize.Sm"
                                 Icon="chevron-down" Text="Expandir tudo"
                                 OnClick="@(_ => _treeGridRef?.ExpandAllAsync() ?? Task.CompletedTask)" />
                    <OmniButton Variant="ButtonVariant.Default" Size="ComponentSize.Sm"
                                 Icon="chevron-right" Text="Recolher tudo"
                                 OnClick="@(_ => _treeGridRef?.CollapseAllAsync() ?? Task.CompletedTask)" />
                    <div style="flex: 1"></div>
                    <span class="omni-mono omni-muted" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;">
                        @CountAll(_sharingRoots) registros
                    </span>
                </div>

                <OmniAlert Severity="NotificationSeverity.Warning"
                            Title="Existem registros com referência de pai não encontrada. Verifique a integridade da estrutura." />

                <OmniDataGrid TItem="SharingNode" Data="@FilteredSharing"
                               @ref="_treeGridRef"
                               ChildrenSelector="@(n => n.Children)"
                               InitiallyExpanded
                               IndentSize="22"
                               AllowPaging="false"
                               RowClass="@(n => n.IsCurrent ? "omni-grid-row-highlight"
                                              : n.IsInconsistent ? "omni-grid-row-warning" : null)">
                    <Columns>
                        <OmniDataGridColumn TItem="SharingNode" Title="Nome / hierarquia" IsHierarchyAnchor
                                             Property="@(n => n.Nome)">
                            <Template>
                                <div class="omni-stack" style="flex-direction: row; align-items: center; gap: 8px; min-width: 0;">
                                    @if (context.IsInconsistent)
                                    {
                                        <OmniIcon Name="alert-triangle" Size="ComponentSize.Sm" />
                                    }
                                    else if (context.Children is { Count: > 0 })
                                    {
                                        <OmniIcon Name="folder" Size="ComponentSize.Sm" />
                                    }
                                    else
                                    {
                                        <OmniIcon Name="file" Size="ComponentSize.Sm" />
                                    }
                                    <span style="font-weight: @(context.IsCurrent ? "600" : "400");">@context.Nome</span>
                                    @if (context.IsCurrent)
                                    {
                                        <OmniBadge Text="Loja atual" Variant="BadgeVariant.Accent" />
                                    }
                                    @if (context.IsInconsistent)
                                    {
                                        <OmniBadge Text="Inconsistente" Variant="BadgeVariant.Warn" />
                                    }
                                </div>
                            </Template>
                        </OmniDataGridColumn>
                        <OmniDataGridColumn TItem="SharingNode" Title="ID proprietário" Property="@(n => n.IdProprietario)" Width="180px">
                            <Template><span class="omni-mono">@context.IdProprietario</span></Template>
                        </OmniDataGridColumn>
                        <OmniDataGridColumn TItem="SharingNode" Title="ID retaguarda loja" Property="@(n => n.IdLoja)" Width="180px">
                            <Template><span class="omni-mono">@context.IdLoja</span></Template>
                        </OmniDataGridColumn>
                        <OmniDataGridColumn TItem="SharingNode" Title="ID retaguarda pai" Property="@(n => n.IdPai ?? "")" Width="180px">
                            <Template><span class="omni-mono">@(string.IsNullOrEmpty(context.IdPai) ? "—" : context.IdPai)</span></Template>
                        </OmniDataGridColumn>
                        <OmniDataGridColumn TItem="SharingNode" Title="Nível" Width="80px" Sortable="false">
                            <Template>
                                <OmniBadge Text="@(context.Nivel?.ToString() ?? "?")"
                                            Variant="@LevelBadgeVariant(context.Nivel)" />
                            </Template>
                        </OmniDataGridColumn>
                    </Columns>
                </OmniDataGrid>
            </div>
        </ShowcaseSection>

        <ShowcaseSection Title="Virtualize 10.000 pedidos in-memory"
                         Description="Virtualize=true + SpacerElement='tr' → apenas ~20 &lt;tr&gt; reais no DOM. Scroll 60fps. Combina com sort, filter per-column, frozen, multi-select."
                         Code="@(@"<OmniDataGrid TItem=""Order"" Data=""@Orders.AllOrders""
               Virtualize RowHeight=""44"" Height=""520px""
               AllowSearch AllowColumnFilter>
    <Columns>...</Columns>
</OmniDataGrid>")">
            <OmniDataGrid TItem="Order" Data="@Orders.AllOrders"
                           Virtualize RowHeight="44" Height="520px"
                           AllowSearch AllowColumnFilter>
                <Columns>
                    <OmniDataGridColumn TItem="Order" Title="Pedido #" PropertyName="Numero" Property="@(o => (object)o.Numero)"
                                         Width="120px" Frozen="FrozenPosition.Left" Filterable>
                        <Template><span class="omni-mono">#@context.Numero</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Cliente" PropertyName="Cliente" Property="@(o => o.Cliente)"
                                         Width="220px" Filterable />
                    <OmniDataGridColumn TItem="Order" Title="Canal" PropertyName="Canal" Property="@(o => o.Canal)"
                                         Width="160px" Filterable />
                    <OmniDataGridColumn TItem="Order" Title="Status" PropertyName="Status" Property="@(o => o.Status)"
                                         Width="160px" Filterable>
                        <Template><OmniBadge Text="@context.Status" Variant="@StatusVariant(context.Status)" /></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Itens" PropertyName="Itens" Property="@(o => (object)o.Itens)" Width="100px">
                        <Template><span class="omni-mono">@context.Itens</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Quando" PropertyName="QuandoUtc" Property="@(o => (object)o.QuandoUtc)" Width="180px">
                        <Template><span class="omni-mono">@context.QuandoUtc.ToString("dd/MM HH:mm")</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Order" Title="Total" PropertyName="Total" Property="@(o => (object)o.Total)"
                                         Width="160px" Frozen="FrozenPosition.Right">
                        <Template><span class="omni-mono">@context.Total.ToString("C", _ptBr)</span></Template>
                    </OmniDataGridColumn>
                </Columns>
            </OmniDataGrid>
        </ShowcaseSection>

        <ShowcaseSection Title="Virtualize + Hierarquia (tree-grid)"
                         Description="Tree-grid com Virtualize ativo: _flatView virtualizado, chevron + indent funcionam idênticos. Ideal pra árvores grandes.">
            <OmniDataGrid TItem="SharingNode" Data="@_sharingRoots"
                           ChildrenSelector="@(n => n.Children)"
                           InitiallyExpanded
                           Virtualize RowHeight="44" Height="360px"
                           IndentSize="22"
                           RowClass="@(n => n.IsCurrent ? "omni-grid-row-highlight"
                                           : n.IsInconsistent ? "omni-grid-row-warning" : null)">
                <Columns>
                    <OmniDataGridColumn TItem="SharingNode" Title="Nome / hierarquia" IsHierarchyAnchor
                                         Property="@(n => n.Nome)">
                        <Template>
                            <div class="omni-stack" style="flex-direction: row; align-items: center; gap: 8px; min-width: 0;">
                                <OmniIcon Name="@(context.IsInconsistent ? "alert-triangle"
                                                  : context.Children is { Count: > 0 } ? "folder" : "file")"
                                           Size="ComponentSize.Sm" />
                                <span style="font-weight: @(context.IsCurrent ? "600" : "400");">@context.Nome</span>
                                @if (context.IsCurrent) { <OmniBadge Text="Loja atual" Variant="BadgeVariant.Accent" /> }
                                @if (context.IsInconsistent) { <OmniBadge Text="Inconsistente" Variant="BadgeVariant.Warn" /> }
                            </div>
                        </Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="SharingNode" Title="ID proprietário" Property="@(n => n.IdProprietario)" Width="160px">
                        <Template><span class="omni-mono">@context.IdProprietario</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="SharingNode" Title="ID retaguarda loja" Property="@(n => n.IdLoja)" Width="160px">
                        <Template><span class="omni-mono">@context.IdLoja</span></Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="SharingNode" Title="Nível" Width="80px" Sortable="false">
                        <Template>
                            <OmniBadge Text="@(context.Nivel?.ToString() ?? "?")"
                                        Variant="@LevelBadgeVariant(context.Nivel)" />
                        </Template>
                    </OmniDataGridColumn>
                </Columns>
            </OmniDataGrid>
        </ShowcaseSection>

        <ShowcaseSection Title="EmptyTemplate + LoadingTemplate"
                         Description="Slots customizáveis pro empty state (ícone + texto + CTA) e pro loading (skeleton rows em vez do spinner). Toggle pra ver cada estado."
                         Code="@(@"<OmniDataGrid TItem=""Order"" LoadData=""@Load"" LoadingSkeleton>
    <Columns>...</Columns>
    <EmptyTemplate>
