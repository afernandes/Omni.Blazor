                    <ChildContent>
                        <p class="omni-muted">Use o cupom <OmniKbd Text="TERCA10" /> no checkout.</p>
                    </ChildContent>
                    <FooterContent>
                        <OmniButton Text="Aplicar" Variant="ButtonVariant.Primary" Size="ComponentSize.Sm" />
                    </FooterContent>
                </OmniCard>
                <OmniCard Title="Plano Pro" Subtitle="R$ 89/mês">
                    <HeaderActions>
                        <OmniBadge Text="POPULAR" Variant="BadgeVariant.Accent" />
