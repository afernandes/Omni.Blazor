                    <ChildContent>
                        <ul class="omni-stack omni-stack-4 omni-muted" style="padding-left: 1.25rem; margin:0;">
                            <li>Pedidos ilimitados</li>
                            <li>Até 3 pontos de venda</li>
                            <li>Integração iFood</li>
                        </ul>
                    </ChildContent>
                    <FooterContent>
                        <OmniButton Text="Começar" Variant="ButtonVariant.Primary" Block />
                    </FooterContent>
