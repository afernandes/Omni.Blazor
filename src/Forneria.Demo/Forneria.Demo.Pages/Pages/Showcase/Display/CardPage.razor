    </HeaderActions>
    <ChildContent>…</ChildContent>
</OmniCard>")">
            <OmniCard Title="Relatório de vendas" Subtitle="últimas 24h">
                <HeaderActions>
                    <OmniButton Icon="download" Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" />
                    <OmniButton Icon="more-vertical" Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" />
                </HeaderActions>
                <ChildContent>
                    <div class="omni-row omni-row-gap-24">
                        <OmniStat Label="RECEITA" Value="R$ 12.480" />
                        <OmniStat Label="PEDIDOS" Value="142" />
                        <OmniStat Label="TICKET" Value="R$ 87,89" />
                    </div>
                </ChildContent>
            </OmniCard>
        </ShowcaseSection>

