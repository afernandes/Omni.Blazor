                         Code="@(@"<OmniChart Series=""@_donut"" Height=""300px""
            DonutCenterLabel=""TOTAL""
            DonutCenterValue=""R$ 89k"" />")">
            <OmniChart Series="@_donutSlices" Height="300px"
                        DonutCenterLabel="TOTAL"
                        DonutCenterValue="R$ 89k" />
        </ShowcaseSection>

        <ShowcaseSection Title="ESQUEMAS DE COR"
                         Description="Palette (default), Accent (monocromático), Pastel, Semantic."
                         Code="@(@"<OmniChart Series=""@series"" ColorScheme=""ChartColorScheme.Palette"" />
<OmniChart Series=""@series"" ColorScheme=""ChartColorScheme.Accent"" />
<OmniChart Series=""@series"" ColorScheme=""ChartColorScheme.Pastel"" />
<OmniChart Series=""@series"" ColorScheme=""ChartColorScheme.Semantic"" />")">
            <div class="omni-grid-2">
                <div>
                    <p class="omni-muted omni-mono" style="font-size:11px;margin:0 0 6px">PALETTE</p>
                    <OmniChart Series="@_schemeDemo" Height="180px" ColorScheme="ChartColorScheme.Palette" />
                </div>
                <div>
                    <p class="omni-muted omni-mono" style="font-size:11px;margin:0 0 6px">ACCENT</p>
                    <OmniChart Series="@_schemeDemo" Height="180px" ColorScheme="ChartColorScheme.Accent" />
                </div>
                <div>
                    <p class="omni-muted omni-mono" style="font-size:11px;margin:0 0 6px">PASTEL</p>
                    <OmniChart Series="@_schemeDemo" Height="180px" ColorScheme="ChartColorScheme.Pastel" />
                </div>
                <div>
                    <p class="omni-muted omni-mono" style="font-size:11px;margin:0 0 6px">SEMANTIC</p>
                    <OmniChart Series="@_schemeDemo" Height="180px" ColorScheme="ChartColorScheme.Semantic" />
                </div>
            </div>
        </ShowcaseSection>

        <ShowcaseSection Title="FORMATADOR DE VALORES"
                         Description="ValueFormatter customiza o eixo Y (e os tooltips)."
                         Code="@(@"<OmniChart Series=""@_revenueArea"" Height=""240px""
            ValueFormatter=""@(v => $""R$ {v:N0}"")"" />")">
            <OmniChart Series="@_revenueArea" Height="240px"
                        ValueFormatter="@(v => $"R$ {v:N0}")" />
        </ShowcaseSection>
    </ChildContent>

    <Api>
        <ShowcaseApiTable Title="OmniChart">
            <ShowcaseApiRow Name="Series" Type="IEnumerable<ChartSeries>" Default="empty"
                            Description="Coleção de séries (obrigatório)." />
            <ShowcaseApiRow Name="Height" Type="string" Default="&quot;260px&quot;"
                            Description="Altura CSS do chart." />
            <ShowcaseApiRow Name="Width" Type="string" Default="&quot;100%&quot;"
                            Description="Largura CSS." />
            <ShowcaseApiRow Name="ColorScheme" Type="ChartColorScheme" Default="Palette"
                            Description="Palette | Accent | Pastel | Semantic." />
            <ShowcaseApiRow Name="LegendPosition" Type="ChartLegendPosition" Default="Bottom"
                            Description="Top | Right | Bottom | Left | None." />
            <ShowcaseApiRow Name="ShowGrid" Type="bool" Default="true"
                            Description="Linhas de grid horizontais no plot area." />
            <ShowcaseApiRow Name="Title" Type="string?" Default="null"
                            Description="Reservado para futuro título no header." />
            <ShowcaseApiRow Name="ValueFormatter" Type="Func<double, string>?" Default="null"
                            Description="Formatador customizado do eixo de valores." />
            <ShowcaseApiRow Name="ValueTicks" Type="int" Default="5"
                            Description="Número desejado de ticks no eixo Y." />
            <ShowcaseApiRow Name="DonutCenterLabel" Type="string?" Default="null"
                            Description="Texto pequeno acima do valor central (Donut)." />
            <ShowcaseApiRow Name="DonutCenterValue" Type="string?" Default="null"
                            Description="Valor central (Donut)." />
        </ShowcaseApiTable>

        <ShowcaseApiTable Title="ChartSeries">
            <ShowcaseApiRow Name="Title" Type="string" Default="&quot;&quot;"
                            Description="Nome exibido na legenda/tooltip." />
            <ShowcaseApiRow Name="Type" Type="ChartSeriesType" Default="Line"
                            Description="Line | Area | Column | Bar | Pie | Donut | Waterfall." />
            <ShowcaseApiRow Name="Color" Type="string?" Default="null"
                            Description="Override de cor; quando nulo, puxa do ColorScheme." />
            <ShowcaseApiRow Name="Points" Type="IEnumerable<ChartDataPoint>" Default="empty"
                            Description="Pontos da série." />
            <ShowcaseApiRow Name="Interpolation" Type="ChartInterpolation" Default="Linear"
                            Description="Linear | Smooth | Step (Line/Area)." />
            <ShowcaseApiRow Name="StrokeWidth" Type="double" Default="2"
                            Description="Espessura da linha (Line/Area)." />
            <ShowcaseApiRow Name="ShowMarkers" Type="bool" Default="false"
                            Description="Mostra círculos nos pontos (Line/Area)." />
            <ShowcaseApiRow Name="AreaOpacity" Type="double" Default="0.18"
                            Description="Opacidade do preenchimento (Area)." />
        </ShowcaseApiTable>

        <ShowcaseApiTable Title="ChartDataPoint">
            <ShowcaseApiRow Name="Category" Type="string" Default="&quot;&quot;"
                            Description="Label no eixo categórico (ou fatia em Pie/Donut)." />
            <ShowcaseApiRow Name="Value" Type="double" Default="0"
                            Description="Valor numérico." />
            <ShowcaseApiRow Name="Color" Type="string?" Default="null"
                            Description="Cor opcional (Pie/Donut — override por fatia)." />
            <ShowcaseApiRow Name="IsTotal" Type="bool" Default="false"
                            Description="Waterfall: marca o ponto como total absoluto (barra a partir do zero). Quando false, é um delta que flutua a partir do acumulado." />
        </ShowcaseApiTable>
    </Api>

</ShowcasePage>

