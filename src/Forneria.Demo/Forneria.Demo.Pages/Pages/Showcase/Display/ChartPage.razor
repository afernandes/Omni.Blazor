@page "/showcase/chart"
@layout ShowcaseLayout

<PageTitle>Chart — Showcase</PageTitle>

<ShowcasePage Title="Chart"
              Subtitle="Gráficos SVG full-featured: Line, Area, Column, Bar, Pie, Donut e Waterfall. Múltiplas séries, eixos, legenda e tooltip.">

    <Overview>
        <p>
            O <code>OmniChart</code> é um componente único que aceita uma coleção de
            <code>ChartSeries</code> e renderiza tudo em SVG puro — sem D3, sem Chart.js, sem
            dependências externas. Suporta sete tipos de série (Line/Area/Column/Bar
            simultâneos no mesmo chart; Pie/Donut/Waterfall isolados, uma série cada).
        </p>
        <p>
            Cada série tem <code>Title</code>, <code>Type</code>, <code>Color</code> (opcional —
            puxa do <code>ColorScheme</code>) e uma lista de <code>ChartDataPoint</code>
            (<code>Category</code> + <code>Value</code>). O eixo de valores ganha ticks
            automáticos com escala "nice" (1/2/5 × 10ⁿ). Tooltips usam <code>title</code>
            nativo do SVG — passe o mouse sobre uma barra/ponto/fatia.
        </p>
    </Overview>

    <WhenToUse>
        <ul>
            <li>Dashboards com tendências temporais (Line/Area).</li>
            <li>Comparação entre categorias (Column/Bar).</li>
            <li>Distribuição percentual (Pie/Donut).</li>
            <li>Decomposição de um total — receita → custos → lucro, fluxo de caixa (Waterfall).</li>
            <li>KPIs visuais com múltiplas séries (Line + Column combinados).</li>
        </ul>
    </WhenToUse>

    <WhenNotToUse>
        <ul>
            <li>Mini-chart inline em célula → use <code>OmniSparkline</code>.</li>
            <li>> 10k pontos por série → considere agregar primeiro (chart é DOM-based).</li>
            <li>Mapas, treemap, sankey → não suportados (escopo é cartesiano + pie).</li>
        </ul>
    </WhenNotToUse>

    <ChildContent>
        <ShowcaseSection Title="LINE — TENDÊNCIA SIMPLES"
                         Description="Uma série temporal de receita semanal."
                         Code="@(@"<OmniChart Series=""@_revenueLine"" Height=""240px"" />

@code {
    private List<ChartSeries> _revenueLine = new() {
        new() { Title = ""Receita"", Type = ChartSeriesType.Line, ShowMarkers = true,
                Points = new[] {
                    new ChartDataPoint { Category = ""Seg"", Value = 8200 },
                    new ChartDataPoint { Category = ""Ter"", Value = 9100 },
                    // ...
                }}
    };
}")">
            <OmniChart Series="@_revenueLine" Height="240px" />
        </ShowcaseSection>

        <ShowcaseSection Title="AREA — DESTAQUE DE VOLUME"
                         Description="Adicione AreaOpacity para suavizar visualmente."
                         Code="@(@"<OmniChart Series=""@series"" Height=""240px"" />
@* Type = Area, AreaOpacity = 0.25 *@")">
            <OmniChart Series="@_revenueArea" Height="240px" />
        </ShowcaseSection>

        <ShowcaseSection Title="LINE COM INTERPOLAÇÃO"
                         Description="Linear (default), Smooth (curva Bézier) e Step (escada)."
                         Code="@(@"new() { Type = ChartSeriesType.Line, Interpolation = ChartInterpolation.Smooth }
new() { Type = ChartSeriesType.Line, Interpolation = ChartInterpolation.Step }")">
            <div class="omni-grid-3">
                <div>
                    <p class="omni-muted omni-mono" style="font-size:11px;margin:0 0 6px">LINEAR</p>
                    <OmniChart Series="@_interpolationLinear" Height="180px" LegendPosition="ChartLegendPosition.None" />
                </div>
                <div>
                    <p class="omni-muted omni-mono" style="font-size:11px;margin:0 0 6px">SMOOTH</p>
                    <OmniChart Series="@_interpolationSmooth" Height="180px" LegendPosition="ChartLegendPosition.None" />
                </div>
                <div>
                    <p class="omni-muted omni-mono" style="font-size:11px;margin:0 0 6px">STEP</p>
                    <OmniChart Series="@_interpolationStep" Height="180px" LegendPosition="ChartLegendPosition.None" />
                </div>
            </div>
        </ShowcaseSection>

        <ShowcaseSection Title="COLUMN — COMPARAÇÃO"
                         Description="Múltiplas séries de colunas ficam agrupadas lado a lado por categoria."
                         Code="@(@"<OmniChart Series=""@_columnGrouped"" Height=""280px"" />")">
            <OmniChart Series="@_columnGrouped" Height="280px" />
        </ShowcaseSection>

        <ShowcaseSection Title="BAR — HORIZONTAL"
                         Description="Use Bar quando há muitas categorias ou nomes longos no eixo."
                         Code="@(@"<OmniChart Series=""@_barCities"" Height=""280px"" />
@* Type = Bar *@")">
            <OmniChart Series="@_barCities" Height="280px" />
        </ShowcaseSection>

        <ShowcaseSection Title="LINHA + COLUNA (MIXED)"
                         Description="Combine tipos diferentes — colunas atrás, linhas na frente."
                         Code="@(@"new ChartSeries { Type = ChartSeriesType.Column, Title = ""Pedidos"", ... }
new ChartSeries { Type = ChartSeriesType.Line,   Title = ""Receita médio (R$)"", ShowMarkers = true, ... }")">
            <OmniChart Series="@_mixedTypes" Height="280px" />
        </ShowcaseSection>

        <ShowcaseSection Title="WATERFALL — PONTE (BRIDGE)"
                         Description="Decompõe um total em entradas e saídas. Marque IsTotal=true nos pontos de total (barra a partir do zero); os demais são deltas que flutuam a partir do acumulado. Verde = entradas, vermelho = saídas, cinza = totais. Passe o mouse para ver cada valor."
                         Code="@(@"<OmniChart Series=""@_waterfall"" Height=""300px""
            LegendPosition=""ChartLegendPosition.None""
            ValueFormatter=""@(v => $""R$ {v/1000:0}k"")"" />

@code {
    private List<ChartSeries> _waterfall = new() {
        new() { Title = ""Fluxo de caixa"", Type = ChartSeriesType.Waterfall,
            Points = new[] {
                new ChartDataPoint { Category = ""Saldo inicial"", Value = 12000, IsTotal = true },
                new ChartDataPoint { Category = ""Vendas"",        Value =  38200 },
                new ChartDataPoint { Category = ""Reembolsos"",    Value =  -4100 },
                new ChartDataPoint { Category = ""Insumos"",       Value = -16800 },
                new ChartDataPoint { Category = ""Impostos"",      Value =  -5200 },
                new ChartDataPoint { Category = ""Saldo final"",   Value =  24100, IsTotal = true },
            }}
    };
}")">
            <OmniChart Series="@_waterfall" Height="300px"
                        LegendPosition="ChartLegendPosition.None"
                        ValueFormatter="@(v => $"R$ {v/1000:0}k")" />
        </ShowcaseSection>

        <ShowcaseSection Title="PIE — DISTRIBUIÇÃO"
                         Description="Pie usa uma única série; cada Point vira uma fatia."
                         Code="@(@"new ChartSeries { Type = ChartSeriesType.Pie, Points = ... }")">
            <OmniChart Series="@_pieSlices" Height="280px" />
        </ShowcaseSection>

