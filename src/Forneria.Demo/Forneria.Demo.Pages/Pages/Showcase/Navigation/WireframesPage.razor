@page "/showcase/wireframes"
@layout ShowcaseLayout

<PageTitle>Wireframes — LEGO Layouts — Showcase</PageTitle>

<ShowcasePage Title="Wireframes — LEGO Layouts"
              Subtitle="10 combinações prontas das primitivas OmniLayout / OmniAppBar / OmniDrawer / OmniMain / OmniToolBar / OmniFooter / OmniContainer / OmniDrawerToggle.">

    <Overview>
        <p>
            O <code>OmniLayout</code> funciona como peças <strong>LEGO</strong>: encaixe os slots
            que você quiser (AppBar, Drawer-Left, Drawer-Right, ToolBar, Main, Footer) em qualquer
            ordem e o grid CSS auto-detecta via <code>:has()</code> quais existem, colapsando os
            ausentes. Inspirado em <strong>MudBlazor MudLayout / MudDrawer</strong>, em
            <strong>Radzen RadzenLayout</strong> (que usa <code>:has()</code> também) e em
            <strong>Bootstrap navbar-expand + offcanvas</strong>.
        </p>
        <p>
            Esta galeria mostra 10 combinações típicas. Cada uma traz um <em>wireframe SVG</em>,
            o <em>código completo</em> copiável e um <strong>botão "Ver demo ao vivo →"</strong>
            que abre uma página em tela cheia rodando aquele wireframe — com conteúdo de exemplo,
            estado funcional (hamburger, módulos contextuais, etc.) e uma pílula "Voltar à galeria"
            no canto inferior direito.
        </p>
        <div class="omni-alert omni-alert-info" style="margin-top: 12px;">
            <OmniIcon Name="info" Size="ComponentSize.Sm" />
            <div>
                Browser support: o sistema usa <code>:has()</code> (Chrome 105+, Safari 15.4+,
                Firefox 121+ — todos de 2022 ou antes).
            </div>
        </div>
    </Overview>

    <WhenToUse>
        <ul>
            <li><strong>Backoffice / admin</strong>: variante <em>AppBar + Left Drawer Responsive</em> é o padrão.</li>
            <li><strong>Marketing / landing</strong>: variante <em>AppBar + Main(Container)</em> com max-width centralizado.</li>
            <li><strong>Kiosk / KDS / TV</strong>: variante <em>Fullscreen</em> sem chrome.</li>
            <li><strong>Mobile-style</strong>: <em>AppBar Top + AppBar Bottom</em> com nav inferior.</li>
            <li><strong>Workspace</strong>: <em>Left Drawer + Right Drawer</em> com 3 colunas.</li>
        </ul>
    </WhenToUse>

    <WhenNotToUse>
        <ul>
            <li>Quando você só precisa de um <code>&lt;OmniSplitView&gt;</code> master/detail dentro de uma página existente — use o SplitView direto.</li>
            <li>Para conteúdo embarcado em terceiros (modais, drawers de produtos) — esses usam <code>OmniDialog</code> / <code>OmniPopover</code>.</li>
        </ul>
    </WhenNotToUse>

    <ChildContent>

        @* ───────── 1. APPBAR ONLY ───────── *@
        <ShowcaseSection Title="1 · APPBAR + MAIN"
                         Description="Wireframe mais simples — só barra superior e área principal. Perfeito para landing pages e telas focadas em conteúdo."
                         Code="@(@"<OmniLayout>
    <OmniAppBar>
        <OmniBrand Name=""Forneria"" />
        <div class=""omni-header-spacer""></div>
        <OmniButton Text=""Entrar"" Variant=""ButtonVariant.Primary"" />
    </OmniAppBar>
    <OmniMain>
        <h1>Bem-vindo</h1>
    </OmniMain>
</OmniLayout>")">
            <WireframeSvg DemoHref="/showcase/wireframes/appbar-only">
                <rect x="0" y="0" width="100%" height="14%" class="wf-bar" />
                <rect x="0" y="14%" width="100%" height="86%" class="wf-main" />
                <text x="50%" y="9%" text-anchor="middle" class="wf-lbl">AppBar</text>
                <text x="50%" y="58%" text-anchor="middle" class="wf-lbl">Main</text>
            </WireframeSvg>
        </ShowcaseSection>

