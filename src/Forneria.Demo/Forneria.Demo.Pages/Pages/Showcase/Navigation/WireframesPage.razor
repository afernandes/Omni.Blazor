    </OmniAppBar>
    <OmniDrawer Variant=""DrawerVariant.Responsive"" Breakpoint=""Breakpoint.Md"">
        <OmniPanelMenu>...</OmniPanelMenu>
    </OmniDrawer>
    <OmniMain>@Body</OmniMain>
</OmniLayout>")">
