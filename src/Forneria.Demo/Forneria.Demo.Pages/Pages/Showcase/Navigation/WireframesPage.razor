<!-- Mini (icon-only, hover-expand) -->
<OmniDrawer Variant=""DrawerVariant.Mini"" />

<!-- Temporary (overlay com backdrop) -->
<OmniDrawer Variant=""DrawerVariant.Temporary"" @bind-Open=""_open"" />

<!-- Responsive (Persistent acima de Breakpoint, Temporary abaixo) -->
<OmniDrawer Variant=""DrawerVariant.Responsive"" Breakpoint=""Breakpoint.Lg"" />")">
