            <OmniPanelMenuItem Text=""Pedidos""    Path=""/pedidos"" />
        </OmniPanelMenu>
    </OmniDrawer>
    <OmniMain>@Body</OmniMain>
</OmniLayout>")">
            <WireframeSvg DemoHref="/showcase/wireframes/appbar-left-drawer-persistent">
