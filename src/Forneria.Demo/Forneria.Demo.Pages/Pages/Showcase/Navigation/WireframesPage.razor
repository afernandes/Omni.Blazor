        @* ───────── CHEAT SHEET ───────── *@
        <ShowcaseSection Title="✦ CHEAT-SHEET — Cada slot é opcional"
                         Description="Como o grid auto-detecta os slots via :has(), você pluga só o que precisa. Tabela de equivalência com frameworks de referência:">
            <div class="omni-table-wrap">
                <table class="omni-table">
                    <thead>
                        <tr>
                            <th>Omni.Blazor</th>
                            <th>MudBlazor</th>
                            <th>Radzen</th>
                            <th>Bootstrap</th>
                            <th>HTML semântico</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td><code>OmniLayout</code></td><td>MudLayout</td><td>RadzenLayout</td><td>(div wrapper)</td><td>—</td></tr>
                        <tr><td><code>OmniAppBar</code></td><td>MudAppBar</td><td>RadzenHeader</td><td>.navbar</td><td>&lt;header&gt;</td></tr>
                        <tr><td><code>OmniDrawer</code></td><td>MudDrawer</td><td>RadzenSidebar</td><td>.offcanvas</td><td>&lt;aside&gt;</td></tr>
                        <tr><td><code>OmniToolBar</code></td><td>MudToolBar</td><td>—</td><td>—</td><td>&lt;div role=&quot;toolbar&quot;&gt;</td></tr>
                        <tr><td><code>OmniMain</code></td><td>MudMainContent</td><td>RadzenBody</td><td>—</td><td>&lt;main&gt;</td></tr>
                        <tr><td><code>OmniFooter</code></td><td>—</td><td>RadzenFooter</td><td>—</td><td>&lt;footer&gt;</td></tr>
                        <tr><td><code>OmniContainer</code></td><td>MudContainer</td><td>—</td><td>.container</td><td>—</td></tr>
                        <tr><td><code>OmniDrawerToggle</code></td><td>—</td><td>RadzenSidebarToggle</td><td>[data-bs-toggle=&quot;offcanvas&quot;]</td><td>&lt;button&gt;</td></tr>
                    </tbody>
                </table>
            </div>
        </ShowcaseSection>

    </ChildContent>

</ShowcasePage>

<style>
    /* Wireframe thumbnails — visual SVG ~640x140 que ilustra a estrutura */
    .wf-svg {
        display: block;
        width: 100%;
        max-width: 640px;
        height: 160px;
        border-radius: 12px;
        background: var(--omni-bg-sunken);
        border: 1px solid var(--omni-line);
        margin: 8px 0 16px;
    }
    .wf-svg .wf-bar  { fill: var(--omni-accent-soft, #fee2e2); stroke: var(--omni-line); stroke-width: 1; }
    .wf-svg .wf-tool { fill: color-mix(in srgb, var(--omni-accent-soft) 60%, var(--omni-bg-elev)); stroke: var(--omni-line); stroke-width: 1; }
    .wf-svg .wf-aside{ fill: var(--omni-bg-elev); stroke: var(--omni-line); stroke-width: 1; }
    .wf-svg .wf-main { fill: var(--omni-bg); stroke: var(--omni-line); stroke-width: 1; }
