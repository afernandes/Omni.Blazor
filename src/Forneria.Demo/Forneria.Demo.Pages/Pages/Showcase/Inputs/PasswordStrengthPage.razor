@page "/showcase/password-strength"
@attribute [ShowcaseInfo(Title = "Password Strength", Category = Cat.Inputs, Icon = "lock", Featured = true)]
@layout ShowcaseLayout

<PageTitle>Password Strength — Showcase</PageTitle>

<ShowcasePage Title="Password Strength"
              Subtitle="Medidor de força + checklist de política. Acompanha o OmniPassword; recalcula só quando a senha muda.">

    <Overview>
        <p>
            O <code>OmniPasswordStrength</code> avalia a senha recebida em <code>Password</code> e mostra
            4 segmentos (Fraca → Forte) e uma lista de requisitos (tamanho, maiúsculas/minúsculas,
            número, símbolo). É agnóstico de política — passe <code>MinLength</code> e ele cuida do resto.
        </p>
    </Overview>

    <ChildContent>
        <ShowcaseSection Title="INTERATIVO"
                         Description="Digite para ver o medidor e o checklist reagirem."
                         Code="@(@"<OmniPassword @bind-Value=""pw"" Placeholder=""Sua senha"" />
<OmniPasswordStrength Password=""@pw"" MinLength=""10"" />")">
            <div style="max-width:360px">
                <OmniPassword @bind-Value="_pw" Placeholder="Crie uma senha" />
                <OmniPasswordStrength Password="@_pw" MinLength="10" />
            </div>
        </ShowcaseSection>

        <ShowcaseSection Title="SEM CHECKLIST"
                         Description="ShowRules=false mostra só o medidor + rótulo."
                         Code="@(@"<OmniPasswordStrength Password=""@pw"" ShowRules=""false"" />")">
            <div style="max-width:360px">
                <OmniPasswordStrength Password="Abc123!xyz" ShowRules="false" />
            </div>
        </ShowcaseSection>

        <ShowcaseSection Title="POLÍTICA CONFIGURÁVEL"
                         Description="Use os toggles estilo ASP.NET Identity (MinLength, RequireUppercase/Lowercase/Digit/Symbol, RequiredUniqueChars) ou passe Rules para uma política 100% própria (rótulo + predicado)."
                         Code="@(@"@* toggles estilo Identity *@
<OmniPasswordStrength Password=""@pw"" MinLength=""12"" RequireSymbol=""false"" RequiredUniqueChars=""4"" />

@* regras 100% customizadas *@
<OmniPasswordStrength Password=""@pw"" Rules=""_rules"" />
@code {
    private readonly OmniPasswordRule[] _rules = {
        new(""Pelo menos 12 caracteres"", p => p.Length >= 12),
        new(""Não conter 'senha'"", p => !p.Contains(""senha"")),
        new(""6+ caracteres distintos"", p => p.Distinct().Count() >= 6),
    };
}")">
            <div class="omni-grid-2">
                <div>
                    <p class="omni-muted omni-mono" style="font-size:11px;margin:0 0 6px">TOGGLES (IDENTITY)</p>
                    <OmniPasswordStrength Password="Abcdef12" MinLength="12" RequireSymbol="false" RequiredUniqueChars="4" />
                </div>
                <div>
                    <p class="omni-muted omni-mono" style="font-size:11px;margin:0 0 6px">REGRAS CUSTOMIZADAS</p>
                    <OmniPasswordStrength Password="abcdefghijkl" Rules="_customRules" />
                </div>
            </div>
        </ShowcaseSection>
    </ChildContent>

    <Api>
        <ShowcaseApiTable Title="OmniPasswordStrength">
            <ShowcaseApiRow Name="Password" Type="string?" Default="null" Description="Senha a avaliar (read-only)." />
            <ShowcaseApiRow Name="MinLength" Type="int" Default="8" Description="Regra de tamanho mínimo (0 remove a regra)." />
            <ShowcaseApiRow Name="RequireUppercase" Type="bool" Default="true" Description="Regra: uma letra maiúscula." />
            <ShowcaseApiRow Name="RequireLowercase" Type="bool" Default="true" Description="Regra: uma letra minúscula." />
            <ShowcaseApiRow Name="RequireDigit" Type="bool" Default="true" Description="Regra: um número." />
            <ShowcaseApiRow Name="RequireSymbol" Type="bool" Default="true" Description="Regra: um símbolo." />
            <ShowcaseApiRow Name="RequiredUniqueChars" Type="int" Default="0" Description="Regra: N caracteres distintos (0 desliga)." />
            <ShowcaseApiRow Name="Rules" Type="IEnumerable<OmniPasswordRule>?" Default="null" Description="Política 100% custom (rótulo + predicado); ignora os toggles." />
            <ShowcaseApiRow Name="ShowLabel" Type="bool" Default="true" Description="Mostra a linha de rótulo/força." />
            <ShowcaseApiRow Name="LabelText" Type="string" Default="&quot;Força da senha&quot;" Description="Texto da legenda." />
            <ShowcaseApiRow Name="ShowRules" Type="bool" Default="true" Description="Mostra o checklist de requisitos." />
        </ShowcaseApiTable>
    </Api>

</ShowcasePage>

@code {
    private string _pw = "";

    private readonly OmniPasswordRule[] _customRules =
    {
        new("Pelo menos 12 caracteres", p => p.Length >= 12),
        new("Não conter 'senha'", p => !p.Contains("senha")),
        new("6+ caracteres distintos", p => p.Distinct().Count() >= 6),
    };
}
