@page "/showcase"
@attribute [ShowcaseInfo(Title = "Bem-vindo", Category = Cat.Overview, Icon = "grid", Order = -2)]
@layout ShowcaseLayout

<PageTitle>Componentes — Omni.Blazor</PageTitle>

<OmniPaneHeader Title="Omni.Blazor"
                 Subtitle="Biblioteca de componentes Blazor com design Forneria — Inter + JetBrains Mono, paleta cream + âmbar, tokens OKLCH." />

<div style="padding: 0 28px 28px; overflow: auto; flex: 1; min-height: 0;">
    <div class="omni-stack omni-stack-24">

        <section class="omni-stack omni-stack-12">
            <div class="omni-section-title">Layout & Navigation</div>
            <div class="omni-grid-auto-280">
                <ComponentCard Title="Layout & SplitView" Description="Estrutura básica de app (Header + Sidebar + Body + sub-painel)" Path="/showcase/layout" Icon="layout-dashboard" />
                <ComponentCard Title="Panel menu"        Description="Menu lateral hierárquico com expansão e indicador de rota ativa" Path="/showcase/panel-menu" Icon="list" />
                <ComponentCard Title="Breadcrumb"        Description="Caminho de navegação com separadores customizáveis" Path="/showcase/breadcrumb" Icon="chevron-right" />
                <ComponentCard Title="Tabs"              Description="Painéis horizontais com ícones e conteúdo dinâmico" Path="/showcase/tabs" Icon="grid" />
                <ComponentCard Title="Segmented control" Description="Toggle de múltiplas opções inspirado em iOS / macOS" Path="/showcase/segmented" Icon="grid" />
            </div>
        </section>

        <section class="omni-stack omni-stack-12">
            <div class="omni-section-title">Forms</div>
            <div class="omni-grid-auto-280">
                <ComponentCard Title="TextBox + Password + TextArea" Description="Campos de texto com leading/trailing icons, clear, contador" Path="/showcase/textbox" Icon="edit" />
                <ComponentCard Title="Numeric"                       Description="Input numérico genérico com prefix/suffix e spinner" Path="/showcase/numeric" Icon="dollar-sign" />
                <ComponentCard Title="Select & AutoComplete"         Description="Select nativo e autocomplete com filtro async" Path="/showcase/select" Icon="search" />
                <ComponentCard Title="DatePicker & Range"            Description="Calendário popover, mask de data, seleção de período" Path="/showcase/datepicker" Icon="calendar" />
                <ComponentCard Title="CheckBox / Switch / Radio"     Description="Controles boolean e grupos de opção exclusiva" Path="/showcase/checkbox-switch-radio" Icon="check" />
                <ComponentCard Title="FormField & Validation"        Description="Wrapper com label, hint, erro, character counter" Path="/showcase/formfield" Icon="help-circle" />
            </div>
        </section>

        <section class="omni-stack omni-stack-12">
            <div class="omni-section-title">Buttons & Display</div>
            <div class="omni-grid-auto-280">
                <ComponentCard Title="Button"        Description="5 variantes × 4 tamanhos × loading state × icon-only" Path="/showcase/buttons" Icon="package" />
                <ComponentCard Title="Card"          Description="Container com header / footer / actions, variantes flat/elevated/clickable" Path="/showcase/card" Icon="package" />
                <ComponentCard Title="Badge & Chip"  Description="Pills para status e filtros, 8 variantes de cor" Path="/showcase/badge-chip" Icon="tag" />
                <ComponentCard Title="Avatar"        Description="Iniciais coloridas ou imagem, 5 tamanhos" Path="/showcase/avatar" Icon="user" />
                <ComponentCard Title="Progress"      Description="Barra linear e segmentada (força de senha)" Path="/showcase/progress" Icon="bar-chart" />
                <ComponentCard Title="Skeleton"      Description="Placeholders animados (text / rect / circle)" Path="/showcase/skeleton" Icon="more-horizontal" />
                <ComponentCard Title="Stat"          Description="Métrica grande com label, delta e variantes" Path="/showcase/stat" Icon="trending-up" />
                <ComponentCard Title="Icon"          Description="Catálogo de ~50 ícones inline (Lucide-style)" Path="/showcase/icons" Icon="star" />
                <ComponentCard Title="Kbd"           Description="Tecla de atalho (mono, borda sutil)" Path="/showcase/kbd" Icon="grid" />
            </div>
        </section>

        <section class="omni-stack omni-stack-12">
            <div class="omni-section-title">Feedback & Data</div>
            <div class="omni-grid-auto-280">
                <ComponentCard Title="Dialog"        Description="Modal, Alert, Confirm e Drawer lateral via DialogService" Path="/showcase/dialog" Icon="alert-circle" />
                <ComponentCard Title="Notification"  Description="Toast em 4 severidades e 4 posições" Path="/showcase/notification" Icon="bell" />
                <ComponentCard Title="Tooltip"       Description="Hint contextual programático via TooltipService" Path="/showcase/tooltip" Icon="info" />
                <ComponentCard Title="Context menu"  Description="Menu suspenso em coordenadas via ContextMenuService" Path="/showcase/context-menu" Icon="more-vertical" />
                <ComponentCard Title="Spinner & Loading" Description="Spinner circular + Button.Loading state" Path="/showcase/loading" Icon="refresh" />
                <ComponentCard Title="DataGrid"      Description="Sort, paginação, busca, edit inline, export CSV, colunas visíveis" Path="/showcase/datagrid" Icon="list" />
            </div>
        </section>

        <section class="omni-stack omni-stack-12">
            <div class="omni-section-title">Marketing & Foundations</div>
            <div class="omni-grid-auto-280">
                <ComponentCard Title="Hero, Eyebrow & Mosaic" Description="Componentes para landing pages e seções introdutórias" Path="/showcase/marketing" Icon="star" />
                <ComponentCard Title="Typography"             Description="Inter (UI) + JetBrains Mono (numérico/labels)" Path="/showcase/typography" Icon="file-text" />
                <ComponentCard Title="Theme & tokens"         Description="Acentos (amber/emerald/blue/violet/crimson) + dark mode + tokens OKLCH" Path="/showcase/theme" Icon="zap" />
            </div>
        </section>
    </div>
</div>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;
}
