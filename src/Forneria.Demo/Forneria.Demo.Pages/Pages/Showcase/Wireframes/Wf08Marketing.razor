@page "/showcase/wireframes/marketing"
@layout WireframeLayout

<PageTitle>WF-8 · Marketing (Container + Footer não-fixo)</PageTitle>

@*  WIREFRAME 8 — Landing page: AppBar transparente sem borda, Main com
    Container Xl centralizado, Footer não-fixo que rola junto. *@
<OmniLayout>
    <OmniAppBar Elevated="false" Bordered="false" Style="background: transparent;">
        <OmniBrand Name="Forneria" />
        <div class="omni-header-spacer"></div>
        <OmniKbd Text="WF-8" />
        <OmniButton Text="Entrar" Variant="ButtonVariant.Ghost" />
        <OmniButton Text="Cadastre-se" Variant="ButtonVariant.Primary" />
    </OmniAppBar>

    <OmniMain Container="ContainerMaxWidth.Xl">
        <section style="padding: 48px 0 24px;">
            <p class="omni-muted" style="text-transform: uppercase; letter-spacing: 0.08em; font-size: 12px; font-weight: 600;">
                ✦ Delivery do bairro
            </p>
            <h1 style="font-size: 48px; line-height: 1.1; margin: 16px 0;">
                A melhor pizza da sua quadra, em <span style="color: var(--omni-accent);">28 minutos</span>.
            </h1>
            <p style="font-size: 18px; color: var(--omni-fg-muted); max-width: 640px;">
                Pedido em 3 toques, motoboy a 4 quarteirões, pizza saindo do forno enquanto
                você confirma o endereço. Sem app, sem cadastro chato — só clicar.
            </p>
            <div class="omni-stack omni-stack-row omni-stack-12" style="margin-top: 24px; flex-direction: row;">
                <OmniButton Text="Pedir agora" Variant="ButtonVariant.Primary" Icon="shopping-cart" />
                <OmniButton Text="Ver cardápio" Variant="ButtonVariant.Ghost" />
            </div>
        </section>

        <section style="padding: 48px 0;">
            <h2 style="margin-bottom: 24px;">Por que Forneria?</h2>
            <div class="omni-row-grid" style="--omni-row-gap: 16px;">
                <div class="omni-col omni-col-12 omni-col-md-4">
                    <OmniCard Title="Forno a lenha de verdade">
                        450°C, 90 segundos. A massa fica crocante por fora, macia por dentro.
                    </OmniCard>
                </div>
                <div class="omni-col omni-col-12 omni-col-md-4">
                    <OmniCard Title="Ingredientes do dia">
                        Tomate San Marzano, muçarela de búfala fresca, manjericão colhido na hora.
                    </OmniCard>
                </div>
                <div class="omni-col omni-col-12 omni-col-md-4">
                    <OmniCard Title="Bairro &amp; entorno">
                        Atendemos Pinheiros, Vila Madalena, Sumaré e Perdizes. Sem frete acima de R$ 80.
                    </OmniCard>
                </div>
            </div>
        </section>

        <section style="padding: 24px 0 64px;">
            <p class="omni-muted">
                <strong>OmniContainer MaxWidth=Xl</strong> = 1440px. Em viewports menores
                ele encolhe respeitando os gutters. Excelente para landing pages onde
                conteúdo amplo seria difícil de ler em telas largas.
            </p>
        </section>
    </OmniMain>

    <OmniFooter Fixed="false">
        <OmniBrand Name="Forneria" />
        <div class="omni-header-spacer"></div>
        <span class="omni-muted">© 2026 Forneria · Vila Madalena</span>
    </OmniFooter>
</OmniLayout>
