@page "/showcase/wireframes/appbar-only"
@layout WireframeLayout

<PageTitle>WF-1 · AppBar + Main</PageTitle>

@*  WIREFRAME 1 — Só AppBar + Main.
    Padrão landing/single-page com identidade no topo e área de conteúdo
    livre. Sem drawer, sem footer, sem toolbar. *@
<OmniLayout>
    <OmniAppBar>
        <OmniBrand Name="Forneria" Tenant="Pizzaria do Forno" />
        <div class="omni-header-spacer"></div>
        <OmniKbd Text="WF-1" />
        <OmniButton Text="Entrar" Variant="ButtonVariant.Primary" Icon="user" />
    </OmniAppBar>

    <OmniMain>
        <div class="wf-demo-content">
            <h1>AppBar + Main</h1>
            <p class="omni-muted">
                Wireframe mais simples — só uma barra superior fixa e área de conteúdo principal.
                Ideal para landing pages, telas focadas em conteúdo (post, doc, vídeo) e fluxos
                lineares sem necessidade de navegação lateral.
            </p>
            <OmniCard Title="Características">
                <ul>
                    <li><code>OmniLayout</code> detecta apenas o AppBar via <code>:has()</code> e colapsa as colunas/linhas vazias.</li>
                    <li>O conteúdo do Main ocupa <strong>100%</strong> do espaço abaixo do AppBar.</li>
                    <li>Sem hamburger — sem drawer para alternar.</li>
                </ul>
            </OmniCard>
        </div>
    </OmniMain>
</OmniLayout>
