@page "/hybrid"
@layout AppShellHybrid
@using System.Globalization

<PageTitle>Forneria — Layout híbrido</PageTitle>

@*  /hybrid — demo da composição "menu horizontal (módulos) + menu vertical
    (itens do módulo) + corpo do dashboard". Usa os primitivos compartilhados
    do design system: OmniPaneHeader (com slot Breadcrumb), OmniRow/OmniCol
    (grid 12-col), OmniCard (Title + Subtitle + HeaderActions + NoPadding). *@

<div class="omni-hd-page">

    @* ─── Page head — breadcrumb · título · ações ─── *@
    <OmniPaneHeader Title="Clientes"
                     Subtitle="Base completa de clientes · sincronizada com PDV, cardápio digital e iFood">
        <Breadcrumb>
            <OmniBreadcrumb Items="@_crumbs" />
        </Breadcrumb>
        <Actions>
            <OmniButton Text="Importar"      Icon="printer"  Variant="ButtonVariant.Ghost"   Size="ComponentSize.Sm" />
            <OmniButton Text="Exportar CSV"  Icon="download" Variant="ButtonVariant.Ghost"   Size="ComponentSize.Sm" />
            <OmniButton Text="Novo cliente"  Icon="plus"     Variant="ButtonVariant.Primary" Size="ComponentSize.Sm" />
        </Actions>
    </OmniPaneHeader>

    @* ─── Toolbar — busca + segmentos + filtro (específica desta página) ─── *@
    <div class="omni-hb-toolbar">
        <div class="omni-hb-toolbar-search">
            <OmniTextBox Placeholder="Buscar por nome, telefone, e-mail…" @bind-Value="_query" />
        </div>
        <OmniSegmentedControl TValue="string" Value="@_segment" ValueChanged="@(v => _segment = v)" Items="@_segments" />
        <div class="omni-hb-toolbar-spacer"></div>
        <OmniButton Text="Filtros" Icon="sliders" Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" />
    </div>

    @* ─── KPIs — grid 12-col responsivo (4 · 2 · 1 colunas) ─── *@
    <OmniRow Gap="14">
        <OmniCol Size="12" SizeMd="6" SizeLg="3">
            <OmniStat Card Icon="users" Label="Clientes no segmento" Value="@Filtered.Count().ToString("N0", _ptBr)"
                       Delta="▲ +12 este mês" DeltaCaption="vs mês anterior" />
        </OmniCol>
        <OmniCol Size="12" SizeMd="6" SizeLg="3">
            <OmniStat Card Icon="dollar-sign" Label="Receita acumulada" Value="@FormatBrl(TotalSpent)"
                       Delta="▲ +18,4%" DeltaCaption="vs período anterior" />
        </OmniCol>
        <OmniCol Size="12" SizeMd="6" SizeLg="3">
            <OmniStat Card Icon="credit-card" Label="Ticket médio" Value="@FormatBrl(AvgTicket)"
                       Delta="▲ +8,2%" DeltaCaption="vs período anterior" />
        </OmniCol>
        <OmniCol Size="12" SizeMd="6" SizeLg="3">
            <OmniStat Card Icon="shopping-cart" Label="Pedidos totais" Value="@TotalOrders.ToString("N0", _ptBr)"
                       Delta="▼ −4,1%" DeltaDown DeltaCaption="vs período anterior" />
        </OmniCol>
    </OmniRow>

    @* ─── Card com a tabela — OmniCard padrão (Title + Subtitle + HeaderActions),
         DataGrid pousa direto no ChildContent. NoPadding evita o double-padding
         do OmniCardBody quando o conteúdo já tem suas próprias bordas. ─── *@
    <OmniCard Title="@CurrentSegmentLabel"
               Subtitle="@($"{Filtered.Count()} clientes · ordenado por valor gasto · atualizado há 2 min")"
               NoPadding>
        <HeaderActions>
            <OmniButton Text="Colunas" Icon="sliders" Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" />
            <OmniButton Text="Ordenar"                Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" />
        </HeaderActions>
        <ChildContent>
            <OmniDataGrid TItem="Cliente" Data="@Filtered" AllowPaging="false" AllowSorting="true">
                <Columns>
                    <OmniDataGridColumn TItem="Cliente" Title="Cliente" Property="@(c => (object?)c.Nome)">
                        <Template Context="c">
                            <div class="omni-hb-cust">
                                <OmniAvatar Initials="@c.Iniciais" />
                                <div>
                                    <div class="omni-hb-cust-name">@c.Nome</div>
                                    <div class="omni-hb-cust-meta omni-mono">#@c.Id.ToString("D4")</div>
                                </div>
                            </div>
                        </Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Cliente" Title="Contato" Property="@(c => (object?)c.Telefone)">
                        <Template Context="c">
                            <div class="omni-mono" style="font-size:12.5px;">@c.Telefone</div>
                            <div class="omni-muted" style="font-size:11.5px;">@c.Email</div>
                        </Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Cliente" Title="Segmento" Property="@(c => (object?)c.Segmento)" Width="120px">
                        <Template Context="c">
                            <OmniBadge Text="@SegmentLabel(c.Segmento)" Variant="@SegmentVariant(c.Segmento)" />
                        </Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Cliente" Title="Pedidos" Property="@(c => (object?)c.Pedidos)" Width="90px">
                        <Template Context="c">
                            <div class="omni-mono" style="text-align:right;">@c.Pedidos</div>
                        </Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Cliente" Title="Ticket médio" Property="@(c => (object?)c.TicketMedio)" Width="120px">
                        <Template Context="c">
                            <div class="omni-mono" style="text-align:right;">@FormatBrl(c.TicketMedio)</div>
                        </Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Cliente" Title="Total gasto" Property="@(c => (object?)c.TotalGasto)" Width="130px">
                        <Template Context="c">
                            <div class="omni-mono" style="text-align:right; font-weight:700;">@FormatBrl(c.TotalGasto)</div>
                        </Template>
                    </OmniDataGridColumn>
                    <OmniDataGridColumn TItem="Cliente" Title="Último pedido" Property="@(c => (object?)c.UltimoPedido)" Width="150px">
                        <Template Context="c">
                            <div>@c.UltimoPedido</div>
                            <OmniBadge Text="@c.Canal" Variant="@ChannelVariant(c.Canal)" />
                        </Template>
                    </OmniDataGridColumn>
                </Columns>
            </OmniDataGrid>
        </ChildContent>
    </OmniCard>
</div>

@code {
    private static readonly CultureInfo _ptBr = new("pt-BR");

    private string _query = "";
    private string _segment = "vip";

    private string CurrentSegmentLabel => _segments.First(s => s.Value == _segment).Label;

    private readonly OmniBreadcrumb.Item[] _crumbs = new[]
    {
        new OmniBreadcrumb.Item("Forneria", "/"),
        new OmniBreadcrumb.Item("Gestão"),
        new OmniBreadcrumb.Item("Clientes"),
        new OmniBreadcrumb.Item("VIPs"),
    };

    private readonly OmniSegmentedControl<string>.Item[] _segments = new[]
    {
        new OmniSegmentedControl<string>.Item("todos",   "Todos"),
        new OmniSegmentedControl<string>.Item("vip",     "VIPs"),
        new OmniSegmentedControl<string>.Item("gold",    "Gold"),
        new OmniSegmentedControl<string>.Item("recor",   "Recorrentes"),
        new OmniSegmentedControl<string>.Item("novo",    "Novos"),
        new OmniSegmentedControl<string>.Item("inativo", "Inativos"),
        new OmniSegmentedControl<string>.Item("risco",   "Em risco"),
    };

    private IEnumerable<Cliente> Filtered =>
        _customers.Where(c =>
            (_segment == "todos" || c.Segmento == _segment) &&
            (string.IsNullOrWhiteSpace(_query) ||
             c.Nome.Contains(_query, StringComparison.OrdinalIgnoreCase) ||
             c.Email.Contains(_query, StringComparison.OrdinalIgnoreCase) ||
             c.Telefone.Contains(_query)));

    private decimal TotalSpent => Filtered.Sum(c => c.TotalGasto);
    private decimal AvgTicket  => Filtered.Any() ? Filtered.Average(c => c.TicketMedio) : 0m;
    private int     TotalOrders => Filtered.Sum(c => c.Pedidos);

    private static string FormatBrl(decimal value) => "R$ " + value.ToString("N2", _ptBr);
    private static string SegmentLabel(string seg) => seg switch
    {
        "vip" => "VIP", "gold" => "Gold", "recor" => "Recorrente",
        "novo" => "Novo", "inativo" => "Inativo", "risco" => "Em risco",
        _ => seg,
    };
    private static BadgeVariant SegmentVariant(string seg) => seg switch
    {
        "vip"     => BadgeVariant.Accent,
        "gold"    => BadgeVariant.Warn,
        "novo"    => BadgeVariant.Good,
        "risco"   => BadgeVariant.Danger,
        "inativo" => BadgeVariant.Plain,
        _ => BadgeVariant.Plain,
    };
    private static BadgeVariant ChannelVariant(string canal) => canal switch
    {
        "DIG" => BadgeVariant.Accent,
        "IFD" => BadgeVariant.Danger,
        "PDV" => BadgeVariant.Plain,
        _ => BadgeVariant.Plain,
    };

    public record Cliente(int Id, string Nome, string Telefone, string Email, string Segmento,
                          decimal TotalGasto, int Pedidos, decimal TicketMedio,
                          string UltimoPedido, string Canal)
    {
        public string Iniciais => string.Concat(Nome.Split(' ').Take(2).Select(p => p[0]));
    }

    private readonly List<Cliente> _customers = new()
