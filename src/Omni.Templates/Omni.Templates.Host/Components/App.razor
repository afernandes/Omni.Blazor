<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <base href="/" />
    <title>Omni Templates</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <OmniTheme Accent="indigo" />
    <link rel="stylesheet" href="@Assets["_content/Omni.Templates/css/templates.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>
<body>
    @* Server host: render mode fixo InteractiveServer. Router/layouts/pages
       vivem na RCL Omni.Templates. Accent indigo = identidade de plataforma. *@
    <Omni.Templates.Routes @rendermode="InteractiveServer" />

    <div id="blazor-error-ui" data-nosnippet>
        Ocorreu um erro inesperado.
        <a href="" class="reload">Recarregar</a>
        <span class="dismiss">×</span>
    </div>

    <script src="@Assets["_content/Omni.Blazor/js/omni.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>
</html>
