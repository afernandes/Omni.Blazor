@page "/templates/error/500"
@layout TemplatesLayout

<PageTitle>500 — Omni Templates</PageTitle>

<div class="tpl-page">
    <TemplateDoc Title="Erro 500 — Erro interno"
                 Description="Falha inesperada no servidor. OmniResult com Status=Error e código de incidente."
                 Code="@_code">
        <div class="tpl-preview-stretch tpl-preview-pad">
            <OmniResult Status="ResultStatus.Error"
                        Title="Algo deu errado"
                        Description="Tivemos um problema ao processar sua solicitação. A equipe já foi notificada — tente novamente em instantes.">
                <Actions>
                    <a href="/" class="omni-btn omni-btn-primary">Tentar de novo</a>
                    <a href="/" class="omni-btn">Voltar ao início</a>
                </Actions>
                <ChildContent>
                    <code class="omni-code">incidente: 7F3A-2C91</code>
                </ChildContent>
            </OmniResult>
        </div>
    </TemplateDoc>
</div>

@code {
    private const string _code = @"<OmniResult Status=""ResultStatus.Error""
            Title=""Algo deu errado""
            Description=""Tivemos um problema ao processar sua solicitação. A equipe já foi notificada."">
    <Actions>
        <button class=""omni-btn omni-btn-primary"" @onclick=""Retry"">Tentar de novo</button>
        <a href=""/"" class=""omni-btn"">Voltar ao início</a>
    </Actions>
    <ChildContent>
        <code class=""omni-code"">incidente: @IncidentId</code>
    </ChildContent>
</OmniResult>";
}
