@page "/templates/error/403"
@layout TemplatesLayout

<PageTitle>403 — Omni Templates</PageTitle>

<div class="tpl-page">
    <TemplateDoc Title="Erro 403 — Acesso negado"
                 Description="Usuário autenticado, mas sem permissão. OmniResult com Status=Forbidden."
                 Code="@_code">
        <div class="tpl-preview-stretch tpl-preview-pad">
            <OmniResult Status="ResultStatus.Forbidden"
                        Title="Acesso negado"
                        Description="Você não tem permissão para acessar esta página. Se acha que é um engano, fale com um administrador.">
                <Actions>
                    <a href="/" class="omni-btn omni-btn-primary">Voltar ao início</a>
                    <a href="/" class="omni-btn">Solicitar acesso</a>
                </Actions>
            </OmniResult>
        </div>
    </TemplateDoc>
</div>

@code {
    private const string _code = @"<OmniResult Status=""ResultStatus.Forbidden""
            Title=""Acesso negado""
            Description=""Você não tem permissão para acessar esta página."">
    <Actions>
        <a href=""/"" class=""omni-btn omni-btn-primary"">Voltar ao início</a>
        <a href=""/acesso"" class=""omni-btn"">Solicitar acesso</a>
    </Actions>
</OmniResult>";
}
