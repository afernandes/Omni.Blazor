@page "/templates/error/maintenance"
@layout TemplatesLayout

<PageTitle>Manutenção — Omni Templates</PageTitle>

<div class="tpl-page">
    <TemplateDoc Title="Manutenção"
                 Description="Sistema temporariamente indisponível. OmniResult com Status=Maintenance."
                 Code="@_code">
        <div class="tpl-preview-stretch tpl-preview-pad">
            <OmniResult Status="ResultStatus.Maintenance"
                        Title="Estamos em manutenção"
                        Description="Estamos fazendo melhorias e voltamos em breve. Obrigado pela paciência.">
                <Actions>
                    <a href="/" class="omni-btn omni-btn-primary">Atualizar página</a>
                    <a href="/" class="omni-btn">Página de status</a>
                </Actions>
            </OmniResult>
        </div>
    </TemplateDoc>
</div>

@code {
    private const string _code = @"<OmniResult Status=""ResultStatus.Maintenance""
            Title=""Estamos em manutenção""
            Description=""Estamos fazendo melhorias e voltamos em breve."">
    <Actions>
        <a href=""/"" class=""omni-btn omni-btn-primary"">Atualizar página</a>
        <a href=""/status"" class=""omni-btn"">Página de status</a>
    </Actions>
</OmniResult>";
}
