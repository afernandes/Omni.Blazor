@page "/templates/auth/forgot"
@layout TemplatesLayout

<PageTitle>Recuperar senha — Omni Templates</PageTitle>

<div class="tpl-page">
    <TemplateDoc Title="Recuperar senha"
                 Description="Solicitação por e-mail com confirmação genérica (não revela se a conta existe). Clique em Enviar para ver o estado de sucesso."
                 Code="@_code">
        <div style="min-height:460px">
            <OmniAuthLayout>
                <div class="omni-auth-card">
                    @if (!_sent)
                    {
                        <div class="omni-auth-head">Esqueceu a senha?</div>
                        <div class="omni-auth-lede">Informe seu e-mail e enviamos um link para redefinir.</div>
                        <div style="margin-top:20px">
                            <OmniFormField Label="E-mail">
                                <OmniTextBox @bind-Value="_email" Type="email" LeadingIcon="mail" Placeholder="voce@empresa.com" />
                            </OmniFormField>
                            <button class="omni-btn omni-btn-primary omni-btn-block omni-btn-lg" @onclick="() => _sent = true">
                                Enviar link de redefinição
                            </button>
                        </div>
                        <div style="margin-top:18px; text-align:center; font-size:13px">
                            <a href="/templates/auth/login" class="omni-link">Voltar ao login</a>
                        </div>
                    }
                    else
                    {
                        <OmniResult Status="ResultStatus.Success" Compact
                                    Title="Verifique sua caixa de entrada"
                                    Description="Se existir uma conta para esse e-mail, você receberá um link de redefinição em instantes.">
                            <Actions>
                                <a href="/templates/auth/login" class="omni-btn omni-btn-primary">Voltar ao login</a>
                                <button class="omni-btn" @onclick="() => _sent = false">Reenviar</button>
                            </Actions>
                        </OmniResult>
                    }
                </div>
            </OmniAuthLayout>
        </div>
    </TemplateDoc>
</div>

@code {
    private string _email = "";
    private bool _sent;

    private const string _code = @"<OmniAuthLayout>
    <div class=""omni-auth-card"">
        @if (!sent)
        {
            <div class=""omni-auth-head"">Esqueceu a senha?</div>
            <div class=""omni-auth-lede"">Informe seu e-mail e enviamos um link para redefinir.</div>
            <OmniFormField Label=""E-mail"">
                <OmniTextBox @bind-Value=""email"" Type=""email"" LeadingIcon=""mail"" Placeholder=""voce@empresa.com"" />
            </OmniFormField>
            <button class=""omni-btn omni-btn-primary omni-btn-block"" @onclick=""Send"">Enviar link de redefinição</button>
        }
        else
        {
            <OmniResult Status=""ResultStatus.Success"" Compact
                        Title=""Verifique sua caixa de entrada""
                        Description=""Se existir uma conta para esse e-mail, você receberá um link."">
                <Actions><a href=""/login"" class=""omni-btn omni-btn-primary"">Voltar ao login</a></Actions>
            </OmniResult>
        }
    </div>
</OmniAuthLayout>";
}
