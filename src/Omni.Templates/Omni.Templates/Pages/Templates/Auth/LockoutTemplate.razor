@page "/templates/auth/lockout"
@layout TemplatesLayout

<PageTitle>Conta bloqueada — Omni Templates</PageTitle>

<div class="tpl-page">
    <TemplateDoc Title="Conta bloqueada (lockout)"
                 Description="Bloqueio temporário após várias tentativas. OmniResult com contagem regressiva e ação de recuperação."
                 Code="@_code">
        <div class="tpl-preview-stretch tpl-preview-pad">
            <OmniResult Status="ResultStatus.Warning"
                        Title="Conta temporariamente bloqueada"
                        Description="Detectamos várias tentativas de login. Por segurança, aguarde o tempo abaixo ou redefina sua senha.">
                <ChildContent>
                    <div style="font-family:var(--omni-font-mono); font-size:40px; font-weight:700; letter-spacing:.02em; color:var(--omni-fg)">04:58</div>
                    <div class="omni-label" style="margin-top:2px">tempo restante</div>
                </ChildContent>
                <Actions>
                    <button class="omni-btn omni-btn-primary" disabled>Tentar novamente</button>
                    <a href="/templates/auth/forgot" class="omni-btn">Redefinir senha agora</a>
                </Actions>
            </OmniResult>
        </div>
    </TemplateDoc>
</div>

@code {
    private const string _code = @"<OmniResult Status=""ResultStatus.Warning""
            Title=""Conta temporariamente bloqueada""
            Description=""Detectamos várias tentativas de login. Aguarde ou redefina sua senha."">
    <ChildContent>
        <div class=""omni-countdown"">04:58</div>
        <div class=""omni-label"">tempo restante</div>
    </ChildContent>
    <Actions>
        <button class=""omni-btn omni-btn-primary"" disabled>Tentar novamente</button>
        <a href=""/reset"" class=""omni-btn"">Redefinir senha agora</a>
    </Actions>
</OmniResult>";
}
