@page "/templates/auth/reset"
@layout TemplatesLayout

<PageTitle>Redefinir senha — Omni Templates</PageTitle>

<div class="tpl-page">
    <TemplateDoc Title="Redefinir senha"
                 Description="Nova senha com medidor de força e confirmação. OmniAuthLayout + OmniPasswordStrength + validação de conferência."
                 Code="@_code">
        <div style="min-height:540px">
            <OmniAuthLayout>
                <div class="omni-auth-card">
                    <div class="omni-auth-head">Redefinir senha</div>
                    <div class="omni-auth-lede">Escolha uma nova senha para sua conta.</div>

                    <div style="margin-top:20px">
                        <OmniFormField Label="Nova senha">
                            <OmniPassword @bind-Value="_pw" Autocomplete="new-password" Placeholder="Nova senha" />
                        </OmniFormField>
                        <OmniPasswordStrength Password="@_pw" MinLength="10" Style="margin-bottom:14px" />
                        <OmniFormField Label="Confirmar senha" Error="@_confirmError">
                            <OmniPassword @bind-Value="_pw2" Autocomplete="new-password" Placeholder="Repita a senha" />
                        </OmniFormField>
                        <button class="omni-btn omni-btn-primary omni-btn-block omni-btn-lg">Redefinir senha</button>
                    </div>

                    <div style="margin-top:18px; text-align:center; font-size:13px">
                        <a href="/templates/auth/login" class="omni-link">Voltar ao login</a>
                    </div>
                </div>
            </OmniAuthLayout>
        </div>
    </TemplateDoc>
</div>

@code {
    private string _pw = "";
    private string _pw2 = "";
    private string? _confirmError =>
        !string.IsNullOrEmpty(_pw2) && _pw2 != _pw ? "As senhas não conferem." : null;

    private const string _code = @"<OmniAuthLayout>
    <div class=""omni-auth-card"">
        <div class=""omni-auth-head"">Redefinir senha</div>
        <OmniFormField Label=""Nova senha"">
            <OmniPassword @bind-Value=""pw"" Placeholder=""Nova senha"" />
        </OmniFormField>
        <OmniPasswordStrength Password=""@pw"" MinLength=""10"" />
        <OmniFormField Label=""Confirmar senha"" Error=""@ConfirmError"">
            <OmniPassword @bind-Value=""pw2"" Placeholder=""Repita a senha"" />
        </OmniFormField>
        <button class=""omni-btn omni-btn-primary omni-btn-block omni-btn-lg"" @onclick=""Reset"">Redefinir senha</button>
    </div>
</OmniAuthLayout>

@code {
    string ConfirmError => pw2 != """" && pw2 != pw ? ""As senhas não conferem."" : null;
}";
}
