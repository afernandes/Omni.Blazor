@page "/templates/misc/empty"
@layout TemplatesLayout

<PageTitle>Estado vazio — Omni Templates</PageTitle>

<div class="tpl-page">
    <TemplateDoc Title="Estado vazio"
                 Description="Placeholder para listas/coleções sem dados. OmniEmptyState dentro de um card."
                 Code="@_code">
        <div class="tpl-preview-stretch tpl-preview-pad">
            <div class="omni-card" style="width:100%; max-width:520px;">
                <OmniEmptyState Icon="inbox"
                                Title="Nenhum pedido ainda"
                                Description="Quando você receber pedidos, eles aparecem aqui. Que tal criar o primeiro?">
                    <Actions>
                        <a href="/" class="omni-btn omni-btn-primary">Novo pedido</a>
                        <a href="/" class="omni-btn">Importar</a>
                    </Actions>
                </OmniEmptyState>
            </div>
        </div>
    </TemplateDoc>
</div>

@code {
    private const string _code = @"<OmniEmptyState Icon=""inbox""
                Title=""Nenhum pedido ainda""
                Description=""Quando você receber pedidos, eles aparecem aqui."">
    <Actions>
        <OmniButton Variant=""ButtonVariant.Primary"">Novo pedido</OmniButton>
    </Actions>
</OmniEmptyState>";
}
