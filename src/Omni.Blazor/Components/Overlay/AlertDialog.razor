@namespace Omni.Blazor.Components
@inherits OmniComponent
@inject DialogService Dialog

<div class="omni-stack omni-stack-16">
    <div class="omni-row omni-row-gap-12">
        @if (!string.IsNullOrEmpty(Options.Icon))
        {
            <div class="omni-toast-ico omni-toast-info"><OmniIcon Name="@Options.Icon" /></div>
        }
        <div class="omni-flex-1">@Message</div>
    </div>
    <div class="omni-row omni-row-end">
        @* data-omni-default — Enter dispara este botão; ganha foco inicial *@
        <OmniButton Text="@Options.OkButtonText" Variant="ButtonVariant.Primary" OnClick="OnOk" data-omni-default="true" />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Message { get; set; } = "";
    [Parameter] public AlertOptions Options { get; set; } = new();

    private void OnOk(MouseEventArgs _) => Dialog.Close((object)true);
}
