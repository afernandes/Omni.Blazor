@namespace Omni.Blazor.Components
@inherits OmniComponent
@inject DialogService Dialog

@* Conteúdo interno do dialog de confirmação (mensagem + botões Cancelar/OK) aberto via DialogService.ConfirmAsync; retorna true/false. *@

<div class="omni-stack omni-stack-16">
    <div class="omni-row omni-row-gap-12">
        @if (!string.IsNullOrEmpty(Options.Icon))
        {
            <div class="omni-toast-ico omni-toast-warn"><OmniIcon Name="@Options.Icon" /></div>
        }
        <div class="omni-flex-1">@Message</div>
    </div>
    <div class="omni-row omni-row-end omni-row-gap-8">
        @* data-omni-cancel — Esc dispara este botão (cancel callback semântica) *@
        <OmniButton Text="@Options.CancelButtonText" OnClick="OnCancel" data-omni-cancel="true" />
        @* data-omni-default — Enter dispara este botão (confirm) e ganha foco inicial *@
        <OmniButton Text="@Options.OkButtonText" Variant="ButtonVariant.Primary" OnClick="OnOk" data-omni-default="true" />
    </div>
</div>

@code {
    /// <summary>Texto da mensagem exibida no corpo da confirmação.</summary>
    [Parameter, EditorRequired] public string Message { get; set; } = "";
    /// <summary>Opções da confirmação (textos dos botões OK/Cancelar, ícone). Default <c>new ConfirmOptions()</c>.</summary>
    [Parameter] public ConfirmOptions Options { get; set; } = new();

    private void OnOk(MouseEventArgs _)     => Dialog.Close((object)true);
    private void OnCancel(MouseEventArgs _) => Dialog.Close((object)false);
}
