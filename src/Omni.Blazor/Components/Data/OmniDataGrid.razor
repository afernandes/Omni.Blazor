    private async Task ExportCsvAsync()
    {
        var cols = VisibleColumns.ToList();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine(string.Join(",", cols.Select(c => CsvEscape(c.Title ?? ""))));
        // Server-side: pega tudo via LoadData(Top=int.MaxValue) — pode ser caro mas é o que o usuário pediu
        IReadOnlyList<TItem> rows;
        if (LoadData is not null)
        {
            var sorts = _sorts
                .Where(s => s.Dir != SortDirection.None)
                .Select(s => new SortDescriptor(s.Col.ResolvedPropertyName, s.Dir))
                .ToList();
            var state = new GridState<TItem>(
                0, int.MaxValue,
                string.IsNullOrWhiteSpace(_search) ? null : _search!.Trim(),
                sorts,
                _filters.Values.ToList(),
                Array.Empty<string>());
            var r = await LoadData(state);
            rows = r.Items;
        }
        else
        {
            rows = ApplyFilterAndSort((Data ?? Enumerable.Empty<TItem>()).ToList());
        }
        foreach (var item in rows)
        {
            sb.AppendLine(string.Join(",", cols.Select(c => CsvEscape(c.GetCellText(item) ?? ""))));
        }
        try { await JS.InvokeVoidAsync("omniBlazor.downloadFile", ExportFilename, sb.ToString(), "text/csv;charset=utf-8"); }
        catch { /* prerender */ }
    }

    private List<TItem> ApplyFilterAndSort(List<TItem> rows)
    {
        IEnumerable<TItem> src = rows;
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var q = _search.Trim();
            src = src.Where(it => _columns.Any(c =>
                c.GetCellText(it)?.Contains(q, StringComparison.OrdinalIgnoreCase) == true));
        }
        src = ApplyColumnFilters(src);
        src = ApplyMultiSort(src);
        return src.ToList();
    }

    // ——— Column filters ————————————————————————————————————————————————
    private async Task OnFilterTextChangedAsync(OmniDataGridColumn<TItem> col, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            _filters.Remove(col);
        }
        else
        {
            _filters[col] = new FilterDescriptor(col.ResolvedPropertyName, FilterOperator.Contains, value);
        }
        _page = 0;
        if (LoadData is not null && DebounceMs > 0) ScheduleDebouncedApply();
        else await ApplyAndRenderAsync();
    }

    private IEnumerable<TItem> ApplyColumnFilters(IEnumerable<TItem> src)
    {
        if (_filters.Count == 0) return src;
        foreach (var (col, filter) in _filters)
        {
            src = src.Where(it => MatchesFilter(it, col, filter));
        }
        return src;
    }

    private static bool MatchesFilter(TItem item, OmniDataGridColumn<TItem> col, FilterDescriptor f)
    {
        object? raw = col.Property is not null ? col.Property(item) : col.GetCellText(item);
        return f.Operator switch
        {
            FilterOperator.Contains       => ToText(raw).Contains(ToText(f.Value), StringComparison.OrdinalIgnoreCase),
            FilterOperator.NotContains    => !ToText(raw).Contains(ToText(f.Value), StringComparison.OrdinalIgnoreCase),
            FilterOperator.Equals         => CompareValues(raw, f.Value) == 0,
            FilterOperator.NotEquals      => CompareValues(raw, f.Value) != 0,
            FilterOperator.StartsWith     => ToText(raw).StartsWith(ToText(f.Value), StringComparison.OrdinalIgnoreCase),
            FilterOperator.EndsWith       => ToText(raw).EndsWith(ToText(f.Value), StringComparison.OrdinalIgnoreCase),
            FilterOperator.GreaterThan    => CompareValues(raw, f.Value) > 0,
            FilterOperator.GreaterOrEqual => CompareValues(raw, f.Value) >= 0,
            FilterOperator.LessThan       => CompareValues(raw, f.Value) < 0,
            FilterOperator.LessOrEqual    => CompareValues(raw, f.Value) <= 0,
            FilterOperator.Between        => CompareValues(raw, f.Value) >= 0 && CompareValues(raw, f.SecondValue) <= 0,
            FilterOperator.NotBetween     => !(CompareValues(raw, f.Value) >= 0 && CompareValues(raw, f.SecondValue) <= 0),
            FilterOperator.IsEmpty        => string.IsNullOrEmpty(ToText(raw)),
            FilterOperator.IsNotEmpty     => !string.IsNullOrEmpty(ToText(raw)),
            _ => true
        };
    }

    private static string ToText(object? v) => v?.ToString() ?? string.Empty;

    private static int CompareValues(object? a, object? b)
    {
        if (a is null && b is null) return 0;
        if (a is null) return -1;
        if (b is null) return 1;
        // Comparable same type
        if (a.GetType() == b.GetType() && a is IComparable ac)
            return ac.CompareTo(b);
        // Try numeric
        try
        {
            var da = Convert.ToDecimal(a, System.Globalization.CultureInfo.InvariantCulture);
            var db = Convert.ToDecimal(b, System.Globalization.CultureInfo.InvariantCulture);
            return da.CompareTo(db);
        }
        catch { /* fall through */ }
        // Try DateTime
        if (a is DateTime || b is DateTime)
        {
            if (DateTime.TryParse(a.ToString(), out var dta) &&
                DateTime.TryParse(b.ToString(), out var dtb))
                return dta.CompareTo(dtb);
        }
        // Fallback: string
        return string.Compare(a.ToString(), b.ToString(), StringComparison.OrdinalIgnoreCase);
    }

    // ——— Aggregations ————————————————————————————————————————————————————
    private object? GetAggregateForColumn(OmniDataGridColumn<TItem> col)
    {
        if (col.Aggregate is null) return null;

        // Server-side: usar valor pré-calculado pelo consumidor (se houver)
        if (LoadData is not null)
        {
            if (_serverAggregates is not null &&
                _serverAggregates.TryGetValue(col.ResolvedPropertyName, out var v))
                return v;
            return null;
        }

        // Client-side: calcula sobre o dataset filtrado completo (não só a página atual)
        var src = ApplyFilterAndSort((Data ?? Enumerable.Empty<TItem>()).ToList());
        var fn = col.Aggregate.Value;
        if (fn == AggregateFunction.Count) return src.Count;

        var values = src
            .Select(col.GetAggregateValue)
            .Where(v => v.HasValue)
            .Select(v => v!.Value)
            .ToList();
        if (values.Count == 0) return null;

        return fn switch
        {
            AggregateFunction.Sum => values.Sum(),
            AggregateFunction.Average => values.Average(),
            AggregateFunction.Min => values.Min(),
            AggregateFunction.Max => values.Max(),
            _ => null
        };
    }

    // Aggregate over an explicit item list (used by per-group footers).
    private static object? ComputeAggregate(OmniDataGridColumn<TItem> col, IReadOnlyList<TItem> items)
    {
        if (col.Aggregate is null) return null;
        var fn = col.Aggregate.Value;
        if (fn == AggregateFunction.Count) return items.Count;
        var values = items.Select(col.GetAggregateValue).Where(v => v.HasValue).Select(v => v!.Value).ToList();
        if (values.Count == 0) return null;
        return fn switch
        {
            AggregateFunction.Sum => values.Sum(),
            AggregateFunction.Average => values.Average(),
            AggregateFunction.Min => values.Min(),
            AggregateFunction.Max => values.Max(),
            _ => null
        };
    }

    // ─── Grouping ─────────────────────────────────────────────────────────
    private void BuildGroups() => _groups = IsGroupMode ? BuildGroupLevel(_view, 0) : new();

    private List<GroupNode> BuildGroupLevel(IReadOnlyList<TItem> items, int level)
    {
        var col = _groupCols[level];
        var isLeaf = level == _groupCols.Count - 1;
        return items
            .GroupBy(it => col.GetSortValue(it))
            .Select(g =>
            {
                var groupItems = g.ToList();
                return new GroupNode(
                    Column: col,
                    Key: g.Key,
                    Count: groupItems.Count,
                    Level: level,
                    Items: groupItems,
                    Children: isLeaf ? null : BuildGroupLevel(groupItems, level + 1));
            })
            .ToList();
    }

    // Stable identity for a group across renders = path of keys from the root.
    private static string GroupPath(string parentPath, GroupNode node)
        => $"{parentPath}/{node.Level}:{node.Key?.ToString() ?? "∅"}";

    private string GroupKeyText(GroupNode node)
    {
        var txt = node.Items.Count > 0 ? node.Column.GetCellText(node.Items[0]) : node.Key?.ToString();
        return string.IsNullOrEmpty(txt) ? "(vazio)" : txt;
    }

    private void ToggleGroup(string path)
    {
        if (!_collapsedGroups.Remove(path)) _collapsedGroups.Add(path);
    }

    private async Task AddGroupColumnAsync(OmniDataGridColumn<TItem> col)
    {
        if (col is null || !col.Groupable || _groupCols.Contains(col)) return;
        _groupCols.Add(col);
        await OnGroupsChangedAsync();
    }

    internal async Task UngroupAsync(OmniDataGridColumn<TItem> col)
    {
        if (_groupCols.Remove(col)) await OnGroupsChangedAsync();
    }

    private async Task OnGroupsChangedAsync()
    {
        _collapsedGroups.Clear();
        await ApplyAndRenderAsync();
        if (Grouped.HasDelegate)
            await Grouped.InvokeAsync(_groupCols.Select(c => c.ResolvedPropertyName).ToList());
    }

    /// <summary>Programmatically groups by the column with the given resolved property name.</summary>
    public Task GroupByAsync(string propertyName)
    {
        var col = _columns.FirstOrDefault(c => c.ResolvedPropertyName == propertyName);
        return col is null ? Task.CompletedTask : AddGroupColumnAsync(col);
    }

    /// <summary>Removes the given property from the grouping.</summary>
    public Task UngroupByAsync(string propertyName)
    {
        var col = _columns.FirstOrDefault(c => c.ResolvedPropertyName == propertyName);
        return col is null ? Task.CompletedTask : UngroupAsync(col);
    }

    /// <summary>Clears all grouping.</summary>
    public Task ClearGroupingAsync()
    {
        if (_groupCols.Count == 0) return Task.CompletedTask;
        _groupCols.Clear();
        return OnGroupsChangedAsync();
    }

    private void OnColGroupDragStart(OmniDataGridColumn<TItem> col) => _draggingGroupCol = col;

    private async Task OnGroupPanelDropAsync()
    {
        var col = _draggingGroupCol;
        _draggingGroupCol = null;
        if (col is not null) await AddGroupColumnAsync(col);
    }

    private static string AggregateLabel(AggregateFunction fn) => fn switch
    {
        AggregateFunction.Sum     => "Σ",
        AggregateFunction.Average => "x̄",
        AggregateFunction.Count   => "#",
        AggregateFunction.Min     => "min",
        AggregateFunction.Max     => "max",
        _ => "?"
    };

    private static string FormatAggregate(OmniDataGridColumn<TItem> col, object? value)
    {
        if (value is null) return "—";
        if (col.AggregateFormat is not null) return col.AggregateFormat(value);
        return value switch
        {
            decimal d => d.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR")),
            double dbl => dbl.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR")),
            float f => f.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR")),
            _ => value.ToString() ?? "—"
        };
    }

    private static string CsvEscape(string value)
    {
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
            return "\"" + value.Replace("\"", "\"\"") + "\"";
        return value;
    }

    /// <summary>
    /// Inline style aplicado no root <c>.omni-grid</c>. Quando <see cref="Virtualize"/>
    /// está ativo, aplica altura fixa no root (o flex column distribui pra toolbar/scroller
    /// naturalmente). Combina com <c>Style</c> do consumidor.
    /// </summary>
    private string? RootInlineStyle
    {
        get
        {
            string? heightPart = null;
            if (Virtualize || !string.IsNullOrEmpty(Height))
            {
                var h = string.IsNullOrEmpty(Height) ? "520px" : Height;
                heightPart = $"height: {h}; max-height: {h};";
            }
            if (string.IsNullOrEmpty(heightPart)) return Style;
            return string.IsNullOrEmpty(Style) ? heightPart : $"{Style?.TrimEnd(';')}; {heightPart}";
        }
    }

    private RenderFragment RenderTreeRowFragment(TreeRow tr) => __builder =>
    {
        var row = tr.Item;
        var level = tr.Level;
        var hasChildren = tr.HasChildren;
        var isEditing = _editingRow is not null && ReferenceEquals(_editingRow, row);
        var isSelected = AllowMultiSelection && Selection.Contains(row);
        var anchorCol = HierarchyAnchorColumn;
        <tr class="@RowCss(row, isEditing, isSelected)" @onclick="@(() => HandleRowClick(row))">
            @if (AllowMultiSelection)
            {
                <td class="omni-grid-td-select" @onclick:stopPropagation>
                    <OmniCheckBox Value="isSelected" ValueChanged="@(v => OnRowSelectChangedAsync(row, v))" />
                </td>
            }
            @foreach (var c in VisibleColumns)
            {
                var isAnchor = c == anchorCol;
                <td class="@CellCss(c)" style="@CellStyle(c)">
                    @if (isAnchor)
                    {
                        <div class="omni-grid-tree-anchor">
                            <span class="omni-grid-tree-indent" style="width: @(level * IndentSize)px;"></span>
                            @if (hasChildren)
                            {
                                <button type="button" class="omni-grid-tree-chevron"
                                        aria-label="@(_treeExpanded.Contains(row) ? "Colapsar" : "Expandir")"
                                        aria-expanded="@_treeExpanded.Contains(row)"
                                        @onclick:stopPropagation
                                        @onclick="@(_ => ToggleTreeAsync(row))">
                                    @if (_treeLoading.Contains(row))
                                    {
                                        <OmniSpinner Size="ComponentSize.Sm" />
                                    }
                                    else
                                    {
                                        <OmniIcon Name="@(_treeExpanded.Contains(row) ? "chevron-down" : "chevron-right")" Size="ComponentSize.Sm" />
                                    }
                                </button>
                            }
                            else
                            {
                                <span class="omni-grid-tree-chevron-spacer"></span>
                            }
                            <span class="omni-grid-tree-content">
                                @if (isEditing && c.EditTemplate is not null) { @c.EditTemplate(row) }
                                else if (c.Template is not null) { @c.Template(row) }
                                else { @c.GetCellText(row) }
                            </span>
                        </div>
                    }
                    else
                    {
                        @if (isEditing && c.EditTemplate is not null) { @c.EditTemplate(row) }
                        else if (c.Template is not null) { @c.Template(row) }
                        else { @c.GetCellText(row) }
                    }
                </td>
            }
            @if (EditMode != DataGridEditMode.None)
            {
                <td class="omni-grid-edit-actions" @onclick:stopPropagation>
                    @if (isEditing)
                    {
                        <OmniButton Icon="check" IconOnly Variant="ButtonVariant.Primary" Size="ComponentSize.Sm"
                                     OnClick="@(_ => SaveAsync(row))" />
                        <OmniButton Icon="x" IconOnly Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm"
                                     OnClick="@(_ => CancelEdit())" />
                    }
                    else
                    {
                        <OmniButton Icon="edit" IconOnly Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm"
                                     OnClick="@(_ => BeginEdit(row))" />
                    }
                </td>
            }
            @if (HasFillerColumn) { <td class="omni-grid-td-filler"></td> }
        </tr>
    };

    private RenderFragment RenderFlatRowFragment(TItem row) => __builder =>
    {
        var isEditing = _editingRow is not null && ReferenceEquals(_editingRow, row);
        var isSelected = AllowMultiSelection && Selection.Contains(row);
        var isExpanded = DetailTemplate is not null && _expanded.Contains(row);
        <tr class="@RowCss(row, isEditing, isSelected)" @onclick="@(() => HandleRowClick(row))">
            @if (AllowMultiSelection)
            {
                <td class="omni-grid-td-select" @onclick:stopPropagation>
                    <OmniCheckBox Value="isSelected" ValueChanged="@(v => OnRowSelectChangedAsync(row, v))" />
                </td>
            }
            @if (DetailTemplate is not null)
            {
                <td class="omni-grid-td-expand" @onclick:stopPropagation>
                    <button type="button"
                            class="@($"omni-grid-expand-btn {(isExpanded ? "omni-active" : "")}")"
                            aria-label="@(isExpanded ? "Colapsar" : "Expandir")"
                            aria-expanded="@isExpanded"
                            @onclick="@(_ => ToggleExpandAsync(row))">
                        <OmniIcon Name="@(isExpanded ? "chevron-down" : "chevron-right")" Size="ComponentSize.Sm" />
                    </button>
                </td>
            }
            @foreach (var c in VisibleColumns)
            {
                <td class="@CellCss(c)" style="@CellStyle(c)">
                    @if (isEditing && c.EditTemplate is not null) { @c.EditTemplate(row) }
                    else if (c.Template is not null) { @c.Template(row) }
                    else { @c.GetCellText(row) }
                </td>
            }
            @if (EditMode != DataGridEditMode.None)
            {
                <td class="omni-grid-edit-actions" @onclick:stopPropagation>
                    @if (isEditing)
                    {
                        <OmniButton Icon="check" IconOnly Variant="ButtonVariant.Primary" Size="ComponentSize.Sm"
                                     OnClick="@(_ => SaveAsync(row))" />
                        <OmniButton Icon="x" IconOnly Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm"
                                     OnClick="@(_ => CancelEdit())" />
                    }
                    else
                    {
                        <OmniButton Icon="edit" IconOnly Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm"
                                     OnClick="@(_ => BeginEdit(row))" />
                    }
                </td>
            }
            @if (HasFillerColumn) { <td class="omni-grid-td-filler"></td> }
        </tr>
        @if (isExpanded)
        {
            <tr class="omni-grid-detail-row">
                <td colspan="@FullColSpan">
                    @DetailTemplate!(row)
                </td>
            </tr>
        }
    };

    // Recursive group renderer: a collapsible header row, then either nested
    // group rows or leaf data rows, then (optionally) a per-group aggregate row.
    private RenderFragment RenderGroupNodeFragment(GroupNode node, string parentPath) => __builder =>
    {
        var path = GroupPath(parentPath, node);
        var collapsed = _collapsedGroups.Contains(path);
        var indent = node.Level * 18;
        <tr class="omni-grid-group-row" @key="path">
            <td colspan="@FullColSpan" class="omni-grid-group-cell">
                <div class="omni-grid-group-head" style="@($"padding-left:{indent + 8}px;")">
                    <button type="button" class="omni-grid-group-toggle"
                            aria-expanded="@((!collapsed).ToString().ToLowerInvariant())"
                            @onclick="@(() => ToggleGroup(path))">
                        <OmniIcon Name="@(collapsed ? "chevron-right" : "chevron-down")" Size="ComponentSize.Sm" />
                    </button>
                    <span class="omni-grid-group-title">@node.Column.Title</span>
                    <span class="omni-grid-group-key">@GroupKeyText(node)</span>
                    <span class="omni-grid-group-count">@node.Count</span>
                </div>
            </td>
        </tr>
        @if (!collapsed)
        {
            if (node.Children is not null)
            {
                foreach (var child in node.Children)
                {
                    @RenderGroupNodeFragment(child, path)
                }
            }
            else
            {
                foreach (var item in node.Items)
                {
                    @RenderFlatRowFragment(item)
                }
            }
            if (ShowGroupFooters && _columns.Any(c => c.Aggregate.HasValue))
            {
                @RenderGroupFooterFragment(node)
            }
        }
    };

    private RenderFragment RenderGroupFooterFragment(GroupNode node) => __builder =>
    {
        <tr class="omni-grid-group-footer">
            @if (AllowMultiSelection) { <td></td> }
            @if (DetailTemplate is not null) { <td></td> }
            @foreach (var c in VisibleColumns)
            {
                <td class="@CellCss(c)" style="@CellStyle(c)">
                    @if (c.Aggregate.HasValue)
                    {
                        var v = ComputeAggregate(c, node.Items);
                        <span class="omni-grid-aggregate-label">@AggregateLabel(c.Aggregate!.Value)</span>
                        <span class="omni-grid-aggregate-value">@FormatAggregate(c, v)</span>
                    }
                </td>
            }
            @if (EditMode != DataGridEditMode.None) { <td></td> }
            @if (HasFillerColumn) { <td class="omni-grid-td-filler"></td> }
        </tr>
    };

    private RenderFragment RenderLoadingSkeleton => __builder =>
    {
        var rows = Math.Max(4, Math.Min(10, EffectivePaging ? PageSize : 8));
        var visibleCols = VisibleColumns.ToList();
        for (int i = 0; i < rows; i++)
        {
            var rowIdx = i;
            <tr class="omni-grid-skeleton-row" style="@($"--row-i: {rowIdx};")">
                @if (AllowMultiSelection) { <td class="omni-grid-td-select"></td> }
                @if (DetailTemplate is not null) { <td class="omni-grid-td-expand"></td> }
                @for (int j = 0; j < visibleCols.Count; j++)
                {
                    var c = visibleCols[j];
                    var w = SkeletonWidth(c, rowIdx, j);
                    <td class="@CellCss(c)" style="@CellStyle(c)">
                        <span class="omni-skeleton omni-grid-skeleton-bar" style="@($"width: {w}%;")"></span>
                    </td>
                }
                @if (EditMode != DataGridEditMode.None) { <td class="omni-grid-edit-actions"></td> }
                @if (HasFillerColumn) { <td class="omni-grid-td-filler"></td> }
            </tr>
        }
    };

    /// <summary>
    /// Largura (%) da barra de skeleton para uma célula. Numéricas ficam mais
    /// estreitas; textuais mais largas. Jitter determinístico por (row, col) cria
    /// variação entre linhas sem random.
    /// </summary>
    private static int SkeletonWidth(OmniDataGridColumn<TItem> col, int rowIdx, int colIdx)
    {
        bool isNumeric = col.Aggregate is not null
            || ContainsAny(col.PropertyName, "id", "numero", "total", "price", "valor", "qtd", "count");
        var baseMin = isNumeric ? 45 : 65;
        var baseMax = isNumeric ? 65 : 90;
        var jitter = ((rowIdx * 7) + colIdx * 3) % (baseMax - baseMin);
        return baseMin + jitter;
    }

    private static bool ContainsAny(string? haystack, params string[] needles)
    {
        if (string.IsNullOrEmpty(haystack)) return false;
        foreach (var n in needles)
        {
            if (haystack.Contains(n, StringComparison.OrdinalIgnoreCase)) return true;
        }
        return false;
    }

    // ─── Column resize ────────────────────────────────────────────────────
    private DotNetObjectReference<OmniDataGrid<TItem>>? _selfRef;

    private async Task StartColumnResizeAsync(int visibleIndex, MouseEventArgs e)
    {
        _selfRef ??= DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("omniBlazor.gridStartColumnResize",
                ColUid(visibleIndex), _selfRef, visibleIndex, e.ClientX, 48);
        }
        catch { /* SSR / JS not ready */ }
    }

    /// <summary>Invoked from JS when a column resize drag finishes.</summary>
    [JSInvokable]
    public Task OnColumnResized(int visibleIndex, double width)
    {
        var cols = VisibleColumns.ToList();
        if (visibleIndex < 0 || visibleIndex >= cols.Count) return Task.CompletedTask;
        var col = cols[visibleIndex];
        col.SetWidth($"{Math.Round(width)}px");
        StateHasChanged();
        return ColumnResized.HasDelegate
            ? ColumnResized.InvokeAsync(new DataGridColumnResizedEventArgs(col.ResolvedPropertyName, width))
            : Task.CompletedTask;
    }

    public void Dispose()
    {
        _searchDebounceTimer?.Dispose();
        _searchDebounceTimer = null;
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = null;
        _selfRef?.Dispose();
        _selfRef = null;
    }
}
