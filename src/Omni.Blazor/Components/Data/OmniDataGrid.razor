    // ——— Tree-grid (hierarquia) ————————————————————————————————————————
    private OmniDataGridColumn<TItem>? HierarchyAnchorColumn =>
        IsHierarchyMode
            ? (VisibleColumns.FirstOrDefault(c => c.IsHierarchyAnchor) ?? VisibleColumns.FirstOrDefault())
            : null;

    private async Task FlattenTreeAsync()
    {
        _flatView.Clear();
        foreach (var root in _view)
        {
            await AppendTreeNodeAsync(root, level: 0);
        }
    }

    private async Task AppendTreeNodeAsync(TItem item, int level)
    {
        var children = await ResolveChildrenAsync(item, loadIfNeeded: false);
        bool hasChildren = ResolveHasChildren(item, children);
        _flatView.Add(new TreeRow(item, level, hasChildren));

        if (_treeExpanded.Contains(item) && hasChildren)
        {
            var loaded = await ResolveChildrenAsync(item, loadIfNeeded: true);
            if (loaded is not null)
            {
                foreach (var c in loaded) await AppendTreeNodeAsync(c, level + 1);
            }
        }
    }

    private async Task<List<TItem>?> ResolveChildrenAsync(TItem item, bool loadIfNeeded)
    {
        if (ChildrenSelector is not null)
        {
            var children = ChildrenSelector(item);
            return children?.ToList();
        }
        if (LoadChildren is not null)
        {
            if (_treeChildrenCache.TryGetValue(item, out var cached)) return cached;
            if (!loadIfNeeded) return null;
            _treeLoading.Add(item);
            try
            {
                var loaded = (await LoadChildren(item))?.ToList() ?? new();
                _treeChildrenCache[item] = loaded;
                return loaded;
            }
            finally
            {
                _treeLoading.Remove(item);
            }
        }
        return null;
    }

    private bool ResolveHasChildren(TItem item, IReadOnlyList<TItem>? children)
    {
        if (HasChildren is not null) return HasChildren(item);
        if (children is not null) return children.Count > 0;
        // Lazy: assume true antes do primeiro load
        return LoadChildren is not null;
    }

    /// <summary>Expande todos os nós cujos filhos sejam conhecidos.</summary>
    public async Task ExpandAllAsync()
    {
        if (!IsHierarchyMode) return;
        foreach (var root in _view) await WalkExpandAsync(root);
        await ApplyAndRenderAsync();
    }

    private async Task WalkExpandAsync(TItem item)
    {
        _treeExpanded.Add(item);
        var children = await ResolveChildrenAsync(item, loadIfNeeded: true);
        if (children is null) return;
        foreach (var c in children) await WalkExpandAsync(c);
    }

    /// <summary>Recolhe todos os nós.</summary>
    public async Task CollapseAllAsync()
    {
        _treeExpanded.Clear();
        await ApplyAndRenderAsync();
    }

    private async Task ToggleTreeAsync(TItem row)
    {
        if (_treeExpanded.Contains(row))
        {
            _treeExpanded.Remove(row);
        }
        else
        {
            _treeExpanded.Add(row);
            // Lazy: força carregamento e cacheia
            if (LoadChildren is not null && !_treeChildrenCache.ContainsKey(row))
            {
                StateHasChanged(); // mostra spinner inline
                await ResolveChildrenAsync(row, loadIfNeeded: true);
            }
        }
        await ApplyAndRenderAsync();
    }

    // ——— Frozen column offsets ————————————————————————————————————————
    private void RecomputeFrozenStyles()
    {
        _frozenStyles.Clear();
        var visibleCols = VisibleColumns.ToList();
        if (!visibleCols.Any(c => c.Frozen.HasValue)) return;

        // Prefix offset: cols especiais antes das colunas declaradas (selection + expand)
        int prefixOffset = 0;
        if (AllowMultiSelection) prefixOffset += 36;
        if (DetailTemplate is not null) prefixOffset += 36;

        // Left frozen — running offset cumulativo
        int leftOffset = prefixOffset;
        OmniDataGridColumn<TItem>? lastLeft = null;
        foreach (var c in visibleCols)
        {
            if (c.Frozen != FrozenPosition.Left) continue;
            var w = ParsePxWidth(c.Width);
            _frozenStyles[c] = (
                Css: "omni-grid-frozen omni-grid-frozen-left",
                Style: $"position: sticky; left: {leftOffset}px;"
            );
            leftOffset += w ?? 0;
            lastLeft = c;
        }
        if (lastLeft is not null)
        {
            var s = _frozenStyles[lastLeft];
            _frozenStyles[lastLeft] = (s.Css + " omni-grid-frozen-left-end", s.Style);
        }

        // Right frozen — running offset cumulativo da direita
        int rightOffset = 0;
        OmniDataGridColumn<TItem>? lastRight = null;
        for (int i = visibleCols.Count - 1; i >= 0; i--)
        {
            var c = visibleCols[i];
            if (c.Frozen != FrozenPosition.Right) continue;
            var w = ParsePxWidth(c.Width);
            _frozenStyles[c] = (
                Css: "omni-grid-frozen omni-grid-frozen-right",
                Style: $"position: sticky; right: {rightOffset}px;"
            );
            rightOffset += w ?? 0;
            lastRight = c;
        }
        if (lastRight is not null)
        {
            var s = _frozenStyles[lastRight];
            _frozenStyles[lastRight] = (s.Css + " omni-grid-frozen-right-end", s.Style);
        }
    }

    private static int? ParsePxWidth(string? w)
    {
        if (string.IsNullOrEmpty(w)) return null;
        var trimmed = w.Trim();
        if (trimmed.EndsWith("px") && int.TryParse(trimmed[..^2], out var px)) return px;
        return null;
    }

    private string CellCss(OmniDataGridColumn<TItem> c)
        => _frozenStyles.TryGetValue(c, out var s) ? s.Css : string.Empty;

    // Column widths live on the <colgroup> <col> elements (so a resize updates
    // one element, not every cell). Cells only carry frozen-column positioning.
    private string? CellStyle(OmniDataGridColumn<TItem> c)
    {
        var frozenPart = _frozenStyles.TryGetValue(c, out var s) ? s.Style : "";
        return string.IsNullOrEmpty(frozenPart) ? null : frozenPart;
    }

