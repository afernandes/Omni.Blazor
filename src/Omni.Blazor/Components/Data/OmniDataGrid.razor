@namespace Omni.Blazor.Components
@typeparam TItem
@inherits OmniComponent
@implements IDisposable
@inject IJSRuntime JS
@using Omni.Blazor.Utilities

@* Tabela de dados rica: sorting, paging, busca, filtros/agregações por coluna, agrupamento, seleção múltipla, master-detail, tree-grid, virtualização e export CSV — in-memory ou server-side via LoadData. *@

<CascadingValue Value="this" IsFixed="true">
    <div class="@RootCss" style="@RootInlineStyle" @attributes="Attributes">
        @if (!Embed && (ToolbarContent is not null || AllowSearch || AllowExport || AllowColumnVisibility))
        {
            <div class="omni-grid-toolbar">
                @if (AllowSearch)
                {
                    <OmniTextBox Class="omni-grid-search"
                                  Placeholder="@SearchPlaceholder"
                                  LeadingIcon="search"
                                  Clearable="true"
                                  Value="@_search"
                                  ValueChanged="OnSearchChangedAsync" />
                }
                @ToolbarContent
                <div style="flex:1"></div>
                @if (AllowColumnVisibility)
                {
                    <div class="omni-grid-colmenu-wrap">
                        <OmniButton Variant="ButtonVariant.Default" Size="ComponentSize.Sm" Icon="settings"
                                     OnClick="@(_ => { _colMenuOpen = !_colMenuOpen; return Task.CompletedTask; })" />
                        @if (_colMenuOpen)
                        {
                            <div class="omni-grid-colmenu" @onclick:stopPropagation>
                                <div class="omni-grid-colmenu-title">Colunas visíveis</div>
                                @foreach (var col in _columns.Where(c => c.CanHide && !string.IsNullOrEmpty(c.Title)))
                                {
                                    <label class="omni-grid-colmenu-item">
                                        <input type="checkbox"
                                               checked="@col.VisibleInternal"
                                               @onchange="@(e => ToggleColumn(col, (bool)e.Value!))" />
                                        <span>@col.Title</span>
                                    </label>
                                }
                            </div>
                        }
                    </div>
                }
                @if (AllowExport)
                {
                    <OmniButton Variant="ButtonVariant.Default" Size="ComponentSize.Sm" Icon="download"
                                 Text="Exportar" OnClick="ExportCsvAsync" />
                }
            </div>
        }

        @* Hidden column registration *@
        <div style="display:none">@Columns</div>

        @if (AllowGrouping)
        {
            <div class="omni-grid-group-panel" @ondragover:preventDefault="true" @ondrop="OnGroupPanelDropAsync">
                @if (_groupCols.Count == 0)
                {
                    <span class="omni-grid-group-panel-hint">@GroupPanelText</span>
                }
                else
                {
                    @foreach (var gc in _groupCols)
                    {
                        <span class="omni-grid-group-chip" @key="gc">
                            <span class="omni-grid-group-chip-text">@gc.Title</span>
                            <button type="button" class="omni-grid-group-chip-x" aria-label="Remover agrupamento"
                                    @onclick="@(() => UngroupAsync(gc))">
                                <OmniIcon Name="x" Size="ComponentSize.Sm" />
                            </button>
                        </span>
                    }
                }
            </div>
        }

        <div class="omni-grid-scroller">
            @if (_loading && LoadingTemplate is null && !LoadingSkeleton)
            {
                <div class="omni-grid-loading" aria-live="polite" aria-busy="true">
                    <OmniSpinner Size="ComponentSize.Md" />
                </div>
            }
            else if (_loading && LoadingTemplate is not null)
            {
                <div class="omni-grid-loading" aria-live="polite" aria-busy="true">
                    @LoadingTemplate
                </div>
            }
            <table class="@TableCss">
                <colgroup>
                    @if (AllowMultiSelection) { <col style="width:36px" /> }
                    @if (DetailTemplate is not null) { <col style="width:36px" /> }
                    @{ var _ci = 0; }
                    @foreach (var c in VisibleColumns)
                    {
                        <col id="@ColUid(_ci)" style="@ColWidthStyle(c)" />
                        _ci++;
                    }
                    @if (EditMode != DataGridEditMode.None) { <col style="width:110px" /> }
                    @if (HasFillerColumn) { <col class="omni-grid-col-filler" /> }
                </colgroup>
                <thead>
                    <tr>
                        @if (AllowMultiSelection)
                        {
                            <th class="omni-grid-th-select" style="width: 36px;" @onclick:stopPropagation>
                                <OmniCheckBox Value="@AllSelectedOnPage" ValueChanged="OnHeaderSelectChangedAsync" />
                            </th>
                        }
                        @if (DetailTemplate is not null)
                        {
                            <th class="omni-grid-th-expand" style="width: 36px;"></th>
                        }
                        @{ var _hi = 0; }
                        @foreach (var c in VisibleColumns)
                        {
                            var hi = _hi;
                            <th class="@($"{HeaderCss(c)} {CellCss(c)}")" style="@CellStyle(c)"
                                @onclick="@(e => OnHeaderClickAsync(c, e))">
                                @if (AllowGrouping && c.Groupable)
                                {
                                    <span class="omni-grid-col-drag" draggable="true" title="Arraste para agrupar"
                                          @onclick:preventDefault="true" @onclick:stopPropagation="true"
                                          @ondragstart="@(() => OnColGroupDragStart(c))"></span>
                                }
                                @c.Title
                                @if (c.Sortable && AllowSorting)
                                {
                                    <span class="omni-grid-th-sort-ico">
                                        <OmniIcon Name="@SortIcon(c)" Size="ComponentSize.Sm" />
                                    </span>
                                    var sortIdx = GetSortIndex(c);
                                    if (sortIdx is not null && _sorts.Count > 1)
                                    {
                                        <span class="omni-grid-th-sort-idx">@(sortIdx + 1)</span>
                                    }
                                }
                                @if (AllowColumnResize && c.Resizable)
                                {
                                    <span class="omni-grid-resizer" title="Redimensionar coluna"
                                          @onclick:preventDefault="true" @onclick:stopPropagation="true"
                                          @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true"
                                          @onmousedown="@(e => StartColumnResizeAsync(hi, e))"></span>
                                }
                            </th>
                            _hi++;
                        }
                        @if (EditMode != DataGridEditMode.None)
                        {
                            <th style="width: 110px;"></th>
                        }
                        @if (HasFillerColumn)
                        {
                            <th class="omni-grid-th-filler" aria-hidden="true"></th>
                        }
                    </tr>
                    @if (AllowColumnFilter && _columns.Any(c => c.Filterable))
                    {
                        <tr class="omni-grid-filter-row">
                            @if (AllowMultiSelection) { <td></td> }
                            @if (DetailTemplate is not null) { <td></td> }
                            @foreach (var c in VisibleColumns)
                            {
                                <td class="@($"omni-grid-filter-cell {CellCss(c)}")" style="@CellStyle(c)">
                                    @if (c.Filterable)
                                    {
                                        var filter = _filters.TryGetValue(c, out var f) ? f : null;
                                        <OmniTextBox Value="@(filter?.Value as string)"
                                                      ValueChanged="@(v => OnFilterTextChangedAsync(c, v))"
                                                      Placeholder="Filtrar..."
                                                      Clearable="true"
                                                      Class="omni-grid-filter-input" />
                                    }
                                </td>
                            }
                            @if (EditMode != DataGridEditMode.None)
                            {
                                <td></td>
                            }
                            @if (HasFillerColumn) { <td class="omni-grid-td-filler"></td> }
                        </tr>
                    }
                </thead>
                <tbody>
                    @{
                        var anchorCol = HierarchyAnchorColumn;
                        var totalRows = IsHierarchyMode ? _flatView.Count : _view.Count;
                    }
                    @if (_loading && LoadingSkeleton && LoadingTemplate is null)
                    {
                        @RenderLoadingSkeleton
                    }
                    else if (totalRows == 0 && !_loading)
                    {
                        <tr><td colspan="@FullColSpan" class="omni-grid-empty">
                            @if (EmptyTemplate is not null) { @EmptyTemplate }
                            else { @EmptyText }
                        </td></tr>
                    }
                    else if (IsHierarchyMode)
                    {
                        @if (Virtualize)
                        {
                            <OmniVirtualize TItem="TreeRow" Items="@_flatView" SpacerElement="tr"
                                             ItemSize="@RowHeight" OverscanCount="@OverscanCount">
                                <ItemContent Context="treeRow">
                                    @RenderTreeRowFragment(treeRow)
                                </ItemContent>
                            </OmniVirtualize>
                        }
                        else
                        {
                            foreach (var treeRow in _flatView)
                            {
                                @RenderTreeRowFragment(treeRow)
                            }
                        }
                    }
                    else if (IsGroupMode)
                    {
                        foreach (var node in _groups)
                        {
                            @RenderGroupNodeFragment(node, "")
                        }
                    }
                    else
                    {
                        @if (Virtualize)
                        {
                            <OmniVirtualize TItem="TItem" Items="@_view" SpacerElement="tr"
                                             ItemSize="@RowHeight" OverscanCount="@OverscanCount">
                                <ItemContent Context="row">
                                    @RenderFlatRowFragment(row)
                                </ItemContent>
                            </OmniVirtualize>
                        }
                        else
                        {
                            foreach (var row in _view)
                            {
                                @RenderFlatRowFragment(row)
                            }
                        }
                    }
                </tbody>
                @if (ShowAggregateRow && _columns.Any(c => c.Aggregate.HasValue))
                {
                    <tfoot>
                        <tr class="omni-grid-aggregate-row">
                            @if (AllowMultiSelection) { <td></td> }
                            @if (DetailTemplate is not null) { <td></td> }
                            @foreach (var c in VisibleColumns)
                            {
                                <td class="@CellCss(c)" style="@CellStyle(c)">
                                    @if (c.Aggregate.HasValue)
                                    {
                                        var v = GetAggregateForColumn(c);
                                        <span class="omni-grid-aggregate-label">@AggregateLabel(c.Aggregate!.Value)</span>
                                        <span class="omni-grid-aggregate-value">@FormatAggregate(c, v)</span>
                                    }
                                </td>
                            }
                            @if (EditMode != DataGridEditMode.None)
                            {
                                <td></td>
                            }
                            @if (HasFillerColumn) { <td class="omni-grid-td-filler"></td> }
                        </tr>
                    </tfoot>
                }
            </table>
        </div>

        @if (EffectivePaging && _totalCount > PageSize)
        {
            <div class="omni-grid-footer">
                <span>@_pageStart–@_pageEnd de @_totalCount</span>
                <div class="omni-grid-pager">
                    <OmniButton Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" IconOnly Icon="chevron-left"
                                 Disabled="@(_page == 0)"
                                 OnClick="OnPrevPageAsync" />
                    <span style="padding: 0 8px;">@(_page + 1) / @TotalPages</span>
                    <OmniButton Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" IconOnly Icon="chevron-right"
                                 Disabled="@(_page >= TotalPages - 1)"
                                 OnClick="OnNextPageAsync" />
                </div>
            </div>
        }
    </div>
</CascadingValue>

@code {
    // ——— Data source ————————————————————————————————————————————————————
    /// <summary>Fonte de dados in-memory. Ignorado se <see cref="LoadData"/> for setado.</summary>
    [Parameter] public IEnumerable<TItem>? Data { get; set; }

    /// <summary>
    /// Callback server-side. Quando setado, o DataGrid delega filter/sort/page
    /// ao consumidor. O retorno é a janela de items a renderizar + total count.
    /// </summary>
    [Parameter] public Func<GridState<TItem>, Task<GridLoadResult<TItem>>>? LoadData { get; set; }

    /// <summary>Override do total quando server-side (caso o consumidor não preencha <c>TotalCount</c> no resultado).</summary>
    [Parameter] public int? Count { get; set; }

    /// <summary>Debounce (ms) entre keystrokes na busca antes de chamar <c>LoadData</c>.</summary>
    [Parameter] public int DebounceMs { get; set; } = 300;

    /// <summary>Definição das colunas (<c>&lt;OmniDataGridColumn&gt;</c>). Registradas via cascading.</summary>
    [Parameter] public RenderFragment? Columns { get; set; }

    /// <summary>Conteúdo extra na toolbar (entre a busca e os botões à direita).</summary>
    [Parameter] public RenderFragment? ToolbarContent { get; set; }

    /// <summary>Mostra o campo de busca textual na toolbar. Default false.</summary>
    [Parameter] public bool AllowSearch { get; set; }

    /// <summary>Permite ordenar clicando no header das colunas <c>Sortable</c>. Default true.</summary>
    [Parameter] public bool AllowSorting { get; set; } = true;

    /// <summary>Liga a paginação no rodapé. Default true. Ignorado quando <see cref="Virtualize"/> está ativo.</summary>
    [Parameter] public bool AllowPaging { get; set; } = true;

    /// <summary>Quantidade de linhas por página. Default 10.</summary>
    [Parameter] public int PageSize { get; set; } = 10;

    /// <summary>Placeholder do campo de busca. Default <c>"Buscar..."</c>.</summary>
    [Parameter] public string SearchPlaceholder { get; set; } = "Buscar...";

    /// <summary>Texto exibido quando não há registros. Default <c>"Nenhum registro encontrado."</c>.</summary>
    [Parameter] public string EmptyText { get; set; } = "Nenhum registro encontrado.";

    /// <summary>Emitido quando uma linha é clicada (fora do modo edição).</summary>
    [Parameter] public EventCallback<TItem> OnRowClick { get; set; }

    /// <summary>
    /// When true, renders without outer border/radius and stretches to fill its
    /// parent (flex:1 + min-height:0). Internal toolbar is hidden — render your
    /// own <c>OmniPaneHeader</c>/<c>OmniPaneToolbar</c> above.
    /// </summary>
    [Parameter] public bool Embed { get; set; }

    /// <summary>Enables inline editing. Each column needs an EditTemplate to be editable.</summary>
    [Parameter] public DataGridEditMode EditMode { get; set; } = DataGridEditMode.None;

    /// <summary>Fired when the user confirms an inline edit (clicks check). Use to persist changes.</summary>
    [Parameter] public EventCallback<TItem> RowUpdated { get; set; }

    /// <summary>Shows a "Exportar" button in the toolbar that downloads visible rows as CSV.</summary>
    [Parameter] public bool AllowExport { get; set; }

    /// <summary>Nome do arquivo gerado pelo export CSV. Default <c>"export.csv"</c>.</summary>
    [Parameter] public string ExportFilename { get; set; } = "export.csv";

    /// <summary>Shows the column visibility menu in the toolbar.</summary>
    [Parameter] public bool AllowColumnVisibility { get; set; }

    /// <summary>Lets the user resize columns by dragging the right edge of a header cell.</summary>
    [Parameter] public bool AllowColumnResize { get; set; }

    /// <summary>Fired after a column is resized (drag of the header handle finished).</summary>
    [Parameter] public EventCallback<DataGridColumnResizedEventArgs> ColumnResized { get; set; }

    /// <summary>
    /// Enables row grouping. Shows a drop panel above the grid; drag a column's
    /// grip there (column must be <c>Groupable</c>) — or call <see cref="GroupByAsync"/> —
    /// to group rows by that column. Multiple columns nest.
    /// </summary>
    [Parameter] public bool AllowGrouping { get; set; }

    /// <summary>Hides a column from the table once it is used as a grouping key (its value shows in the group header instead).</summary>
    [Parameter] public bool HideGroupedColumn { get; set; }

    /// <summary>Renders a per-group aggregate footer row (reuses each column's <c>Aggregate</c>). Requires aggregated columns.</summary>
    [Parameter] public bool ShowGroupFooters { get; set; }

    /// <summary>Placeholder text shown in the (empty) group panel.</summary>
    [Parameter] public string GroupPanelText { get; set; } = "Arraste o cabeçalho de uma coluna aqui para agrupar";

    /// <summary>Fired whenever the grouping changes; carries the ordered grouped property names.</summary>
    [Parameter] public EventCallback<IReadOnlyList<string>> Grouped { get; set; }

    /// <summary>
    /// Renderiza uma linha de agregação (<c>&lt;tfoot&gt;</c>) somando/contando/etc.
    /// colunas que definam <see cref="OmniDataGridColumn{TItem}.Aggregate"/>.
    /// Em modo server-side, valores vêm de <see cref="GridLoadResult{TItem}.Aggregates"/>;
    /// client-side, calculados sobre o dataset filtrado completo (não só a página atual).
    /// </summary>
    [Parameter] public bool ShowAggregateRow { get; set; }

    /// <summary>
    /// Habilita uma linha de filtros por coluna abaixo do header. Só colunas com
    /// <see cref="OmniDataGridColumn{TItem}.Filterable"/> exibem o input.
    /// </summary>
    [Parameter] public bool AllowColumnFilter { get; set; }

    // ——— Multi-selection ———————————————————————————————————————————————
    /// <summary>Habilita uma coluna de checkbox à esquerda para seleção múltipla.</summary>
    [Parameter] public bool AllowMultiSelection { get; set; }

    /// <summary>Itens selecionados. Quando setado pelo consumidor (via <c>@bind-SelectedItems</c>), o DataGrid usa essa referência diretamente.</summary>
    [Parameter] public HashSet<TItem>? SelectedItems { get; set; }

    /// <summary>Emitido quando a seleção muda. O argumento é o set atual.</summary>
    [Parameter] public EventCallback<HashSet<TItem>> SelectedItemsChanged { get; set; }

    // ——— Row expand (master-detail) ————————————————————————————————————
    /// <summary>Template renderizado abaixo da linha quando ela está expandida.</summary>
    [Parameter] public RenderFragment<TItem>? DetailTemplate { get; set; }

    /// <summary>Single = apenas uma linha expandida por vez; Multi = quantas o usuário quiser.</summary>
    [Parameter] public ExpandMode ExpandMode { get; set; } = ExpandMode.Single;

    /// <summary>Emitido quando uma linha é expandida.</summary>
    [Parameter] public EventCallback<TItem> OnRowExpand { get; set; }

    /// <summary>Emitido quando uma linha é colapsada.</summary>
    [Parameter] public EventCallback<TItem> OnRowCollapse { get; set; }

    // ——— Hierarquia / Tree-grid ———————————————————————————————————————
    /// <summary>
    /// Função síncrona que retorna os filhos de um item. Quando setada, o grid
    /// vira tree-grid: cada linha pode expandir mostrando filhos com indentação.
    /// Multi-nível recursivo.
    /// </summary>
    [Parameter] public Func<TItem, IEnumerable<TItem>?>? ChildrenSelector { get; set; }

    /// <summary>
    /// Callback assíncrono que carrega os filhos sob demanda. Disparado na primeira
    /// expansão de cada nó. Resultado é cacheado. Mutuamente exclusivo com <see cref="ChildrenSelector"/>;
    /// se ambos estiverem setados, <c>ChildrenSelector</c> tem prioridade.
    /// </summary>
    [Parameter] public Func<TItem, Task<IEnumerable<TItem>?>>? LoadChildren { get; set; }

    /// <summary>
    /// Predicado opcional que decide se uma linha tem filhos (mostra o chevron).
    /// Útil em modo <see cref="LoadChildren"/> onde a contagem só é conhecida após o load.
    /// Default: assume <c>true</c> quando <c>LoadChildren</c> está setado.
    /// </summary>
    [Parameter] public Func<TItem, bool>? HasChildren { get; set; }

    /// <summary>Pixels de indentação por nível. Default 20.</summary>
    [Parameter] public int IndentSize { get; set; } = 20;

    /// <summary>Quando true, expande todos os nós no primeiro render. Default false.</summary>
    [Parameter] public bool InitiallyExpanded { get; set; }

    /// <summary>
    /// Função opcional que retorna classes CSS extras por linha — útil para destacar
    /// linhas específicas (ex: "linha atual", "registro com pendência"). Aplicado em
    /// conjunto com as classes internas (selecionado, edição, etc.).
    /// </summary>
    [Parameter] public Func<TItem, string?>? RowClass { get; set; }

    // ——— Empty / Loading templates ————————————————————————————————————
    /// <summary>
    /// Slot custom para o estado vazio. Substitui o <see cref="EmptyText"/> quando setado.
    /// Permite ícone + título + CTA ricos.
    /// </summary>
    [Parameter] public RenderFragment? EmptyTemplate { get; set; }

    /// <summary>
    /// Slot custom para o overlay de loading. Substitui o spinner default quando setado.
    /// </summary>
    [Parameter] public RenderFragment? LoadingTemplate { get; set; }

    /// <summary>
    /// Quando true e <see cref="LoadingTemplate"/> não está setado, renderiza linhas
    /// de <c>OmniSkeleton</c> em vez do spinner — mais elegante para listas longas.
    /// </summary>
    [Parameter] public bool LoadingSkeleton { get; set; }

    // ——— Virtualization ———————————————————————————————————————————————
    /// <summary>
    /// Liga a virtualização do <c>&lt;tbody&gt;</c>: somente as linhas visíveis
    /// (e um overscan pequeno) são montadas no DOM. **Ignora <see cref="AllowPaging"/>**
    /// — paging e virtualize são mutuamente exclusivos. Requer <see cref="Height"/>
    /// definido (default <c>520px</c>). Implementação via <c>OmniVirtualize</c>
    /// com <c>SpacerElement="tr"</c>.
    /// </summary>
    [Parameter] public bool Virtualize { get; set; }

    /// <summary>Altura fixa (px) por linha quando virtualize ativo. Default 44.</summary>
    [Parameter] public float RowHeight { get; set; } = 44;

    /// <summary>Linhas extras renderizadas fora do viewport. Default 4.</summary>
    [Parameter] public int OverscanCount { get; set; } = 4;

    /// <summary>
    /// Altura do scroller. Obrigatória quando virtualize ativo (default <c>520px</c>
    /// é aplicado automaticamente se não setado).
    /// </summary>
    [Parameter] public string? Height { get; set; }

    private readonly List<OmniDataGridColumn<TItem>> _columns = new();
    private List<TItem> _view = new();
    // Multi-column sort: ordem importa, primeiro = critério primário
    private readonly List<(OmniDataGridColumn<TItem> Col, SortDirection Dir)> _sorts = new();
    private string? _search;
    private int _page;
    private int _totalCount;
    private int _pageStart;
    private int _pageEnd;
    private TItem? _editingRow;
    private bool _colMenuOpen;
    private bool _loading;
    private System.Threading.Timer? _searchDebounceTimer;
    private CancellationTokenSource? _loadCts;
    private int _loadSeq;
    private IReadOnlyDictionary<string, object?>? _serverAggregates;
    private readonly Dictionary<OmniDataGridColumn<TItem>, FilterDescriptor> _filters = new();
    private readonly HashSet<TItem> _selectedInternal = new();
    private readonly HashSet<TItem> _expanded = new();

    private HashSet<TItem> Selection => SelectedItems ?? _selectedInternal;

    // Grouping state
    private readonly List<OmniDataGridColumn<TItem>> _groupCols = new();
    private List<GroupNode> _groups = new();
    private readonly HashSet<string> _collapsedGroups = new();
    private OmniDataGridColumn<TItem>? _draggingGroupCol;

    // A single grouped node: all items under it, plus nested subgroups (null at
    // the deepest grouping level, where the items render as data rows).
    private sealed record GroupNode(
        OmniDataGridColumn<TItem> Column,
        object? Key,
        int Count,
        int Level,
        IReadOnlyList<TItem> Items,
        IReadOnlyList<GroupNode>? Children);

    // Tree-grid state
    private readonly HashSet<TItem> _treeExpanded = new();
#pragma warning disable CS8714 // TItem may not satisfy 'notnull' — usuário garante chaves não-nulas via ChildrenSelector/LoadChildren
    private readonly Dictionary<TItem, List<TItem>> _treeChildrenCache = new();
#pragma warning restore CS8714
    private readonly HashSet<TItem> _treeLoading = new();
    private List<TreeRow> _flatView = new();
    private bool _initiallyExpandedApplied;

    private bool IsHierarchyMode => ChildrenSelector is not null || LoadChildren is not null;

    /// <summary>True when at least one column is grouped (and not in tree mode).</summary>
    private bool IsGroupMode => _groupCols.Count > 0 && !IsHierarchyMode;

    private sealed record TreeRow(TItem Item, int Level, bool HasChildren);

    // Frozen column inline styles (recomputed when visible columns / widths change)
    private readonly Dictionary<OmniDataGridColumn<TItem>, (string Css, string Style)> _frozenStyles = new();

    private IEnumerable<OmniDataGridColumn<TItem>> VisibleColumns =>
        _columns.Where(c => c.VisibleInternal && !(HideGroupedColumn && _groupCols.Contains(c)));

    private int TotalColCount =>
        VisibleColumns.Count()
        + (AllowMultiSelection ? 1 : 0)
        + (DetailTemplate is not null ? 1 : 0)
        + (EditMode != DataGridEditMode.None ? 1 : 0);

    /// <summary>
    /// When column resizing is on we append a trailing "filler" column with no
    /// width. Under <c>table-layout: fixed</c> a width-less &lt;col&gt; absorbs all
    /// leftover horizontal space, so the real columns render at their EXACT
    /// declared widths instead of being stretched to fill 100%. That removes the
    /// stretch→re-measure feedback loop that made a resize "jump" on the first
    /// pixel of drag, and keeps shrinking precise (the filler grows to take the
    /// slack instead of redistributing it across the other columns).
    /// </summary>
    private bool HasFillerColumn => AllowColumnResize;

    /// <summary>Colspan that spans every column including the resize filler.</summary>
    private int FullColSpan => TotalColCount + (HasFillerColumn ? 1 : 0);

    private bool AllSelectedOnPage => _view.Count > 0 && _view.All(it => Selection.Contains(it));

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));

    /// <summary>Paging efetivo: desligado quando virtualize está ativo (são mutuamente exclusivos).</summary>
    private bool EffectivePaging => AllowPaging && !Virtualize;

    private string RootCss => CssBuilder.Default("omni-grid")
        .AddClass("omni-grid-embed", Embed)
        .AddClass(Class)
        .Build();

    internal void Register(OmniDataGridColumn<TItem> col)
    {
        if (!_columns.Contains(col)) { _columns.Add(col); _ = ApplyAndRenderAsync(); }
    }
    internal void Unregister(OmniDataGridColumn<TItem> col) => _columns.Remove(col);

    protected override async Task OnParametersSetAsync()
    {
        await ApplyAndRenderAsync();
    }

    private async Task OnSearchChangedAsync(string? value)
    {
        _search = value;
        _page = 0;
        if (LoadData is not null && DebounceMs > 0)
        {
            ScheduleDebouncedApply();
        }
        else
        {
            await ApplyAndRenderAsync();
        }
    }

    private void ScheduleDebouncedApply()
    {
        _searchDebounceTimer?.Dispose();
        _searchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(ApplyAndRenderAsync);
        }, null, DebounceMs, System.Threading.Timeout.Infinite);
    }

    private async Task OnPrevPageAsync()
    {
        if (_page == 0) return;
        _page--;
        await ApplyAndRenderAsync();
    }

    private async Task OnNextPageAsync()
    {
        if (_page >= TotalPages - 1) return;
        _page++;
        await ApplyAndRenderAsync();
    }

    private async Task ApplyAndRenderAsync()
    {
        if (LoadData is not null)
        {
            await ApplyServerSideAsync();
        }
        else
        {
            ApplyInMemory();
        }

        if (IsHierarchyMode)
        {
            if (InitiallyExpanded && !_initiallyExpandedApplied)
            {
                _initiallyExpandedApplied = true;
                foreach (var root in _view) await WalkExpandAsync(root);
            }
            await FlattenTreeAsync();
        }

        BuildGroups();
        RecomputeFrozenStyles();
        StateHasChanged();
    }

    private void ApplyInMemory()
    {
        var src = (Data ?? Enumerable.Empty<TItem>()).AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var q = _search.Trim();
            src = src.Where(it => _columns.Any(c =>
                c.GetCellText(it)?.Contains(q, StringComparison.OrdinalIgnoreCase) == true));
        }
        src = ApplyColumnFilters(src);
        src = ApplyMultiSort(src);
        var list = src.ToList();
        _totalCount = list.Count;
        if (EffectivePaging)
        {
            _page = Math.Min(_page, Math.Max(0, TotalPages - 1));
            _view = list.Skip(_page * PageSize).Take(PageSize).ToList();
            _pageStart = _totalCount == 0 ? 0 : _page * PageSize + 1;
            _pageEnd = Math.Min(_totalCount, (_page + 1) * PageSize);
        }
        else
        {
            _view = list;
            _pageStart = list.Count == 0 ? 0 : 1;
            _pageEnd = list.Count;
        }
    }

    private async Task ApplyServerSideAsync()
    {
        // Cancel previous in-flight load — só o último request vale.
        _loadCts?.Cancel();
        _loadCts = new CancellationTokenSource();
        var token = _loadCts.Token;
        var seq = ++_loadSeq;

        var sorts = _sorts
            .Where(s => s.Dir != SortDirection.None)
            .Select(s => new SortDescriptor(s.Col.ResolvedPropertyName, s.Dir))
            .ToList();

        var skip = EffectivePaging ? _page * PageSize : 0;
        var top  = EffectivePaging ? PageSize        : int.MaxValue;

        var state = new GridState<TItem>(
            Skip: skip,
            Top: top,
            Search: string.IsNullOrWhiteSpace(_search) ? null : _search!.Trim(),
            Sort: sorts,
            Filters: _filters.Values.ToList(),
            GroupBy: Array.Empty<string>());

        _loading = true;
        StateHasChanged();
        GridLoadResult<TItem>? result = null;
        try
        {
            result = await LoadData!(state);
            if (token.IsCancellationRequested || seq != _loadSeq) return;
        }
        catch (OperationCanceledException) { return; }
        finally
        {
            if (seq == _loadSeq) _loading = false;
        }

        if (result is null) { _view = new(); _totalCount = 0; _serverAggregates = null; return; }
        _view = result.Items.ToList();
        _totalCount = Count ?? result.TotalCount;
        _serverAggregates = result.Aggregates;
        if (EffectivePaging)
        {
            // Don't reset _page here — server controls pagination.
            _page = Math.Min(_page, Math.Max(0, TotalPages - 1));
            _pageStart = _totalCount == 0 ? 0 : _page * PageSize + 1;
            _pageEnd = Math.Min(_totalCount, _page * PageSize + _view.Count);
        }
        else
        {
            _pageStart = _view.Count == 0 ? 0 : 1;
            _pageEnd = _view.Count;
        }
    }

    private async Task OnHeaderClickAsync(OmniDataGridColumn<TItem> c, MouseEventArgs e)
    {
        if (!AllowSorting || !c.Sortable) return;
        var existing = _sorts.FindIndex(s => s.Col == c);
        var shift = e.ShiftKey;

        if (existing >= 0)
        {
            var current = _sorts[existing].Dir;
            var next = current switch
            {
                SortDirection.Ascending => SortDirection.Descending,
                SortDirection.Descending => SortDirection.None,
                _ => SortDirection.Ascending
            };
            if (next == SortDirection.None)
            {
                _sorts.RemoveAt(existing);
            }
            else
            {
                _sorts[existing] = (c, next);
            }
            if (!shift)
            {
                // Sem Shift: mantém só esta coluna como critério único (a menos que tenha removido)
                var keep = _sorts.FirstOrDefault(s => s.Col == c);
                _sorts.Clear();
                if (keep.Col is not null) _sorts.Add(keep);
            }
        }
        else
        {
            if (!shift) _sorts.Clear();
            _sorts.Add((c, SortDirection.Ascending));
        }

        _page = 0;
        await ApplyAndRenderAsync();
    }

    private SortDirection? GetSortDir(OmniDataGridColumn<TItem> c)
    {
        var idx = _sorts.FindIndex(s => s.Col == c);
        return idx >= 0 ? _sorts[idx].Dir : null;
    }

    private int? GetSortIndex(OmniDataGridColumn<TItem> c)
    {
        var idx = _sorts.FindIndex(s => s.Col == c);
        return idx >= 0 ? idx : null;
    }

    private string HeaderCss(OmniDataGridColumn<TItem> c)
    {
        if (!AllowSorting || !c.Sortable) return "";
        var dir = GetSortDir(c);
        return dir is null ? "omni-grid-th-sort" : "omni-grid-th-sort omni-active";
    }

    private string SortIcon(OmniDataGridColumn<TItem> c)
    {
        var dir = GetSortDir(c);
        if (dir is null) return "chevron-down";
        return dir == SortDirection.Ascending ? "chevron-up" : "chevron-down";
    }

    private IEnumerable<TItem> ApplyMultiSort(IEnumerable<TItem> src)
    {
        if (!AllowSorting || _sorts.Count == 0) return src;
        IOrderedEnumerable<TItem>? ordered = null;
        for (int i = 0; i < _sorts.Count; i++)
        {
            var (col, dir) = _sorts[i];
            Func<TItem, object?> key = col.GetSortValue;
            if (i == 0)
            {
                ordered = dir == SortDirection.Ascending
                    ? src.OrderBy(key)
                    : src.OrderByDescending(key);
            }
            else
            {
                ordered = dir == SortDirection.Ascending
                    ? ordered!.ThenBy(key)
                    : ordered!.ThenByDescending(key);
            }
        }
        return ordered ?? src;
    }

    private string RowCss(TItem row, bool isEditing, bool isSelected)
    {
        var cls = "";
        if (OnRowClick.HasDelegate) cls += "omni-grid-row-clickable ";
        if (isEditing)              cls += "omni-grid-row-editing ";
        if (isSelected)             cls += "omni-grid-row-selected ";
        if (RowClass is not null)
        {
            var extra = RowClass(row);
            if (!string.IsNullOrWhiteSpace(extra)) cls += extra + " ";
        }
        return cls.Trim();
    }

    // ——— Selection ————————————————————————————————————————————————————
    private async Task OnHeaderSelectChangedAsync(bool value)
    {
        var sel = Selection;
        if (value)
        {
            foreach (var it in _view) sel.Add(it);
        }
        else
        {
            foreach (var it in _view) sel.Remove(it);
        }
        await NotifySelectionChangedAsync();
    }

    private async Task OnRowSelectChangedAsync(TItem row, bool value)
    {
        var sel = Selection;
        if (value) sel.Add(row); else sel.Remove(row);
        await NotifySelectionChangedAsync();
