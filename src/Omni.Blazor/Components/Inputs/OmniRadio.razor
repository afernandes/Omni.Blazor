@namespace Omni.Blazor.Components
@typeparam TValue
@inherits OmniComponentWithChildren
@using Omni.Blazor.Utilities

@* Single radio button; registers with the enclosing OmniRadioGroup via cascading parameter. *@

<label class="@RootCss" style="@Style" @attributes="Attributes">
    <input type="radio"
           class="omni-radio-input"
           name="@(Group?.GroupName)"
           value="@($"{Value}")"
           checked="@IsSelected"
           disabled="@(Disabled || Group?.Disabled == true)"
           @onchange="OnChange" />
    @if (ChildContent is not null) { @ChildContent }
    else if (!string.IsNullOrEmpty(Label)) { <span>@Label</span> }
</label>

@code {
    [CascadingParameter] internal OmniRadioGroup<TValue>? Group { get; set; }

    /// <summary>Value this radio represents; the group is selected when it equals the group's bound value. Required.</summary>
    [Parameter, EditorRequired] public TValue Value { get; set; } = default!;
    /// <summary>Text label shown next to the radio when no <c>ChildContent</c> is provided.</summary>
    [Parameter] public string? Label { get; set; }
    /// <summary>Disables this radio (also disabled when the group is disabled). Default false.</summary>
    [Parameter] public bool Disabled { get; set; }

    private bool IsSelected => Group?.IsSelected(Value) == true;

    private string RootCss => CssBuilder.Default("omni-radio")
        .AddClass("omni-radio-selected", IsSelected)
        .AddClass("omni-radio-disabled", Disabled)
        .AddClass(Class)
        .Build();

    private Task OnChange(ChangeEventArgs _) => Group?.SelectAsync(Value) ?? Task.CompletedTask;
}
