@namespace Omni.Blazor.Components
@inherits FormComponent<string>
@using Omni.Blazor.Utilities

@* Password text input with an optional show/hide visibility toggle button. *@

<div class="@RootCss" style="@Style" @attributes="Attributes">
    <input class="@InputCss"
           type="@(_visible ? "text" : "password")"
           value="@Value"
           placeholder="@Placeholder"
           disabled="@Disabled"
           readonly="@ReadOnly"
           minlength="@MinLength"
           autocomplete="@Autocomplete"
           name="@Name"
           @oninput="OnInput" />
    @if (ShowToggle)
    {
        <button type="button" class="omni-input-group-ico omni-input-group-ico-right"
                style="border:0;background:none;cursor:pointer;color:inherit;pointer-events:auto;"
                tabindex="-1"
                @onclick="ToggleVisibility">
            <OmniIcon Name="@(_visible ? "eye-off" : "eye")" Size="ComponentSize.Sm" />
        </button>
    }
</div>

@code {
    /// <summary>Placeholder text shown when the input is empty.</summary>
    [Parameter] public string? Placeholder { get; set; }
    /// <summary>HTML <c>autocomplete</c> attribute. Default "current-password".</summary>
    [Parameter] public string? Autocomplete { get; set; } = "current-password";
    /// <summary>Visual size of the input. Default <c>Md</c>.</summary>
    [Parameter] public ComponentSize Size { get; set; } = ComponentSize.Md;
    /// <summary>Minimum length enforced via the input's <c>minlength</c> attribute. Default null (none).</summary>
    [Parameter] public int? MinLength { get; set; }
    /// <summary>Show the eye button that toggles between masked and plain text. Default true.</summary>
    [Parameter] public bool ShowToggle { get; set; } = true;

    private bool _visible;

    // Wrapper div is the consumer-visible root, so Class is appended here.
    private string RootCss => CssBuilder.Default("omni-input-group")
        .AddClass("omni-input-group-right")
        .AddClass(Class)
        .Build();

    private string InputCss => CssBuilder.Default("omni-input")
        .AddClass("omni-input-sm", Size == ComponentSize.Sm)
        .AddClass("omni-input-lg", Size == ComponentSize.Lg)
        .AddClass("omni-invalid",  IsInvalid)
        .Build();

    private void ToggleVisibility() => _visible = !_visible;

    private Task OnInput(ChangeEventArgs e) => SetValueAsync(e.Value?.ToString());
}
