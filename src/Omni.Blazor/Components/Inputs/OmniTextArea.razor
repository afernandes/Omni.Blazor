@namespace Omni.Blazor.Components
@inherits FormComponent<string>
@using Omni.Blazor.Utilities

@* Multi-line text input (<textarea>) bound to a string value. *@

<textarea class="@RootCss"
          style="@Style"
          rows="@Rows"
          placeholder="@Placeholder"
          disabled="@Disabled"
          readonly="@ReadOnly"
          maxlength="@MaxLength"
          name="@Name"
          @oninput="OnInput"
          @attributes="Attributes">@Value</textarea>

@code {
    /// <summary>Placeholder text shown when the textarea is empty.</summary>
    [Parameter] public string? Placeholder { get; set; }
    /// <summary>Visible number of text rows. Default 4.</summary>
    [Parameter] public int Rows { get; set; } = 4;
    /// <summary>Maximum number of characters allowed (via <c>maxlength</c>). Default null (no limit).</summary>
    [Parameter] public int? MaxLength { get; set; }

    private string RootCss => CssBuilder.Default("omni-input")
        .AddClass("omni-textarea")
        .AddClass("omni-invalid", IsInvalid)
        .AddClass(Class)
        .Build();

    private Task OnInput(ChangeEventArgs e) => SetValueAsync(e.Value?.ToString());
}
