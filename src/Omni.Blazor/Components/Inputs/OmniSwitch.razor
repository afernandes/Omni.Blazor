@namespace Omni.Blazor.Components
@inherits FormComponent<bool>
@using Omni.Blazor.Utilities

@* Toggle switch bound to a bool value, with an optional inline label. *@

<label class="@RootCss" style="@Style" @attributes="Attributes">
    <input type="checkbox"
           class="omni-switch-input"
           checked="@Value"
           disabled="@Disabled"
           name="@Name"
           @onchange="OnChange" />
    @if (ChildContent is not null) { @ChildContent }
    else if (!string.IsNullOrEmpty(Label)) { <span>@Label</span> }
</label>

@code {
    /// <summary>Text label shown next to the switch when no <c>ChildContent</c> is provided.</summary>
    [Parameter] public string? Label { get; set; }
    /// <summary>Custom label content; rendered instead of <see cref="Label"/> when provided.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string RootCss => CssBuilder.Default("omni-switch")
        .AddClass(Class)
        .Build();

    private Task OnChange(ChangeEventArgs e)
    {
        var v = e.Value is bool b && b;
        return SetValueAsync(v);
    }
}
