@namespace Omni.Blazor.Components
@typeparam TValue
@inherits FormComponent<TValue>
@using Omni.Blazor.Utilities

<select class="@RootCss"
        style="@Style"
        disabled="@Disabled"
        name="@Name"
        value="@FormatValue(Value)"
        @onchange="OnChange"
        @attributes="Attributes">
    @if (Placeholder is not null)
    {
        <option value="" disabled selected="@(Value is null)">@Placeholder</option>
    }
    @if (Items is not null)
    {
        foreach (var item in Items)
        {
            // Without a ValueSelector each item *is* its own value (identity).
            // Using `default` here made every option share the same value, so
            // any selection resolved back to default(TValue).
            var v = FormatValue(ValueSelector is not null ? ValueSelector(item) : item);
            var t = TextSelector is not null ? TextSelector(item) : item?.ToString() ?? "";
            <option value="@v">@t</option>
        }
    }
    @ChildContent
</select>

@code {
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public IEnumerable<TValue>? Items { get; set; }
    [Parameter] public Func<TValue?, TValue?>? ValueSelector { get; set; }
    [Parameter] public Func<TValue?, string>? TextSelector { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string RootCss => CssBuilder.Default("omni-select")
        .AddClass("omni-invalid", IsInvalid)
        .AddClass(Class)
        .Build();

    private string? FormatValue(TValue? v) => v?.ToString();

    private Task OnChange(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrEmpty(raw)) return SetValueAsync(default);
        try
        {
            var target = typeof(TValue);
            target = Nullable.GetUnderlyingType(target) ?? target;
            // Convert.ChangeType can't parse an enum's name back to the enum —
            // it throws, so enum-valued selects need Enum.Parse explicitly.
            object converted = target.IsEnum
                ? Enum.Parse(target, raw)
                : Convert.ChangeType(raw, target, System.Globalization.CultureInfo.InvariantCulture);
            return SetValueAsync((TValue?)converted);
        }
        catch
        {
            return SetValueAsync(default);
        }
    }
}
