@namespace Omni.Blazor.Components
@inherits FormComponent<bool>
@using Omni.Blazor.Utilities

<label class="@RootCss" style="@Style" @attributes="Attributes">
    <input type="checkbox"
           class="omni-check-input"
           checked="@Value"
           disabled="@Disabled"
           name="@Name"
           @onchange="OnChange" />
    @if (ChildContent is not null) { <span class="omni-check-label">@ChildContent</span> }
    else if (!string.IsNullOrEmpty(Label)) { <span class="omni-check-label">@Label</span> }
</label>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string RootCss => CssBuilder.Default("omni-check")
        .AddClass(Class)
        .Build();

    private Task OnChange(ChangeEventArgs e)
    {
        var v = e.Value is bool b && b;
        return SetValueAsync(v);
    }
}
