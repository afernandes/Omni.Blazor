@namespace Omni.Blazor.Components
@inherits OmniComponent
@using System.Linq
@using Omni.Blazor.Models
@using Omni.Blazor.State
@using Omni.Blazor.Utilities

@*
    Password strength meter + configurable requirement checklist. Pair it with
    OmniPassword. Policy-agnostic: the default rules are driven by the same knobs
    as ASP.NET Identity's PasswordOptions (MinLength, RequireUppercase / Lowercase
    / Digit / Symbol, RequiredUniqueChars). For a fully custom policy, pass Rules
    (label + predicate) and the defaults are ignored. The 4-segment meter reflects
    the fraction of rules satisfied; full strength only when ALL rules pass.

    Usage (Identity-style toggles):
        <OmniPasswordStrength Password="@pw" MinLength="10"
                              RequireSymbol="false" RequiredUniqueChars="4" />

    Usage (custom rules):
        <OmniPasswordStrength Password="@pw" Rules="_rules" />
        @code {
            private readonly OmniPasswordRule[] _rules = {
                new("Pelo menos 12 caracteres", p => p.Length >= 12),
                new("Não conter o nome de usuário", p => !p.Contains("admin", StringComparison.OrdinalIgnoreCase)),
            };
        }
*@

<div class="@RootCss" style="@Style" @attributes="Attributes">
    <div class="omni-pwstrength-meter" aria-hidden="true">
        @for (var i = 1; i <= 4; i++)
        {
            <div class="omni-pwstrength-seg @(i <= _score ? LevelSegClass : null)"></div>
        }
    </div>
    @if (ShowLabel)
    {
        <div class="omni-pwstrength-label">
            <span>@LabelText</span>
            <b style="@($"color:{LevelColor}")">@LevelWord</b>
        </div>
    }
    @if (ShowRules && _rules.Count > 0)
    {
        <div class="omni-pwstrength-rules">
            @foreach (var r in _rules)
            {
                <div class="omni-pwstrength-rule @(r.Met ? "omni-pwstrength-rule-met" : null)" @key="r.Label">
                    <OmniIcon Name="@(r.Met ? "check" : "x")" Size="ComponentSize.Sm" />
                    <span>@r.Label</span>
                </div>
            }
        </div>
    }
</div>

@code {
    /// <summary>The password to evaluate (read-only; this component never owns the value).</summary>
    [Parameter] public string? Password { get; set; }

    /// <summary>Minimum length rule. Set to 0 to drop the length rule. Default 8.</summary>
    [Parameter] public int MinLength { get; set; } = 8;

    /// <summary>Require an uppercase letter (default rule). Default true.</summary>
    [Parameter] public bool RequireUppercase { get; set; } = true;

    /// <summary>Require a lowercase letter (default rule). Default true.</summary>
    [Parameter] public bool RequireLowercase { get; set; } = true;

    /// <summary>Require a digit (default rule). Default true.</summary>
    [Parameter] public bool RequireDigit { get; set; } = true;

    /// <summary>Require a non-alphanumeric symbol (default rule). Default true.</summary>
    [Parameter] public bool RequireSymbol { get; set; } = true;

    /// <summary>Require at least N distinct characters (default rule). 0 disables it.</summary>
    [Parameter] public int RequiredUniqueChars { get; set; }

    /// <summary>Fully custom rule set. When provided, the built-in toggles above are ignored.</summary>
    [Parameter] public IEnumerable<OmniPasswordRule>? Rules { get; set; }

    /// <summary>Show the strength word + caption line. Default true.</summary>
    [Parameter] public bool ShowLabel { get; set; } = true;

    /// <summary>Caption text on the label line. Default "Força da senha".</summary>
    [Parameter] public string LabelText { get; set; } = "Força da senha";

    /// <summary>Show the per-rule checklist. Default true.</summary>
    [Parameter] public bool ShowRules { get; set; } = true;

    internal int RecomputeCount;
    private int _score;
    private List<RuleState> _rules = new();
    private readonly record struct RuleState(string Label, bool Met);

    protected override void OnInitialized()
    {
        RegisterParameter<string?>(nameof(Password)).WithParameter(() => Password).WithChangeHandler(Recompute).Attach();
        RegisterParameter<int>(nameof(MinLength)).WithParameter(() => MinLength).WithChangeHandler(Recompute).Attach();
        RegisterParameter<bool>(nameof(RequireUppercase)).WithParameter(() => RequireUppercase).WithChangeHandler(Recompute).Attach();
        RegisterParameter<bool>(nameof(RequireLowercase)).WithParameter(() => RequireLowercase).WithChangeHandler(Recompute).Attach();
        RegisterParameter<bool>(nameof(RequireDigit)).WithParameter(() => RequireDigit).WithChangeHandler(Recompute).Attach();
        RegisterParameter<bool>(nameof(RequireSymbol)).WithParameter(() => RequireSymbol).WithChangeHandler(Recompute).Attach();
        RegisterParameter<int>(nameof(RequiredUniqueChars)).WithParameter(() => RequiredUniqueChars).WithChangeHandler(Recompute).Attach();
        RegisterParameter<IEnumerable<OmniPasswordRule>?>(nameof(Rules)).WithParameter(() => Rules).WithChangeHandler(Recompute).Attach();
    }

    private void Recompute()
    {
        RecomputeCount++;
        var pw = Password ?? "";
        var defs = Rules?.ToList() ?? BuildDefaultRules();
        _rules = defs.Select(r => new RuleState(r.Label, SafeTest(r.Test, pw))).ToList();

        var total = _rules.Count;
        var met = _rules.Count(r => r.Met);
        _score = pw.Length == 0 || total == 0
            ? 0
            : met >= total ? 4 : Math.Clamp((int)Math.Ceiling(met / (double)total * 4), 1, 3);
    }

    private List<OmniPasswordRule> BuildDefaultRules()
    {
        var list = new List<OmniPasswordRule>();
        if (MinLength > 0) list.Add(new($"Pelo menos {MinLength} caracteres", p => p.Length >= MinLength));
        if (RequireUppercase) list.Add(new("Uma letra maiúscula", p => p.Any(char.IsUpper)));
        if (RequireLowercase) list.Add(new("Uma letra minúscula", p => p.Any(char.IsLower)));
        if (RequireDigit) list.Add(new("Um número", p => p.Any(char.IsDigit)));
        if (RequireSymbol) list.Add(new("Um símbolo", p => p.Any(c => !char.IsLetterOrDigit(c))));
        if (RequiredUniqueChars > 1) list.Add(new($"Pelo menos {RequiredUniqueChars} caracteres distintos", p => p.Distinct().Count() >= RequiredUniqueChars));
        return list;
    }

    private static bool SafeTest(Func<string, bool>? test, string pw)
    {
        try { return test?.Invoke(pw) ?? false; }
        catch { return false; }
    }

    private string LevelWord => _score switch
    {
        1 => "Fraca", 2 => "Razoável", 3 => "Boa", 4 => "Forte", _ => "—"
    };
    private string LevelSegClass => _score switch
    {
        1 => "omni-pwstrength-seg-weak",
        2 => "omni-pwstrength-seg-fair",
        3 => "omni-pwstrength-seg-good",
        4 => "omni-pwstrength-seg-strong",
        _ => ""
    };
    private string LevelColor => _score switch
    {
        1 => "var(--omni-danger)",
        2 => "var(--omni-warn)",
        3 or 4 => "var(--omni-good)",
        _ => "var(--omni-fg-soft)"
    };

    private string RootCss => CssBuilder.Default("omni-pwstrength").AddClass(Class).Build();
}
