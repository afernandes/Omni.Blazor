@namespace Omni.Blazor.Components
@inherits OmniComponentWithChildren
@using Omni.Blazor.Utilities

@* Renders a keyboard key/shortcut as a styled <kbd> element. *@

<kbd class="@RootCss" style="@Style" @attributes="Attributes">
    @if (ChildContent is not null) { @ChildContent }
    else { @Text }
</kbd>

@code {
    /// <summary>Key text to display, used when no <see cref="OmniComponentWithChildren.ChildContent"/> is supplied.</summary>
    [Parameter] public string? Text { get; set; }

    private string RootCss => CssBuilder.Default("omni-kbd")
        .AddClass(Class)
        .Build();
}
