@namespace Omni.Blazor.Components
@inherits OmniComponent
@using System.Text
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.AspNetCore.Components.RenderTree
@using Omni.Blazor.Utilities

@*
    OmniMarkdown — renders CommonMark-ish Markdown as HTML (RadzenMarkdown port).
    Self-contained C# parser, no JS / no external package. XSS-safe: text is
    escaped, URLs go through a scheme allow-list, and raw HTML is escaped unless
    AllowHtml is set (then it passes a best-effort sanitizer).

    Usage:
        <OmniMarkdown Text="@("# Olá\n\nTexto **em negrito** e `código`.")" />
      or write the markdown between the tags:
        <OmniMarkdown>
        ## Título
        - item 1
        - item 2
        </OmniMarkdown>
*@

<div class="@RootCss" style="@Style" @attributes="Attributes">@Rendered</div>

@code {
    /// <summary>The markdown source. Takes precedence over <see cref="ChildContent"/>.</summary>
    [Parameter] public string? Text { get; set; }

    /// <summary>Markdown written raw between the tags (text frames are concatenated).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// When true, embedded raw HTML is sanitized and rendered; when false (default)
    /// it is escaped and shown literally. Only enable for trusted content — the
    /// sanitizer is best-effort.
    /// </summary>
    [Parameter] public bool AllowHtml { get; set; }

    private string? _cachedSource;
    private bool _cachedAllowHtml;
    private MarkupString _cached;

    // Number of times the Markdown parser actually ran — exposed for tests to assert
    // memoization (re-renders that don't change the source must NOT reparse).
    internal int ParseCount { get; private set; }

    // Memoized: reparse only when the source text or AllowHtml changes. Comparing the
    // fields directly avoids allocating a combined cache key on every (cache-hit) render.
    // Unrelated re-renders (Class/Style/parent) reuse the cached MarkupString instead of
    // re-running the parser every frame — the streaming hot path re-rendered O(n²).
    private MarkupString Rendered
    {
        get
        {
            string? source = ResolveSource();
            if (!string.Equals(source, _cachedSource, StringComparison.Ordinal) || AllowHtml != _cachedAllowHtml)
            {
                _cached = (MarkupString)MarkdownRenderer.ToHtml(source, AllowHtml);
                _cachedSource = source;
                _cachedAllowHtml = AllowHtml;
                ParseCount++;
            }
            return _cached;
        }
    }

    private string RootCss => CssBuilder.Default("omni-markdown").AddClass(Class).Build();

    private string? ResolveSource()
    {
        if (!string.IsNullOrEmpty(Text)) return Text;
        if (ChildContent is not null) return Dedent(ExtractText(ChildContent));
        return null;
    }

    // Render the child fragment into a throwaway builder and concatenate its
    // text/markup frames — this recovers the raw markdown written between the tags.
    // BL0006: reading RenderTree frames is deliberate here — recovering the raw markdown
    // authored between the tags is exactly what needs the frame contents, and there is no
    // public API for it. Contained to this one helper.
#pragma warning disable BL0006
    private static string ExtractText(RenderFragment fragment)
    {
        using var builder = new RenderTreeBuilder();
        builder.AddContent(0, fragment);
        var range = builder.GetFrames();
        var frames = range.Array;
        var sb = new StringBuilder();
        for (int i = 0; i < range.Count; i++)
        {
            var f = frames[i];
            if (f.FrameType == RenderTreeFrameType.Text) sb.Append(f.TextContent);
            else if (f.FrameType == RenderTreeFrameType.Markup) sb.Append(f.MarkupContent);
        }
        return sb.ToString();
    }
#pragma warning restore BL0006

    // Strip the common leading indentation introduced by writing markdown
    // indented under the .razor tag.
    private static string Dedent(string text)
    {
        var lines = text.Replace("\r\n", "\n").Split('\n');
        int min = int.MaxValue;
        foreach (var l in lines)
        {
            if (string.IsNullOrWhiteSpace(l)) continue;
            int n = 0; while (n < l.Length && l[n] == ' ') n++;
            if (n < min) min = n;
        }
        if (min is 0 or int.MaxValue) return text.Trim('\n');
        for (int i = 0; i < lines.Length; i++)
            if (lines[i].Length >= min) lines[i] = lines[i].Substring(min);
        return string.Join("\n", lines).Trim('\n');
    }
}
