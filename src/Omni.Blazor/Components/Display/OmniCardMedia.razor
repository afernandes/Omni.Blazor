@namespace Omni.Blazor.Components
@using Omni.Blazor.Models
@using Omni.Blazor.Utilities
@inherits OmniComponentWithChildren

@*  Structural card part — a flush image / media block. Carries the
    `omni-card-part` marker so the parent card's body auto-wrapper dissolves
    (display:contents) and this becomes a direct flex child of the card.
    Position Top/Bottom render an image cap; Overlay fills the card with the
    image and lays ChildContent on top; Start/End sit beside the body in a
    horizontal card.  *@
<div class="@RootCss" style="@RootStyle" @attributes="Attributes">
    @if (!string.IsNullOrEmpty(Src))
    {
        <img src="@Src" alt="@Alt" />
    }
    @if (Position == CardMediaPosition.Overlay)
    {
        <div class="omni-card-media-content">@ChildContent</div>
    }
    else if (string.IsNullOrEmpty(Src))
    {
        @ChildContent
    }
</div>

@code {
    /// <summary>Image URL. When set, renders an <c>&lt;img&gt;</c>.</summary>
    [Parameter] public string? Src { get; set; }

    /// <summary>Alternative text for the image.</summary>
    [Parameter] public string? Alt { get; set; }

    /// <summary>Where the media sits in the card. Default <see cref="CardMediaPosition.Top"/>.</summary>
    [Parameter] public CardMediaPosition Position { get; set; } = CardMediaPosition.Top;

    /// <summary>Optional fixed height (e.g. <c>"160px"</c>).</summary>
    [Parameter] public string? Height { get; set; }

    private string RootCss => CssBuilder.Default("omni-card-part omni-card-media")
        .AddClass($"omni-card-media-{Position.ToString().ToLowerInvariant()}")
        .AddClass(Class)
        .Build();

    private string? RootStyle
    {
        get
        {
            var h = string.IsNullOrEmpty(Height) ? null : $"height: {Height};";
            return (h, Style) switch
            {
                (null, null) => null,
                (null, _)    => Style,
                (_, null)    => h,
                _            => h + Style
            };
        }
    }
}
