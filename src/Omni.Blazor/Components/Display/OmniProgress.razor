@namespace Omni.Blazor.Components
@inherits OmniComponent
@using Omni.Blazor.Utilities

@* Horizontal progress bar, or a segmented variant (e.g. password strength) when Segments > 0. *@

@if (Segments > 0)
{
    <div class="@SegCss" style="@Style" @attributes="Attributes">
        @for (int i = 0; i < Segments; i++)
        {
            <div class="@("omni-progress-seg-cell" + (i < Active ? " omni-on" : ""))"></div>
        }
    </div>
}
else
{
    <div class="@BarCss" style="@Style" @attributes="Attributes">
        <div class="omni-progress-bar" style="@BarStyle"></div>
    </div>
}

@code {
    /// <summary>Current progress value (relative to <see cref="Max"/>); clamped to 0-100% of the bar width.</summary>
    [Parameter] public double Value { get; set; }
    /// <summary>Value that represents 100% fill. Default 100.</summary>
    [Parameter] public double Max { get; set; } = 100;
    /// <summary>Bar thickness (Md default): Sm, Md, or Lg.</summary>
    [Parameter] public ComponentSize Size { get; set; } = ComponentSize.Md;
    /// <summary>Color variant of the bar fill (Accent default); Good/Warn/Danger map to semantic colors.</summary>
    [Parameter] public BadgeVariant Variant { get; set; } = BadgeVariant.Accent;

    /// <summary>Optional arbitrary CSS colour for the bar (overrides <see cref="Variant"/>).</summary>
    [Parameter] public string? Color { get; set; }

    /// <summary>If > 0, render as segmented progress (used for password strength).</summary>
    [Parameter] public int Segments { get; set; }
    /// <summary>Number of filled segments (segmented mode); also drives the strength color via omni-s1..s4.</summary>
    [Parameter] public int Active { get; set; }

    private double Clamped => Math.Max(0, Math.Min(100, Max == 0 ? 0 : (Value / Max) * 100.0));

    private string BarStyle
    {
        get
        {
            var w = "width: " + Clamped.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) + "%;";
            return string.IsNullOrEmpty(Color) ? w : w + " background: " + Color + ";";
        }
    }

    private string BarCss => CssBuilder.Default("omni-progress")
        .AddClass(Size == ComponentSize.Sm ? "omni-progress-sm" : Size == ComponentSize.Lg ? "omni-progress-lg" : null)
        .AddClass(Variant switch
        {
            BadgeVariant.Good   => "omni-progress-good",
            BadgeVariant.Warn   => "omni-progress-warn",
            BadgeVariant.Danger => "omni-progress-danger",
            _ => null
        })
        .AddClass(Class)
        .Build();

    private string SegCss => CssBuilder.Default("omni-progress-seg")
        .AddClass(Active switch
        {
            1 => "omni-s1",
            2 => "omni-s2",
            3 => "omni-s3",
            4 => "omni-s4",
            _ => null
        })
        .AddClass(Class)
        .Build();
}
