@namespace Omni.Blazor.Components
@inherits OmniComponentWithChildren
@using Omni.Blazor.Utilities

@* Compact pill/tag button — optional dot and icon, with active/accent/static visual states. *@

<button type="button" class="@RootCss" style="@Style" @onclick="HandleClickAsync" @attributes="Attributes">
    @if (ShowDot)
    {
        <span class="omni-chip-dot"></span>
    }
    @if (!string.IsNullOrEmpty(Icon))
    {
        <OmniIcon Name="@Icon" Size="ComponentSize.Sm" />
    }
    @if (ChildContent is not null) { @ChildContent }
    else if (!string.IsNullOrEmpty(Text)) { @Text }
</button>

@code {
    /// <summary>Chip label text, used when no <see cref="OmniComponentWithChildren.ChildContent"/> is supplied.</summary>
    [Parameter] public string? Text { get; set; }
    /// <summary>Optional icon name rendered before the text.</summary>
    [Parameter] public string? Icon { get; set; }
    /// <summary>When true, applies the active/selected visual state.</summary>
    [Parameter] public bool Active { get; set; }
    /// <summary>When true, shows a small leading status dot.</summary>
    [Parameter] public bool ShowDot { get; set; }
    /// <summary>When true, applies the accent color styling.</summary>
    [Parameter] public bool Accent { get; set; }
    /// <summary>When true, renders as a non-interactive (display-only) chip.</summary>
    [Parameter] public bool Static { get; set; }
    /// <summary>Fired when the chip is clicked.</summary>
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    private string RootCss => CssBuilder.Default("omni-chip")
        .AddClass("omni-chip-active", Active)
        .AddClass("omni-chip-accent", Accent)
        .AddClass("omni-chip-static", Static)
        .AddClass(Class)
        .Build();

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (OnClick.HasDelegate) await OnClick.InvokeAsync(e);
    }
}
