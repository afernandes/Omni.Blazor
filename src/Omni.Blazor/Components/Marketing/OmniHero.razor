@namespace Omni.Blazor.Components
@inherits OmniComponentWithChildren
@using Omni.Blazor.Utilities

@* Marketing hero section composing an eyebrow, title, subtitle and a CTA row above arbitrary child content. *@

<section class="@RootCss" style="@Style" @attributes="Attributes">
    @if (EyebrowContent is not null) { @EyebrowContent }
    else if (!string.IsNullOrEmpty(Eyebrow))
    {
        <OmniEyebrow Text="@Eyebrow" />
    }

    @if (TitleContent is not null) { @TitleContent }
    else if (!string.IsNullOrEmpty(Title))
    {
        <h1 class="omni-hero-title">@((MarkupString)Title)</h1>
    }

    @if (!string.IsNullOrEmpty(Subtitle))
    {
        <p class="omni-hero-sub">@Subtitle</p>
    }

    @if (CtaContent is not null)
    {
        <div class="omni-hero-cta-row">@CtaContent</div>
    }

    @ChildContent
</section>

@code {
    /// <summary>Eyebrow text rendered in an <see cref="OmniEyebrow"/>; ignored when <see cref="EyebrowContent"/> is set.</summary>
    [Parameter] public string? Eyebrow { get; set; }
    /// <summary>Custom eyebrow markup; when set it replaces the <see cref="Eyebrow"/> text.</summary>
    [Parameter] public RenderFragment? EyebrowContent { get; set; }
    /// <summary>Hero title rendered as an <c>h1</c>; the value is treated as raw HTML (MarkupString). Ignored when <see cref="TitleContent"/> is set.</summary>
    [Parameter] public string? Title { get; set; }
    /// <summary>Custom title markup; when set it replaces the <see cref="Title"/> heading.</summary>
    [Parameter] public RenderFragment? TitleContent { get; set; }
    /// <summary>Subtitle paragraph rendered below the title; omitted when empty.</summary>
    [Parameter] public string? Subtitle { get; set; }
    /// <summary>Call-to-action markup rendered in a dedicated row below the subtitle.</summary>
    [Parameter] public RenderFragment? CtaContent { get; set; }

    private string RootCss => CssBuilder.Default("omni-hero")
        .AddClass(Class)
        .Build();
}
