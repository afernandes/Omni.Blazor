@namespace Omni.Blazor.Components
@inherits OmniComponent
@implements IAsyncDisposable
@inject NavigationManager Nav
@inject DialogService Dialogs
@inject IJSRuntime JS

@*
    Intercepts navigation attempts when `When` returns true and asks the user to
    confirm. Inspired by MudBlazor's MudExitPrompt, but the prompt is gated by a
    predicate (most apps only want to prompt while there are unsaved changes).

      <OmniExitPrompt When="@(() => form.IsModified && !saved)" />

    Covers two cases:
      1. In-app navigation (Blazor route change) — uses NavigationManager.
         RegisterLocationChangingHandler + DialogService.Confirm (or window.confirm
         when UseNativePrompt=true). Blocks via context.PreventNavigation().
      2. Browser unload (tab close / refresh / typing a new URL) — JS hooks
         window.beforeunload. The browser always shows its native prompt; custom
         text is intentionally ignored by modern browsers.

    Renders nothing.
*@

@code {
    /// <summary>Predicate that gates the prompt: navigation is intercepted only while it returns true. When null, the prompt is always active.</summary>
    [Parameter] public Func<bool>? When { get; set; }
    /// <summary>Title of the confirmation dialog (DialogService path only).</summary>
    [Parameter] public string Title { get; set; } = "Sair sem salvar?";
    /// <summary>Body message of the confirmation prompt (used by both the dialog and the native window.confirm).</summary>
    [Parameter] public string Text { get; set; } = "Você tem alterações não salvas. Deseja sair mesmo assim?";
    /// <summary>Label of the confirm (leave) button in the dialog.</summary>
    [Parameter] public string ConfirmText { get; set; } = "Sair sem salvar";
    /// <summary>Label of the cancel (stay) button in the dialog.</summary>
    [Parameter] public string CancelText { get; set; } = "Continuar editando";
    /// <summary>When true, uses the browser's native window.confirm instead of the Omni DialogService for in-app navigation. Default false.</summary>
    [Parameter] public bool UseNativePrompt { get; set; }

    private readonly string _id = $"ep-{Guid.NewGuid():N}";
    private IDisposable? _locationHandle;
    private bool _beforeUnloadActive;
    private bool _disposed;

    protected override void OnInitialized()
    {
        // Intercepting Blazor route changes is free — register once and let the
        // handler short-circuit when When() is false. This avoids tearing the
        // handler down and rebuilding it on every parameter toggle.
        _locationHandle = Nav.RegisterLocationChangingHandler(OnLocationChanging);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_disposed) return;
        var shouldGuard = When?.Invoke() ?? true;
        await SyncBeforeUnload(shouldGuard);
    }

    private async ValueTask SyncBeforeUnload(bool shouldGuard)
    {
        if (shouldGuard == _beforeUnloadActive) return;
        try
        {
            if (shouldGuard) await JS.InvokeVoidAsync("omniBlazor.enableExitPrompt",  _id);
            else             await JS.InvokeVoidAsync("omniBlazor.disableExitPrompt", _id);
            _beforeUnloadActive = shouldGuard;
        }
        catch { /* JS may not be ready during prerender — retry next OnParametersSet */ }
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (_disposed) return;
        var shouldGuard = When?.Invoke() ?? true;
        if (!shouldGuard) return;

        bool? confirmed;
        if (UseNativePrompt)
        {
            try { confirmed = await JS.InvokeAsync<bool>("window.confirm", Text); }
            catch { confirmed = true; /* fail-open if JS unavailable */ }
        }
        else
        {
            confirmed = await Dialogs.Confirm(Text, Title, new Models.ConfirmOptions
            {
                OkButtonText = ConfirmText,
                CancelButtonText = CancelText,
                Icon = "alert-triangle"
            });
        }

        if (confirmed != true)
        {
            context.PreventNavigation();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed) return;
        _disposed = true;
        _locationHandle?.Dispose();
        _locationHandle = null;
        if (_beforeUnloadActive)
        {
            try { await JS.InvokeVoidAsync("omniBlazor.disableExitPrompt", _id); }
            catch { }
            _beforeUnloadActive = false;
        }
    }
}
