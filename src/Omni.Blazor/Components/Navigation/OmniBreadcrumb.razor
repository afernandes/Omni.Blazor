@namespace Omni.Blazor.Components
@inherits OmniComponent
@using Omni.Blazor.Utilities

@* Breadcrumb trail (`<nav>`): renders Items as "/"-separated links, with the last (or path-less) item shown as the current page. *@
<nav class="@RootCss" style="@Style" @attributes="Attributes">
    @if (Items is not null)
    {
        var i = 0;
        foreach (var it in Items)
        {
            var last = i == Items.Count() - 1;
            if (i > 0) { <span class="omni-breadcrumb-sep">/</span> }
            if (last || string.IsNullOrEmpty(it.Path)) { <span class="omni-breadcrumb-current">@it.Text</span> }
            else { <a href="@it.Path">@it.Text</a> }
            i++;
        }
    }
</nav>

@code {
    public record Item(string Text, string? Path = null);

    /// <summary>Ordered trail of crumbs; each Item is a Text plus an optional Path (link). The last item renders as the current page.</summary>
    [Parameter] public IEnumerable<Item>? Items { get; set; }

    private string RootCss => CssBuilder.Default("omni-breadcrumb")
        .AddClass(Class)
        .Build();
}
