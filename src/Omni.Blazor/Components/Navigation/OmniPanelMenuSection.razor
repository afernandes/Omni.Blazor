@namespace Omni.Blazor.Components
@inherits OmniComponentWithChildren

@* Groups panel-menu items under an optional section heading. *@
@if (!string.IsNullOrEmpty(Label))
{
    <div class="omni-sidebar-section-label">@Label</div>
}
<div class="omni-panel-menu" style="@Style">@ChildContent</div>

@code {
    /// <summary>Optional uppercase section heading rendered above the grouped items; when empty, no heading is shown.</summary>
    [Parameter] public string? Label { get; set; }
}
