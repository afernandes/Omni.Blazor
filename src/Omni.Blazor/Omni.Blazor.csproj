<Project Sdk="Microsoft.NET.Sdk.Razor">

  <!-- TargetFramework, language, build-quality props (Deterministic, Source
       Link, symbols) come from /Directory.Build.props. Package versions are
       centralized in /Directory.Packages.props (CPM). -->

  <PropertyGroup>
    <RootNamespace>Omni.Blazor</RootNamespace>
    <AssemblyName>Omni.Blazor</AssemblyName>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- NuGet package metadata. Version is derived from git tags by MinVer
       (vX.Y.Z). To cut a release: tag with `git tag v1.2.3` and push it. -->
  <PropertyGroup>
    <PackageId>Omni.Blazor</PackageId>
    <Title>Omni.Blazor</Title>
    <Description>Blazor component library for .NET 10 — 80+ components (DataGrid, DatePicker, Dialog, Stepper, BottomSheet, FAB, ...), warm cream/amber design system, dark mode and runtime accent swap.</Description>
    <PackageTags>blazor;components;ui;datagrid;design-system;dotnet;razor;omni</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" />
    <PackageReference Include="AspNetCore.SassCompiler" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <!-- Test project sees private state via internal accessibility (e.g.
         OmniBarcode.DisplayValue) without exposing it on the public API. -->
    <InternalsVisibleTo Include="Omni.Blazor.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- Keep SCSS sources out of static web assets / output -->
    <Content Remove="Themes\**" />
    <None Include="Themes\**" />
    <!-- sasscompiler.json is a build-time config; never ship it as content -->
    <Content Remove="sasscompiler.json" />
    <None Update="sasscompiler.json" Pack="false" />
  </ItemGroup>

  <ItemGroup>
    <!-- Files shipped inside the .nupkg -->
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
    <None Include="..\..\assets\icon.png" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

</Project>
